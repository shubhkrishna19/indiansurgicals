---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout
  title="Redirecting To Catalogue"
  description="Redirecting to the full online product catalogue."
>
  <meta http-equiv="refresh" content="0; url=/products" />
  <section class="section redirect-page">
    <div class="container redirect-page__panel panel">
      <span class="eyebrow">Redirecting</span>
      <h1>Opening the full product catalogue.</h1>
      <p>The online catalogue is now part of the main catalogue page for a cleaner browsing flow.</p>
      <a href="/products" class="button button--primary">Open full catalogue</a>
    </div>
  </section>
</BaseLayout>

<style>
  .redirect-page {
    min-height: 60vh;
    display: grid;
    align-items: center;
  }

  .redirect-page__panel {
    display: grid;
    gap: 1rem;
    max-width: 46rem;
    padding: 1.5rem;
  }

  .redirect-page__panel h1,
  .redirect-page__panel p {
    margin: 0;
  }

  .redirect-page__panel h1 {
    font-size: clamp(2.2rem, 4vw, 3.6rem);
    line-height: 1;
    letter-spacing: -0.04em;
  }

  .redirect-page__panel p {
    color: var(--color-text-muted);
    line-height: 1.75;
  }
</style>
