---
import BaseLayout from "../layouts/BaseLayout.astro";
import SectionTitle from "../components/SectionTitle.astro";
import { business, getPrimaryContactHref } from "../data/business";
import { getAllCategories } from "../data/catalogue";

const categories = getAllCategories();
const primaryContactHref = getPrimaryContactHref();
const otherWebsiteHref = business.contact.website ? `https://${business.contact.website}` : "";
---

<BaseLayout
  title="Contact And Enquiries"
  description="Contact Indian Surgical Industries for quotations, product guidance, and direct buying communication."
>
  <section class="section contact-hero">
    <div class="container contact-hero__grid">
      <div class="contact-hero__content" data-parallax-group>
        <span class="eyebrow" data-parallax-speed="0.08">Contact And Enquiries</span>
        <h1 data-parallax-speed="0.16">Contact the team for quotations, product guidance, and direct buying communication.</h1>
        <p class="contact-hero__copy">{business.quoteOnlyNote}</p>
        <p class="contact-hero__copy">
          Use the published mobile numbers, telephone line, WhatsApp, and email contacts below for direct
          communication with Indian Surgical Industries.
        </p>

        <div class="contact-hero__actions">
          <a href={primaryContactHref} class="button button--primary">Contact now</a>
          <a href="/products" class="button button--secondary">View product range</a>
        </div>
      </div>

      <aside class="contact-hero__panel panel">
        <p class="contact-hero__panel-kicker">Business Snapshot</p>
        <div class="contact-hero__facts">
          <div>
            <span>Manufacturer</span>
            <strong>{business.brand}</strong>
          </div>
          <div>
            <span>Base</span>
            <strong>{business.manufacturingBase}</strong>
          </div>
          <div>
            <span>Legacy</span>
            <strong>{business.experienceClaim}</strong>
          </div>
          <div>
            <span>Quotation support</span>
            <strong>Direct factory response</strong>
          </div>
        </div>
      </aside>
    </div>
  </section>

  <section class="section section--band">
    <div class="container">
      <SectionTitle
        kicker="Direct Contact Channels"
        title="Choose the best contact channel for your requirement."
        subtitle="Use WhatsApp for fast discussion, call for urgent requirements, or email your shortlisted product family and model details."
        align="left"
      />

      <div class="contact-grid">
        {business.contact.phones.length > 0 && (
          <article class="panel contact-card">
            <span>Mobile</span>
            {business.contact.phones.map((phone) => (
              <a href={`tel:${phone}`}>{phone}</a>
            ))}
          </article>
        )}

        {business.contact.telephones.length > 0 && (
          <article class="panel contact-card">
            <span>Telephone</span>
            {business.contact.telephones.map((phone) => (
              <a href={`tel:${phone}`}>{phone}</a>
            ))}
          </article>
        )}

        {business.contact.whatsappNumber && (
          <article class="panel contact-card">
            <span>WhatsApp</span>
            <a href={`https://wa.me/${business.contact.whatsappNumber}`}>+{business.contact.whatsappNumber}</a>
          </article>
        )}

        {business.contact.emails.length > 0 && (
          <article class="panel contact-card">
            <span>Email</span>
            {business.contact.emails.map((email) => (
              <a href={`mailto:${email}`}>{email}</a>
            ))}
          </article>
        )}

        <article class="panel contact-card">
          <span>Website</span>
          <a href={otherWebsiteHref} target="_blank" rel="noreferrer">Visit Our Other Website</a>
        </article>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container process-grid">
      <div>
        <SectionTitle
          kicker="Best Way To Enquire"
          title="A better shortlist leads to a quicker response."
          subtitle="Share the relevant category, product family, and model reference so the team can guide you faster."
          align="left"
        />

        <ol class="process-list">
          <li>
            <strong>Open the relevant product category.</strong>
            Begin with the category that matches your requirement, such as autoclaves, hollowares, suction units, furniture, or OT equipment.
          </li>
          <li>
            <strong>Shortlist the matching family.</strong>
            Shortlist the product family that best matches your capacity, size, or application requirement.
          </li>
          <li>
            <strong>Share the model and quantity.</strong>
            When you contact the team, mention the product family, required model, quantity, and dispatch location for faster quotation support.
          </li>
        </ol>
      </div>

      <aside class="panel section-list">
        <h2>Product categories</h2>
        <ul>
          {categories.map((category) => (
            <li><a href={`/products/${category.slug}`}>{category.name}</a></li>
          ))}
        </ul>
      </aside>
    </div>
  </section>
</BaseLayout>

<style>
  .contact-hero {
    padding-top: 4.4rem;
  }

  .contact-hero__grid {
    display: grid;
    grid-template-columns: 1.25fr 0.85fr;
    gap: 2rem;
    align-items: start;
  }

  .contact-hero__content {
    display: grid;
    gap: 1.1rem;
  }

  .contact-hero__content h1 {
    font-size: clamp(2.6rem, 5vw, 4.6rem);
    line-height: 0.95;
    letter-spacing: -0.05em;
    max-width: 12ch;
  }

  .contact-hero__copy {
    margin: 0;
    color: var(--color-text-muted);
    line-height: 1.8;
    max-width: 52rem;
  }

  .contact-hero__actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.9rem;
  }

  .contact-hero__panel {
    display: grid;
    gap: 1rem;
    padding: 1.3rem;
  }

  .contact-hero__panel-kicker,
  .contact-card span,
  .status-card span {
    color: var(--color-primary);
    font-size: 0.76rem;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }

  .contact-hero__facts {
    display: grid;
    gap: 0.8rem;
  }

  .contact-hero__facts div {
    padding: 1rem;
    border-radius: 1rem;
    background: rgba(25, 77, 128, 0.06);
  }

  .contact-hero__facts span {
    display: block;
    color: var(--color-text-muted);
    font-size: 0.8rem;
    margin-bottom: 0.35rem;
  }

  .contact-hero__facts strong {
    font-family: var(--font-heading);
    font-size: 1.35rem;
  }

  .section--band {
    background: linear-gradient(180deg, rgba(25, 77, 128, 0.04), rgba(25, 77, 128, 0.01));
  }

  .contact-grid,
  .status-grid {
    display: grid;
    grid-template-columns: repeat(5, minmax(0, 1fr));
    gap: 1rem;
  }

  .contact-card,
  .status-card,
  .section-list {
    display: grid;
    gap: 0.8rem;
    padding: 1.2rem;
  }

  .contact-card a,
  .section-list a {
    color: var(--color-text);
    font-weight: 600;
  }

  .contact-card a {
    word-break: break-word;
  }

  .contact-card p,
  .status-card p {
    margin: 0;
    color: var(--color-text-muted);
    line-height: 1.7;
  }

  .status-card h2,
  .section-list h2 {
    font-size: 1.25rem;
  }

  .process-grid {
    display: grid;
    grid-template-columns: 1.1fr 0.9fr;
    gap: 2rem;
  }

  .process-list {
    display: grid;
    gap: 1rem;
    padding-left: 1.2rem;
    margin: 0;
    color: var(--color-text-muted);
    line-height: 1.75;
  }

  .process-list strong {
    display: block;
    color: var(--color-text);
    margin-bottom: 0.15rem;
  }

  .section-list ul {
    display: grid;
    gap: 0.75rem;
    margin: 0;
    padding-left: 1rem;
    color: var(--color-text-muted);
  }

  @media (max-width: 1100px) {
    .contact-hero__grid,
    .status-grid,
    .process-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }

    .contact-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  @media (max-width: 760px) {
    .contact-hero__grid,
    .contact-grid,
    .status-grid,
    .process-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
