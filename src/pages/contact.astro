---
import BaseLayout from "../layouts/BaseLayout.astro";
import SectionTitle from "../components/SectionTitle.astro";
import { business, getPrimaryContactHref, hasPublicContactDetails } from "../data/business";
import { getAllCategories } from "../data/catalogue";

const contactReady = hasPublicContactDetails();
const categories = getAllCategories();
const primaryContactHref = getPrimaryContactHref();
---

<BaseLayout
  title="Contact And Enquiries"
  description="Review the enquiry status for Indian Surgical Industries and browse the catalogue structure before direct quotation discussion."
>
  <section class="section contact-hero">
    <div class="container contact-hero__grid">
      <div class="contact-hero__content">
        <span class="eyebrow">Enquiry Status</span>
        <h1>Indian Surgical Industries runs this site as a quote-only product catalogue.</h1>
        <p class="contact-hero__copy">{business.quoteOnlyNote}</p>
        <p class="contact-hero__copy">
          {contactReady
            ? "Public contact channels are active below."
            : "Public phone, WhatsApp, and email publication is being finalized. The catalogue and company profile are live so buyers can already review the range properly."}
        </p>

        <div class="contact-hero__actions">
          <a href="/products" class="button button--primary">Browse the catalogue</a>
          <a href={primaryContactHref} class="button button--secondary">
            {contactReady ? "Contact now" : "View contact status"}
          </a>
        </div>
      </div>

      <aside class="contact-hero__panel panel">
        <p class="contact-hero__panel-kicker">Business Snapshot</p>
        <div class="contact-hero__facts">
          <div>
            <span>Manufacturer</span>
            <strong>{business.brand}</strong>
          </div>
          <div>
            <span>Base</span>
            <strong>{business.manufacturingBase}</strong>
          </div>
          <div>
            <span>Legacy</span>
            <strong>{business.experienceClaim}</strong>
          </div>
          <div>
            <span>Commercial mode</span>
            <strong>Quote only</strong>
          </div>
        </div>
      </aside>
    </div>
  </section>

  <section class="section section--band">
    <div class="container">
      <SectionTitle
        kicker="Contact Layer"
        title={contactReady ? "Public contact channels are available." : "Public contact channels are being finalized."}
        subtitle="The website is already usable as a full display catalogue with family pages, model selectors, and specification views."
        align="left"
      />

      {contactReady ? (
        <div class="contact-grid">
          {business.contact.phones.length > 0 && (
            <article class="panel contact-card">
              <span>Mobile</span>
              {business.contact.phones.map((phone) => (
                <a href={`tel:${phone}`}>{phone}</a>
              ))}
            </article>
          )}

          {business.contact.telephones.length > 0 && (
            <article class="panel contact-card">
              <span>Telephone</span>
              {business.contact.telephones.map((phone) => (
                <a href={`tel:${phone}`}>{phone}</a>
              ))}
            </article>
          )}

          {business.contact.whatsappNumber && (
            <article class="panel contact-card">
              <span>WhatsApp</span>
              <a href={`https://wa.me/${business.contact.whatsappNumber}`}>+{business.contact.whatsappNumber}</a>
            </article>
          )}

          {business.contact.emails.length > 0 && (
            <article class="panel contact-card">
              <span>Email</span>
              {business.contact.emails.map((email) => (
                <a href={`mailto:${email}`}>{email}</a>
              ))}
            </article>
          )}

          <article class="panel contact-card">
            <span>Works Address</span>
            <p>{business.contact.addressLines.join(", ")}</p>
          </article>

          <article class="panel contact-card">
            <span>Website</span>
            <p>{business.contact.website}</p>
          </article>
        </div>
      ) : (
        <div class="status-grid">
          <article class="panel status-card">
            <span>Contact publication</span>
            <h2>Pending final public details</h2>
            <p>{business.contactNote}</p>
          </article>

          <article class="panel status-card">
            <span>What buyers can do now</span>
            <h2>Shortlist the right family and model first</h2>
            <p>Use the category, family, and model pages to understand product fit before direct communication is switched on publicly.</p>
          </article>

          <article class="panel status-card">
            <span>Manufacturing base</span>
            <h2>{business.manufacturingBase}</h2>
            <p>{business.marketPresence}</p>
          </article>
        </div>
      )}
    </div>
  </section>

  <section class="section">
    <div class="container process-grid">
      <div>
        <SectionTitle
          kicker="How To Use The Site"
          title="The site is structured for procurement-style navigation."
          subtitle="Move from section to family to model instead of browsing generic cards with incomplete detail."
          align="left"
        />

        <ol class="process-list">
          <li>
            <strong>Open a business section.</strong>
            Review the relevant category first, such as autoclaves, hospital furniture, suction units, or OT lights.
          </li>
          <li>
            <strong>Shortlist the product family.</strong>
            Each family page consolidates images, family summary, and the available model lineup.
          </li>
          <li>
            <strong>Compare models.</strong>
            Use the variant matrix and model switcher to inspect capacities, sizes, and other specification differences.
          </li>
        </ol>
      </div>

      <aside class="panel section-list">
        <h2>Catalogue sections</h2>
        <ul>
          {categories.map((category) => (
            <li><a href={`/products/${category.slug}`}>{category.name}</a></li>
          ))}
        </ul>
      </aside>
    </div>
  </section>
</BaseLayout>

<style>
  .contact-hero {
    padding-top: 4.4rem;
  }

  .contact-hero__grid {
    display: grid;
    grid-template-columns: 1.25fr 0.85fr;
    gap: 2rem;
    align-items: start;
  }

  .contact-hero__content {
    display: grid;
    gap: 1.1rem;
  }

  .contact-hero__content h1 {
    font-size: clamp(2.6rem, 5vw, 4.6rem);
    line-height: 0.95;
    letter-spacing: -0.05em;
    max-width: 12ch;
  }

  .contact-hero__copy {
    margin: 0;
    color: var(--color-text-muted);
    line-height: 1.8;
    max-width: 52rem;
  }

  .contact-hero__actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.9rem;
  }

  .contact-hero__panel {
    display: grid;
    gap: 1rem;
    padding: 1.3rem;
  }

  .contact-hero__panel-kicker,
  .contact-card span,
  .status-card span {
    color: var(--color-primary);
    font-size: 0.76rem;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }

  .contact-hero__facts {
    display: grid;
    gap: 0.8rem;
  }

  .contact-hero__facts div {
    padding: 1rem;
    border-radius: 1rem;
    background: rgba(25, 77, 128, 0.06);
  }

  .contact-hero__facts span {
    display: block;
    color: var(--color-text-muted);
    font-size: 0.8rem;
    margin-bottom: 0.35rem;
  }

  .contact-hero__facts strong {
    font-family: var(--font-heading);
    font-size: 1.35rem;
  }

  .section--band {
    background: linear-gradient(180deg, rgba(25, 77, 128, 0.04), rgba(25, 77, 128, 0.01));
  }

  .contact-grid,
  .status-grid {
    display: grid;
    grid-template-columns: repeat(5, minmax(0, 1fr));
    gap: 1rem;
  }

  .contact-card,
  .status-card,
  .section-list {
    display: grid;
    gap: 0.8rem;
    padding: 1.2rem;
  }

  .contact-card a,
  .section-list a {
    color: var(--color-text);
    font-weight: 600;
  }

  .contact-card a {
    word-break: break-word;
  }

  .contact-card p,
  .status-card p {
    margin: 0;
    color: var(--color-text-muted);
    line-height: 1.7;
  }

  .status-card h2,
  .section-list h2 {
    font-size: 1.25rem;
  }

  .process-grid {
    display: grid;
    grid-template-columns: 1.1fr 0.9fr;
    gap: 2rem;
  }

  .process-list {
    display: grid;
    gap: 1rem;
    padding-left: 1.2rem;
    margin: 0;
    color: var(--color-text-muted);
    line-height: 1.75;
  }

  .process-list strong {
    display: block;
    color: var(--color-text);
    margin-bottom: 0.15rem;
  }

  .section-list ul {
    display: grid;
    gap: 0.75rem;
    margin: 0;
    padding-left: 1rem;
    color: var(--color-text-muted);
  }

  @media (max-width: 1100px) {
    .contact-hero__grid,
    .status-grid,
    .process-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }

    .contact-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  @media (max-width: 760px) {
    .contact-hero__grid,
    .contact-grid,
    .status-grid,
    .process-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
