---
import BaseLayout from '../layouts/BaseLayout.astro';
import CTAButtons from '../components/CTAButtons.astro';
import MotionController from '../components/MotionController.astro';
import { business, getWhatsAppLink } from '../data/business';

const { brand, phones, whatsappNumber, email, address } = business;

const fullAddress = `${address.line1}, ${address.line2 ? address.line2 + ', ' : ''}${address.city}, ${address.state} ${address.postalCode}, ${address.country}`;
---

<BaseLayout title="Contact Us" description="Get in touch with IndianSurgicals for medical equipment quotes. Contact us via phone, WhatsApp, or email.">
  <!-- Hero Section -->
  <section class="page-hero">
    <div class="page-hero__bg">
      <div class="page-hero__pattern"></div>
    </div>
    <div class="container">
      <h1 class="page-hero__title reveal">Contact Us</h1>
      <p class="page-hero__subtitle reveal">We're here to help with your medical equipment needs</p>
    </div>
  </section>

  <!-- Contact Cards Section -->
  <section class="contact-section">
    <div class="container">
      <div class="contact-grid reveal-stagger">
        <!-- Phone Card -->
        <div class="contact-card">
          <div class="contact-card__icon">
            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"></path>
            </svg>
          </div>
          <h3 class="contact-card__title">Phone</h3>
          <p class="contact-card__desc">Call us during working hours for immediate assistance</p>
          <div class="contact-card__links">
            {phones.map((phone) => (
              <a href={`tel:${phone}`} class="contact-card__link">{phone}</a>
            ))}
          </div>
          <span class="working-hours-badge badge badge-success">Open Now</span>
        </div>

        <!-- WhatsApp Card -->
        <div class="contact-card contact-card--whatsapp">
          <div class="contact-card__icon">
            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M21 11.5a8.38 8.38 0 0 1-.9 3.8 8.5 8.5 0 0 1-7.6 4.7 8.38 8.38 0 0 1-3.8-.9L3 21l1.9-5.7a8.38 8.38 0 0 1-.9-3.8 8.5 8.5 0 0 1 4.7-7.6 8.38 8.38 0 0 1 3.8-.9h.5a8.48 8.48 0 0 1 8 8v.5z"></path>
            </svg>
          </div>
          <h3 class="contact-card__title">WhatsApp</h3>
          <p class="contact-card__desc">Chat with us for quick quotes and product inquiries</p>
          <div class="contact-card__links">
            <a href={getWhatsAppLink('Hi, I need a quote for medical equipment')} class="contact-card__link contact-card__link--whatsapp">
              Send Message
            </a>
          </div>
          <span class="contact-card__note">Messages accepted anytime</span>
        </div>

        <!-- Email Card -->
        <div class="contact-card">
          <div class="contact-card__icon">
            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"></path>
              <polyline points="22,6 12,13 2,6"></polyline>
            </svg>
          </div>
          <h3 class="contact-card__title">Email</h3>
          <p class="contact-card__desc">Send us an email for detailed inquiries</p>
          <div class="contact-card__links">
            <a href={`mailto:${email}`} class="contact-card__link">{email}</a>
          </div>
          <span class="contact-card__note">Response within 24 hours</span>
        </div>

        <!-- Address Card -->
        <div class="contact-card">
          <div class="contact-card__icon">
            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"></path>
              <circle cx="12" cy="10" r="3"></circle>
            </svg>
          </div>
          <h3 class="contact-card__title">Address</h3>
          <p class="contact-card__desc">Visit our office during working hours</p>
          <address class="contact-card__address">
            {address.line1}<br />
            {address.line2 && <>{address.line2}<br /></>}
            {address.city}, {address.state} {address.postalCode}<br />
            {address.country}
          </address>
        </div>
      </div>
    </div>
  </section>

  <!-- Working Hours Panel -->
  <section class="hours-section">
    <div class="container">
      <div class="hours-panel reveal">
        <div class="hours-panel__icon">
          <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <circle cx="12" cy="12" r="10"></circle>
            <polyline points="12 6 12 12 16 14"></polyline>
          </svg>
        </div>
        <div class="hours-panel__content">
          <h3 class="hours-panel__title">Working Hours</h3>
          <div class="hours-panel__schedule">
            <div class="hours-panel__day">
              <span class="hours-panel__day-label">Mon - Sat</span>
              <span class="hours-panel__day-time">10:00 AM - 7:00 PM (IST)</span>
            </div>
            <div class="hours-panel__day">
              <span class="hours-panel__day-label">Sunday</span>
              <span class="hours-panel__day-time hours-panel__day-time--closed">Closed</span>
            </div>
          </div>
          <p class="hours-panel__note">
            <span class="working-hours-badge badge badge-warning">Note</span>
            WhatsApp messages are accepted anytime
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- Contact Form Section -->
  <section class="form-section">
    <div class="container">
      <div class="form-grid">
        <div class="form-content reveal">
          <h2 class="form-title">Send us a Message</h2>
          <p class="form-desc">Fill out the form below and we'll get back to you within 24 hours.</p>
          <form class="contact-form" action="#" method="POST">
            <div class="form-group">
              <label for="name" class="form-label">Full Name</label>
              <input type="text" id="name" name="name" class="form-input" placeholder="Your name" required />
            </div>
            <div class="form-group">
              <label for="email" class="form-label">Email Address</label>
              <input type="email" id="email" name="email" class="form-input" placeholder="your@email.com" required />
            </div>
            <div class="form-group">
              <label for="message" class="form-label">Message</label>
              <textarea id="message" name="message" class="form-input form-textarea" placeholder="Tell us about your requirements..." rows="5" required></textarea>
            </div>
            <button type="submit" class="form-submit">
              Send Message
              <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <line x1="22" y1="2" x2="11" y2="13"></line>
                <polygon points="22 2 15 22 11 13 2 9 22 2"></polygon>
              </svg>
            </button>
          </form>
        </div>
        <div class="map-content reveal">
          <h2 class="form-title">Find Us</h2>
          <p class="form-desc">We're located in {address.city}. Visit us during working hours.</p>
          <div class="map-placeholder">
            <div class="map-placeholder__content">
              <svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"></path>
                <circle cx="12" cy="10" r="3"></circle>
              </svg>
              <p>Map Placeholder</p>
              <span>{address.city}, {address.state}</span>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <MotionController />
</BaseLayout>

<style>
  /* Page Hero */
  .page-hero {
    position: relative;
    padding: var(--space-24) 0;
    min-height: 40vh;
    display: flex;
    align-items: center;
    overflow: hidden;
  }

  .page-hero__bg {
    position: absolute;
    inset: 0;
    z-index: -1;
  }

  .page-hero__pattern {
    position: absolute;
    inset: 0;
    background:
      radial-gradient(ellipse 80% 50% at 50% -20%, rgba(13, 148, 136, 0.15), transparent),
      radial-gradient(ellipse 60% 40% at 80% 60%, rgba(249, 115, 22, 0.08), transparent);
  }

  .page-hero__title {
    font-family: var(--font-heading);
    font-size: clamp(2.5rem, 5vw, 3.5rem);
    font-weight: 600;
    color: var(--color-text);
    margin-bottom: var(--space-4);
  }

  .page-hero__subtitle {
    font-size: 1.125rem;
    color: var(--color-text-muted);
    max-width: 600px;
  }

  /* Contact Section */
  .contact-section {
    padding: var(--space-16) 0;
  }

  .contact-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: var(--space-6);
  }

  .contact-card {
    background: var(--color-surface);
    border-radius: var(--radius-xl);
    padding: var(--space-6);
    text-align: center;
    box-shadow: var(--shadow-md);
    transition: all 0.3s var(--ease-out-expo);
    display: flex;
    flex-direction: column;
  }

  .contact-card:hover {
    transform: translateY(-4px);
    box-shadow: var(--shadow-lg);
  }

  .contact-card--whatsapp {
    background: linear-gradient(135deg, #25D366 0%, #128C7E 100%);
  }

  .contact-card--whatsapp .contact-card__icon {
    background: rgba(255, 255, 255, 0.2);
    color: white;
  }

  .contact-card--whatsapp .contact-card__title,
  .contact-card--whatsapp .contact-card__desc,
  .contact-card--whatsapp .contact-card__link,
  .contact-card--whatsapp .contact-card__note {
    color: white;
  }

  .contact-card--whatsapp .contact-card__desc {
    color: rgba(255, 255, 255, 0.85);
  }

  .contact-card__icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 56px;
    height: 56px;
    background: var(--color-primary-50);
    border-radius: var(--radius-full);
    color: var(--color-primary);
    margin-bottom: var(--space-4);
  }

  .contact-card__title {
    font-family: var(--font-heading);
    font-size: 1.125rem;
    font-weight: 600;
    color: var(--color-text);
    margin-bottom: var(--space-2);
  }

  .contact-card__desc {
    font-size: 0.875rem;
    color: var(--color-text-muted);
    margin-bottom: var(--space-4);
    flex: 1;
  }

  .contact-card__links {
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
    margin-bottom: var(--space-3);
  }

  .contact-card__link {
    font-size: 0.9375rem;
    font-weight: 600;
    color: var(--color-primary);
    text-decoration: none;
    transition: color 0.2s;
  }

  .contact-card__link:hover {
    color: var(--color-primary-dark);
    text-decoration: underline;
  }

  .contact-card__link--whatsapp {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: var(--space-2) var(--space-4);
    background: white;
    color: #128C7E;
    border-radius: var(--radius-full);
    font-weight: 600;
  }

  .contact-card__link--whatsapp:hover {
    background: #f0f0f0;
    text-decoration: none;
  }

  .contact-card__note {
    font-size: 0.75rem;
    color: var(--color-text-muted);
  }

  .contact-card__address {
    font-style: normal;
    font-size: 0.875rem;
    line-height: 1.6;
    color: var(--color-text-muted);
  }

  /* Hours Section */
  .hours-section {
    padding: var(--space-8) 0 var(--space-16);
  }

  .hours-panel {
    background: var(--color-surface);
    border-radius: var(--radius-xl);
    padding: var(--space-8);
    box-shadow: var(--shadow-md);
    display: flex;
    align-items: flex-start;
    gap: var(--space-6);
    max-width: 600px;
    margin: 0 auto;
  }

  .hours-panel__icon {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 64px;
    height: 64px;
    background: var(--color-primary-50);
    border-radius: var(--radius-full);
    color: var(--color-primary);
    flex-shrink: 0;
  }

  .hours-panel__content {
    flex: 1;
  }

  .hours-panel__title {
    font-family: var(--font-heading);
    font-size: 1.25rem;
    font-weight: 600;
    color: var(--color-text);
    margin-bottom: var(--space-4);
  }

  .hours-panel__schedule {
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
    margin-bottom: var(--space-4);
  }

  .hours-panel__day {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding-bottom: var(--space-3);
    border-bottom: 1px solid var(--color-border);
  }

  .hours-panel__day:last-child {
    border-bottom: none;
    padding-bottom: 0;
  }

  .hours-panel__day-label {
    font-weight: 600;
    color: var(--color-text);
  }

  .hours-panel__day-time {
    color: var(--color-text-muted);
  }

  .hours-panel__day-time--closed {
    color: var(--color-error);
    font-weight: 500;
  }

  .hours-panel__note {
    display: flex;
    align-items: center;
    gap: var(--space-2);
    font-size: 0.875rem;
    color: var(--color-text-muted);
  }

  /* Form Section */
  .form-section {
    padding: var(--space-16) 0;
    background: var(--color-bg-alt);
  }

  .form-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-12);
    align-items: start;
  }

  .form-title {
    font-family: var(--font-heading);
    font-size: 1.5rem;
    font-weight: 600;
    color: var(--color-text);
    margin-bottom: var(--space-2);
  }

  .form-desc {
    font-size: 0.9375rem;
    color: var(--color-text-muted);
    margin-bottom: var(--space-6);
  }

  .contact-form {
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
  }

  .form-group {
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
  }

  .form-label {
    font-size: 0.875rem;
    font-weight: 600;
    color: var(--color-text);
  }

  .form-input {
    padding: var(--space-3) var(--space-4);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    font-size: 1rem;
    color: var(--color-text);
    background: var(--color-surface);
    transition: border-color 0.2s, box-shadow 0.2s;
  }

  .form-input:focus {
    outline: none;
    border-color: var(--color-primary);
    box-shadow: 0 0 0 3px var(--color-primary-50);
  }

  .form-input::placeholder {
    color: var(--color-text-muted);
  }

  .form-textarea {
    resize: vertical;
    min-height: 120px;
  }

  .form-submit {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: var(--space-2);
    padding: var(--space-3) var(--space-6);
    background: var(--color-primary);
    color: white;
    border: none;
    border-radius: var(--radius-lg);
    font-size: 1rem;
    font-weight: 600;
    cursor: pointer;
    transition: background 0.2s, transform 0.2s;
    margin-top: var(--space-2);
  }

  .form-submit:hover {
    background: var(--color-primary-dark);
    transform: translateY(-2px);
  }

  .map-placeholder {
    background: var(--color-surface);
    border-radius: var(--radius-xl);
    padding: var(--space-16);
    text-align: center;
    border: 2px dashed var(--color-border);
  }

  .map-placeholder__content {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-2);
    color: var(--color-text-muted);
  }

  .map-placeholder__content svg {
    color: var(--color-primary);
    opacity: 0.5;
  }

  .map-placeholder__content p {
    font-weight: 600;
    color: var(--color-text);
  }

  .map-placeholder__content span {
    font-size: 0.875rem;
  }

  /* Responsive */
  @media (max-width: 1024px) {
    .contact-grid {
      grid-template-columns: repeat(2, 1fr);
    }

    .form-grid {
      grid-template-columns: 1fr;
    }
  }

  @media (max-width: 640px) {
    .page-hero {
      min-height: 30vh;
      padding: var(--space-16) 0;
    }

    .contact-grid {
      grid-template-columns: 1fr;
    }

    .hours-panel {
      flex-direction: column;
      text-align: center;
    }

    .hours-panel__icon {
      margin: 0 auto;
    }

    .hours-panel__day {
      flex-direction: column;
      gap: var(--space-1);
    }
  }
</style>
