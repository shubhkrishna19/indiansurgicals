---
import BaseLayout from "../../layouts/BaseLayout.astro";
import ProductCard from "../../components/ProductCard.astro";
import SectionTitle from "../../components/SectionTitle.astro";
import { getAllCategories, getAllFamilies } from "../../data/catalogue";

const categories = getAllCategories();
const families = getAllFamilies();
---

<BaseLayout
  title="Catalogue"
  description="Browse Indian Surgical Industries product families by category, family, and model coverage."
>
  <section class="section">
    <div class="container">
      <SectionTitle
        kicker="Product Catalogue"
        title="Browse Categories, Product Families, and Available Models"
        subtitle="Open any product family to review images, listed models, and specification details before requesting a quotation."
        align="left"
      />

      <div class="catalogue-toolbar panel">
        <div class="catalogue-toolbar__search">
          <label for="catalogue-search">Search products</label>
          <input id="catalogue-search" type="search" placeholder="Search by family, category, or model" />
        </div>

        <label class="catalogue-toolbar__mobile-select">
          <span>Category</span>
          <select id="catalogue-mobile-filter">
            <option value="all">All categories</option>
            {categories.map((category) => (
              <option value={category.slug}>{category.name}</option>
            ))}
          </select>
        </label>

        <div class="catalogue-toolbar__filters" aria-label="Category filters">
          <button class="is-active" data-filter="all">All categories</button>
          {categories.map((category) => (
            <button data-filter={category.slug}>{category.name}</button>
          ))}
        </div>

        <p class="catalogue-toolbar__count">
          <strong id="catalogue-count">{families.length}</strong> product families available
        </p>
      </div>

      <div class="catalogue-grid" id="catalogue-grid">
        {families.map((family) => (
          <div
            class="catalogue-grid__item"
            data-category={family.categorySlug}
            data-search={`${family.name} ${family.summary} ${family.variants.map((variant) => variant.model).join(" ")}`.toLowerCase()}
          >
            <ProductCard family={family} />
          </div>
        ))}
      </div>

      <div class="catalogue-empty panel" id="catalogue-empty" hidden>
        <h2>No matching products found.</h2>
        <p>Try a broader keyword or switch back to all categories.</p>
      </div>
    </div>
  </section>
</BaseLayout>

<script>
  const searchInput = document.getElementById("catalogue-search");
  const mobileFilter = document.getElementById("catalogue-mobile-filter");
  const filterButtons = Array.from(document.querySelectorAll("[data-filter]"));
  const catalogueItems = Array.from(document.querySelectorAll(".catalogue-grid__item"));
  const countNode = document.getElementById("catalogue-count");
  const emptyNode = document.getElementById("catalogue-empty");

  let activeFilter = "all";

  function applyFilters() {
    const query = searchInput instanceof HTMLInputElement ? searchInput.value.trim().toLowerCase() : "";
    let visible = 0;

    for (const item of catalogueItems) {
      const element = item;
      const category = element.getAttribute("data-category") ?? "";
      const haystack = element.getAttribute("data-search") ?? "";
      const categoryMatches = activeFilter === "all" || category === activeFilter;
      const queryMatches = !query || haystack.includes(query);
      const matches = categoryMatches && queryMatches;
      element.toggleAttribute("hidden", !matches);
      if (matches) {
        visible += 1;
      }
    }

    if (countNode) {
      countNode.textContent = String(visible);
    }
    if (emptyNode) {
      emptyNode.hidden = visible !== 0;
    }
  }

  searchInput?.addEventListener("input", applyFilters);
  mobileFilter?.addEventListener("change", () => {
    activeFilter = mobileFilter instanceof HTMLSelectElement ? mobileFilter.value : "all";
    filterButtons.forEach((candidate) => candidate.classList.remove("is-active"));
    const activeButton = filterButtons.find((button) => button.getAttribute("data-filter") === activeFilter);
    activeButton?.classList.add("is-active");
    applyFilters();
  });
  filterButtons.forEach((button) => {
    button.addEventListener("click", () => {
      activeFilter = button.getAttribute("data-filter") ?? "all";
      filterButtons.forEach((candidate) => candidate.classList.remove("is-active"));
      button.classList.add("is-active");
      if (mobileFilter instanceof HTMLSelectElement) {
        mobileFilter.value = activeFilter;
      }
      applyFilters();
    });
  });
</script>

<style>
  .catalogue-toolbar {
    display: grid;
    grid-template-columns: minmax(0, 1fr) auto;
    grid-template-areas:
      "search count"
      "filters filters";
    gap: 1rem 1.2rem;
    align-items: start;
    padding: 1.2rem;
    margin-top: 1.2rem;
    margin-bottom: 1.4rem;
  }

  .catalogue-toolbar__search {
    display: grid;
    gap: 0.55rem;
    grid-area: search;
  }

  .catalogue-toolbar__search label {
    font-size: 0.82rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--color-primary);
  }

  .catalogue-toolbar__search input {
    border: 1px solid rgba(84, 96, 109, 0.18);
    border-radius: 1rem;
    padding: 0.9rem 1rem;
    background: rgba(255, 255, 255, 0.84);
  }

  .catalogue-toolbar__filters {
    grid-area: filters;
    display: flex;
    flex-wrap: wrap;
    gap: 0.7rem;
  }

  .catalogue-toolbar__mobile-select {
    display: none;
    gap: 0.55rem;
    grid-area: select;
  }

  .catalogue-toolbar__mobile-select span {
    font-size: 0.82rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--color-primary);
  }

  .catalogue-toolbar__mobile-select select {
    width: 100%;
    border: 1px solid rgba(84, 96, 109, 0.18);
    border-radius: 1rem;
    padding: 0.82rem 0.95rem;
    background: rgba(255, 255, 255, 0.88);
    color: var(--color-text);
  }

  .catalogue-toolbar__filters button {
    border: 1px solid rgba(84, 96, 109, 0.18);
    border-radius: 999px;
    padding: 0.65rem 0.9rem;
    background: rgba(255, 255, 255, 0.82);
    color: var(--color-text-muted);
  }

  .catalogue-toolbar__filters button.is-active {
    background: var(--color-primary);
    border-color: var(--color-primary);
    color: white;
  }

  .catalogue-toolbar__count {
    grid-area: count;
    align-self: end;
    margin: 0;
    padding-top: 1.9rem;
    color: var(--color-text-muted);
    text-align: right;
  }

  .catalogue-grid {
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    gap: 1.2rem;
  }

  .catalogue-empty {
    display: grid;
    gap: 0.7rem;
    padding: 1.4rem;
    margin-top: 1.2rem;
  }

  .catalogue-empty p {
    color: var(--color-text-muted);
  }

  @media (max-width: 1280px) {
    .catalogue-grid {
      grid-template-columns: repeat(3, minmax(0, 1fr));
    }
  }

  @media (max-width: 980px) {
    .catalogue-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  @media (max-width: 920px) {
    .catalogue-toolbar {
      grid-template-columns: 1fr;
      grid-template-areas:
        "search"
        "count"
        "filters";
    }

    .catalogue-toolbar__count {
      padding-top: 0;
      text-align: left;
    }
  }

  @media (max-width: 700px) {
    .catalogue-toolbar {
      padding: 0.95rem;
      margin-top: 1rem;
      margin-bottom: 1.1rem;
      gap: 0.85rem;
      grid-template-areas:
        "search"
        "select"
        "count";
    }

    .catalogue-toolbar__mobile-select {
      display: grid;
    }

    .catalogue-toolbar__search {
      gap: 0.45rem;
    }

    .catalogue-toolbar__search input {
      padding: 0.8rem 0.9rem;
    }

    .catalogue-toolbar__filters {
      display: none;
    }

    .catalogue-toolbar__count {
      font-size: 0.92rem;
    }

    .catalogue-grid {
      grid-template-columns: 1fr;
      gap: 0.95rem;
    }
  }
</style>
