---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Breadcrumbs from '../../../components/Breadcrumbs.astro';
import ProductCard from '../../../components/ProductCard.astro';
import SpecsTable from '../../../components/SpecsTable.astro';
import CTAButtons from '../../../components/CTAButtons.astro';
import MotionController from '../../../components/MotionController.astro';
import { categories, getCategoryBySlug } from '../../../data/categories';
import { products, getProductBySlug, getProductsByCategory, getFeaturedProducts } from '../../../data/products';
import { business, getWhatsAppLink } from '../../../data/business';

export function getStaticPaths() {
  return products.map((product) => ({
    params: {
      category: product.categorySlug,
      product: product.slug
    },
    props: { product },
  }));
}

const { product } = Astro.props;
const category = getCategoryBySlug(product.categorySlug);
const relatedProducts = getProductsByCategory(product.categorySlug)
  .filter((p) => p.slug !== product.slug)
  .slice(0, 4);
const featuredProducts = getFeaturedProducts().slice(0, 4);

const whatsappLink = getWhatsAppLink(`Hi, I'd like to get a quote for: ${product.name}`);
const callLink = `tel:${business.phones[0]}`;
const emailLink = `mailto:${business.email}`;

const breadcrumbs = [
  { label: 'Products', href: '/products' },
  { label: category?.name || '', href: `/products/${product.categorySlug}` },
  { label: product.name }
];
---

<BaseLayout
  title={product.name}
  description={product.shortDesc}
>
  <!-- Product Hero -->
  <section class="product-hero">
    <div class="container">
      <Breadcrumbs breadcrumbs={breadcrumbs} />

      <div class="product-hero__grid">
        <!-- Product Image -->
        <div class="product-hero__image-wrapper">
          <div class="product-hero__image-container">
            <img
              src={product.images[0]}
              alt={product.name}
              class="product-hero__image"
              style={`view-transition-name: product-image-${product.slug}`}
            />
          </div>

          <!-- Additional Images Thumbnails -->
          {product.images.length > 1 && (
            <div class="product-hero__thumbnails">
              {product.images.map((image, index) => (
                <button
                  class={`product-hero__thumbnail ${index === 0 ? 'product-hero__thumbnail--active' : ''}`}
                  data-index={index}
                >
                  <img src={image} alt={`${product.name} - Image ${index + 1}`} />
                </button>
              ))}
            </div>
          )}
        </div>

        <!-- Product Info -->
        <div class="product-hero__info">
          <!-- Tags -->
          <div class="product-hero__tags">
            {product.tags.map((tag) => (
              <span class="product-hero__tag">{tag}</span>
            ))}
            {category && (
              <a href={`/products/${category.slug}`} class="product-hero__category-tag">
                {category.icon} {category.name}
              </a>
            )}
          </div>

          <!-- Title -->
          <h1
            class="product-hero__title"
            style={`view-transition-name: product-title-${product.slug}`}
          >
            {product.name}
          </h1>

          <!-- Short Description -->
          <p class="product-hero__short-desc">{product.shortDesc}</p>

          <!-- CTA Box -->
          <div class="product-hero__cta-box">
            <h3 class="product-hero__cta-title">Get a Quote</h3>
            <p class="product-hero__cta-text">
              Share your requirements and we'll get back to you with pricing
            </p>
            <div class="product-hero__cta-buttons">
              <CTAButtons variant="whatsapp" href={whatsappLink} icon="whatsapp">
                WhatsApp Quote
              </CTAButtons>
              <CTAButtons variant="phone" href={callLink} icon="phone">
                Call Now
              </CTAButtons>
              <CTAButtons variant="email" href={emailLink} icon="email">
                Email Inquiry
              </CTAButtons>
            </div>
          </div>

          <!-- Trust Indicators -->
          <div class="product-hero__trust">
            <div class="product-hero__trust-item">
              <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"></path>
              </svg>
              <span>Quality Checked</span>
            </div>
            <div class="product-hero__trust-item">
              <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <rect x="1" y="3" width="15" height="13"></rect>
                <polygon points="16 8 20 8 23 11 23 16 16 16 16 8"></polygon>
                <circle cx="5.5" cy="18.5" r="2.5"></circle>
                <circle cx="18.5" cy="18.5" r="2.5"></circle>
              </svg>
              <span>Fast Dispatch</span>
            </div>
            <div class="product-hero__trust-item">
              <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <line x1="12" y1="1" x2="12" y2="23"></line>
                <path d="M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"></path>
              </svg>
              <span>GST Invoice</span>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Overview Section -->
  <section class="product-overview">
    <div class="container">
      <div class="product-overview__grid">
        <div class="product-overview__content">
          <h2 class="product-overview__title">Overview</h2>
          <p class="product-overview__text">{product.longDesc}</p>
        </div>

        <div class="product-overview__highlights">
          <h3 class="product-overview__highlights-title">Key Features</h3>
          <ul class="product-overview__highlights-list">
            <li>Premium quality materials</li>
            <li>Industry-standard specifications</li>
            <li>Certified for medical use</li>
            <li>Warranty support available</li>
            <li>Competitive bulk pricing</li>
          </ul>
        </div>
      </div>
    </div>
  </section>

  <!-- Specifications Section -->
  <section class="product-specs">
    <div class="container">
      <h2 class="product-specs__title">Specifications</h2>
      <div class="product-specs__table">
        <SpecsTable specs={product.specs} />
      </div>
    </div>
  </section>

  <!-- Related Products -->
  {relatedProducts.length > 0 && (
    <section class="related-products">
      <div class="container">
        <h2 class="related-products__title">Related Products</h2>
        <div class="related-products__grid">
          {relatedProducts.map((relatedProduct) => (
            <ProductCard product={relatedProduct} />
          ))}
        </div>
      </div>
    </section>
  )}

  <!-- More Featured Products -->
  <section class="featured-products">
    <div class="container">
      <h2 class="featured-products__title">Featured Products</h2>
      <div class="featured-products__grid">
        {featuredProducts.map((featuredProduct) => (
          <ProductCard product={featuredProduct} />
        ))}
      </div>
    </div>
  </section>

  <!-- CTA Strip -->
  <section class="product-cta-strip">
    <div class="container">
      <div class="product-cta-strip__content">
        <h2 class="product-cta-strip__title">Need this product or something similar?</h2>
        <p class="product-cta-strip__text">Contact us for competitive pricing and bulk order discounts</p>
        <div class="product-cta-strip__buttons">
          <CTAButtons variant="primary" href="/products">
            Browse More Products
          </CTAButtons>
          <CTAButtons variant="whatsapp" href={whatsappLink} icon="whatsapp">
            Get Quote on WhatsApp
          </CTAButtons>
        </div>
      </div>
    </div>
  </section>

  <MotionController />
</BaseLayout>

<style>
  /* Product Hero */
  .product-hero {
    padding: var(--space-8) 0 var(--space-16);
    background: var(--color-bg-alt);
  }

  .product-hero__grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-12);
    align-items: start;
  }

  .product-hero__image-wrapper {
    position: sticky;
    top: calc(var(--header-height) + var(--space-8));
  }

  .product-hero__image-container {
    background: var(--color-surface);
    border-radius: var(--radius-2xl);
    overflow: hidden;
    box-shadow: var(--shadow-lg);
  }

  .product-hero__image {
    width: 100%;
    aspect-ratio: 4 / 3;
    object-fit: cover;
  }

  .product-hero__thumbnails {
    display: flex;
    gap: var(--space-3);
    margin-top: var(--space-4);
  }

  .product-hero__thumbnail {
    width: 80px;
    height: 60px;
    border-radius: var(--radius-lg);
    overflow: hidden;
    border: 2px solid transparent;
    background: none;
    padding: 0;
    cursor: pointer;
    transition: all 0.3s var(--ease-out-expo);
  }

  .product-hero__thumbnail--active,
  .product-hero__thumbnail:hover {
    border-color: var(--color-primary);
  }

  .product-hero__thumbnail img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .product-hero__info {
    padding-top: var(--space-4);
  }

  .product-hero__tags {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2);
    margin-bottom: var(--space-4);
  }

  .product-hero__tag {
    padding: var(--space-1) var(--space-3);
    background: var(--color-primary-50);
    color: var(--color-primary);
    font-size: 0.75rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    border-radius: var(--radius-full);
  }

  .product-hero__category-tag {
    padding: var(--space-1) var(--space-3);
    background: var(--color-bg-alt);
    color: var(--color-text);
    font-size: 0.75rem;
    font-weight: 500;
    text-decoration: none;
    border-radius: var(--radius-full);
    transition: all 0.2s var(--ease-out-expo);
  }

  .product-hero__category-tag:hover {
    background: var(--color-primary);
    color: white;
  }

  .product-hero__title {
    font-family: var(--font-heading);
    font-size: clamp(2rem, 4vw, 2.75rem);
    font-weight: 600;
    color: var(--color-text);
    line-height: 1.2;
    margin-bottom: var(--space-4);
  }

  .product-hero__short-desc {
    font-size: 1.125rem;
    line-height: 1.7;
    color: var(--color-text-muted);
    margin-bottom: var(--space-8);
  }

  /* CTA Box */
  .product-hero__cta-box {
    background: var(--color-surface);
    border-radius: var(--radius-xl);
    padding: var(--space-6);
    box-shadow: var(--shadow-md);
    margin-bottom: var(--space-8);
  }

  .product-hero__cta-title {
    font-family: var(--font-heading);
    font-size: 1.25rem;
    font-weight: 600;
    color: var(--color-text);
    margin-bottom: var(--space-2);
  }

  .product-hero__cta-text {
    font-size: 0.9375rem;
    color: var(--color-text-muted);
    margin-bottom: var(--space-4);
  }

  .product-hero__cta-buttons {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-3);
  }

  /* Trust Indicators */
  .product-hero__trust {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-6);
    padding: var(--space-4) 0;
    border-top: 1px solid var(--color-border);
  }

  .product-hero__trust-item {
    display: flex;
    align-items: center;
    gap: var(--space-2);
    font-size: 0.875rem;
    color: var(--color-text-muted);
  }

  .product-hero__trust-item svg {
    color: var(--color-success);
  }

  /* Overview Section */
  .product-overview {
    padding: var(--space-16) 0;
  }

  .product-overview__grid {
    display: grid;
    grid-template-columns: 2fr 1fr;
    gap: var(--space-12);
  }

  .product-overview__title {
    font-family: var(--font-heading);
    font-size: 1.75rem;
    font-weight: 600;
    color: var(--color-text);
    margin-bottom: var(--space-4);
  }

  .product-overview__text {
    font-size: 1.0625rem;
    line-height: 1.8;
    color: var(--color-text-muted);
  }

  .product-overview__highlights {
    background: var(--color-surface);
    border-radius: var(--radius-xl);
    padding: var(--space-6);
    box-shadow: var(--shadow-md);
    height: fit-content;
  }

  .product-overview__highlights-title {
    font-size: 1.125rem;
    font-weight: 600;
    color: var(--color-text);
    margin-bottom: var(--space-4);
  }

  .product-overview__highlights-list {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .product-overview__highlights-list li {
    display: flex;
    align-items: center;
    gap: var(--space-3);
    padding: var(--space-2) 0;
    font-size: 0.9375rem;
    color: var(--color-text-muted);
  }

  .product-overview__highlights-list li::before {
    content: '';
    width: 6px;
    height: 6px;
    background: var(--color-primary);
    border-radius: 50%;
    flex-shrink: 0;
  }

  /* Specs Section */
  .product-specs {
    padding: var(--space-16) 0;
    background: var(--color-bg-alt);
  }

  .product-specs__title {
    font-family: var(--font-heading);
    font-size: 1.75rem;
    font-weight: 600;
    color: var(--color-text);
    margin-bottom: var(--space-8);
    text-align: center;
  }

  .product-specs__table {
    max-width: 700px;
    margin: 0 auto;
  }

  /* Related Products */
  .related-products {
    padding: var(--space-16) 0;
  }

  .related-products__title {
    font-family: var(--font-heading);
    font-size: 1.75rem;
    font-weight: 600;
    color: var(--color-text);
    margin-bottom: var(--space-8);
  }

  .related-products__grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: var(--space-6);
  }

  /* Featured Products */
  .featured-products {
    padding: var(--space-16) 0;
    background: var(--color-bg-alt);
  }

  .featured-products__title {
    font-family: var(--font-heading);
    font-size: 1.75rem;
    font-weight: 600;
    color: var(--color-text);
    margin-bottom: var(--space-8);
  }

  .featured-products__grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: var(--space-6);
  }

  /* CTA Strip */
  .product-cta-strip {
    padding: var(--space-16) 0;
    background: linear-gradient(135deg, var(--color-primary) 0%, var(--color-primary-dark) 100%);
  }

  .product-cta-strip__content {
    text-align: center;
    max-width: 600px;
    margin: 0 auto;
  }

  .product-cta-strip__title {
    font-family: var(--font-heading);
    font-size: clamp(1.5rem, 3vw, 2rem);
    font-weight: 600;
    color: white;
    margin-bottom: var(--space-4);
  }

  .product-cta-strip__text {
    font-size: 1.0625rem;
    color: rgba(255, 255, 255, 0.85);
    margin-bottom: var(--space-6);
  }

  .product-cta-strip__buttons {
    display: flex;
    justify-content: center;
    gap: var(--space-4);
  }

  .product-cta-strip__buttons :global(.cta-button--primary) {
    background: white;
    color: var(--color-primary);
  }

  .product-cta-strip__buttons :global(.cta-button--primary:hover) {
    background: var(--color-secondary-light);
  }

  /* Responsive */
  @media (max-width: 1024px) {
    .product-hero__grid {
      grid-template-columns: 1fr;
    }

    .product-hero__image-wrapper {
      position: static;
    }

    .product-overview__grid {
      grid-template-columns: 1fr;
    }

    .related-products__grid,
    .featured-products__grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 640px) {
    .product-hero__cta-buttons {
      flex-direction: column;
    }

    .product-hero__trust {
      flex-direction: column;
      gap: var(--space-3);
    }

    .related-products__grid,
    .featured-products__grid {
      grid-template-columns: 1fr;
    }

    .product-cta-strip__buttons {
      flex-direction: column;
    }
  }
</style>
