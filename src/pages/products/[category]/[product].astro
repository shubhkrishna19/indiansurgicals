---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import Breadcrumbs from "../../../components/Breadcrumbs.astro";
import ProductCard from "../../../components/ProductCard.astro";
import ProductGallery from "../../../components/ProductGallery.astro";
import SectionTitle from "../../../components/SectionTitle.astro";
import type { ProductFamily } from "../../../data/catalogue";
import {
  getAllFamilies,
  getCategoryBySlug,
  getRelatedFamilies,
} from "../../../data/catalogue";
import { business } from "../../../data/business";

export function getStaticPaths() {
  const paths = new Map<string, { params: { category: string; product: string }; props: { family: ProductFamily } }>();

  for (const family of getAllFamilies()) {
    const canonicalKey = `${family.categorySlug}/${family.slug}`;
    paths.set(canonicalKey, {
      params: { category: family.categorySlug, product: family.slug },
      props: { family },
    });

    if (family.legacyCategorySlug && family.legacyCategorySlug !== family.categorySlug) {
      const legacyKey = `${family.legacyCategorySlug}/${family.slug}`;
      paths.set(legacyKey, {
        params: { category: family.legacyCategorySlug, product: family.slug },
        props: { family },
      });
    }
  }

  return Array.from(paths.values());
}

const { family } = Astro.props;
const category = getCategoryBySlug(family.categorySlug);
const relatedFamilies = getRelatedFamilies(family, 4);
const activeVariant = family.variants[0];
const matrixColumns = family.tableColumns.length > 0 ? family.tableColumns : ["Model"];
const galleryImages = Array.from(
  new Set(((activeVariant?.images?.length ? activeVariant.images : family.images) ?? []).filter(Boolean)),
);
const detailNotes = [...family.highlights, ...family.notes].filter(Boolean).slice(0, 6);
const heroSummary = family.description || family.summary;

function getAttributeValue(
  variant: { attributes: { label: string; value: string }[] },
  label: string,
) {
  return variant.attributes.find((attribute) => attribute.label === label)?.value ?? "Not listed";
}
---

<BaseLayout title={family.name} description={family.summary}>
  <section class="section product-hero">
    <div class="container">
      <div class="product-hero__navrow">
        <Breadcrumbs
          class="product-hero__breadcrumbs"
          breadcrumbs={[
            { label: "Catalogue", href: "/products" },
            category ? { label: category.name, href: `/products/${category.slug}` } : { label: family.categorySlug },
            { label: family.name },
          ]}
        />
        <span class="product-hero__category-tag">{category?.name ?? "Product Range"}</span>
      </div>

      <div class="product-hero__grid">
        <div class="product-hero__content" data-parallax-group>
          <h1>{family.name}</h1>
          <p class="product-hero__summary" data-parallax-speed="0.1">{heroSummary}</p>

          <div class="product-hero__meta">
            <div class="panel">
              <strong>{family.variants.length}</strong>
              <span>available models</span>
            </div>
            <div class="panel">
              <strong>{category?.name ?? "Catalogue"}</strong>
              <span>product category</span>
            </div>
            <div class="panel">
              <strong>Quote on request</strong>
              <span>pricing shared directly</span>
            </div>
          </div>

        </div>

        <aside class="product-hero__aside panel">
          <p class="product-hero__aside-kicker">Quotation Support</p>
          <h2>Need this product for hospital, dealer, or export buying?</h2>
          <p>{business.quoteOnlyNote}</p>
          <p>{business.contactNote}</p>
          <a href="/get-quote" class="button button--primary">Request a quote</a>
        </aside>
      </div>
    </div>
  </section>

  {detailNotes.length > 0 && (
    <section class="section section--product-highlights">
      <div class="container">
        <div class="product-highlights panel">
          <div class="product-highlights__intro">
            <span class="eyebrow">Key Specifications</span>
            <h2>Review the main specifications and product details for this family.</h2>
          </div>

          <div class="product-highlights__grid">
            {detailNotes.map((item) => (
              <article class="product-highlight-item">
                <span class="product-highlight-item__marker" aria-hidden="true"></span>
                <p>{item}</p>
              </article>
            ))}
          </div>
        </div>
      </div>
    </section>
  )}

  <section class="section">
    <div class="container">
      {galleryImages.length > 0 ? (
        <ProductGallery images={galleryImages} name={family.name} />
      ) : (
        <div class="gallery-empty panel">
          <h2>Additional product images can be shared on request.</h2>
          <p>For more photographs, packing details, or model confirmation, contact the team directly.</p>
        </div>
      )}
    </div>
  </section>

  <section class="section section--band">
    <div class="container">
      <SectionTitle
        kicker="Model Comparison"
        title="Compare the available models before you enquire."
        subtitle="Review size, capacity, and configuration differences across the lineup to shortlist the right option quickly."
      />

      <div class="matrix panel">
        <div class="matrix__table-wrap">
          <table>
            <thead>
              <tr>
                {matrixColumns.map((column) => (
                  <th>{column}</th>
                ))}
              </tr>
            </thead>
            <tbody>
              {family.variants.map((variant) => (
                <tr>
                  <td>{variant.model}</td>
                  {matrixColumns.slice(1).map((column) => (
                    <td>{getAttributeValue(variant, column)}</td>
                  ))}
                </tr>
              ))}
            </tbody>
          </table>
        </div>

        <div class="matrix__cards" aria-label="Model comparison cards">
          {family.variants.map((variant) => (
            <article class="matrix-card">
              <div class="matrix-card__head">
                <p class="matrix-card__eyebrow">Model</p>
                <h3>{variant.model}</h3>
              </div>

              <div class="matrix-card__rows">
                {matrixColumns.map((column, columnIndex) => (
                  <div class="matrix-card__row">
                    <span>{column}</span>
                    <strong>
                      {columnIndex === 0 ? variant.model : getAttributeValue(variant, column)}
                    </strong>
                  </div>
                ))}
              </div>
            </article>
          ))}
        </div>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container variant-section">
      <SectionTitle
        title="Model Details"
        subtitle={family.variants.length > 1 ? "Browse the available models below." : ""}
      />

      <div class="variant-switcher" role="tablist" aria-label="Model selector">
        {family.variants.map((variant, index) => (
          <button
            class:list={["variant-switcher__button", { "is-active": index === 0 }]}
            data-model-target={variant.slug}
            data-model-images={JSON.stringify(
              Array.from(new Set(((variant.images?.length ? variant.images : family.images) ?? []).filter(Boolean))),
            )}
            data-model-name={variant.displayName ?? family.name}
            role="tab"
            aria-selected={index === 0 ? "true" : "false"}
          >
            {variant.model}
          </button>
        ))}
      </div>

      <div class="variant-panels">
        {family.variants.map((variant, index) => (
          <article
            class:list={["variant-panel panel", { "is-active": index === 0 }]}
            data-model-panel={variant.slug}
            hidden={index === 0 ? undefined : true}
          >
            <div class="variant-panel__header">
              <div>
                <p class="variant-panel__eyebrow">Model</p>
                <h2>{variant.displayName ?? variant.model}</h2>
                {variant.displayName && variant.displayName !== variant.model && (
                  <p class="variant-panel__model-code">Model: {variant.model}</p>
                )}
              </div>
              <span class="variant-panel__tag">{family.name}</span>
            </div>

            <div class="variant-panel__grid">
              <div class="variant-panel__specs">
                {variant.attributes.map((attribute) => (
                  <div class="variant-panel__spec">
                    <span>{attribute.label}</span>
                    <strong>{attribute.value}</strong>
                  </div>
                ))}
              </div>

              <div class="variant-panel__notes">
                <h3>Model details</h3>
                {variant.descriptionLines.length > 0 ? (
                  <ul>
                    {variant.descriptionLines.map((line) => (
                      <li>{line}</li>
                    ))}
                  </ul>
                ) : (
                  <p>Additional model details can be shared during quotation discussion.</p>
                )}
              </div>
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>

  {relatedFamilies.length > 0 && (
    <section class="section">
      <div class="container">
        <SectionTitle
          kicker="Related Families"
          title={`More in ${category?.name ?? "this range"}.`}
          subtitle="Buyers reviewing this category also compare the following products."
        />

        <div class="related-grid">
          {relatedFamilies.map((relatedFamily) => (
            <ProductCard family={relatedFamily} />
          ))}
        </div>
      </div>
    </section>
  )}
</BaseLayout>

<script>
  const setupVariantSwitcher = () => {
    const buttons = Array.from(document.querySelectorAll<HTMLButtonElement>("[data-model-target]"));
    const panels = Array.from(document.querySelectorAll<HTMLElement>("[data-model-panel]"));

    buttons.forEach((button) => {
      if (button.dataset.variantReady === "true") {
        return;
      }

      button.dataset.variantReady = "true";

      button.addEventListener("click", () => {
        const target = button.getAttribute("data-model-target");
        const images = JSON.parse(button.getAttribute("data-model-images") ?? "[]");
        const name = button.getAttribute("data-model-name") ?? "";
        buttons.forEach((candidate) => {
          candidate.classList.remove("is-active");
          candidate.setAttribute("aria-selected", "false");
        });
        panels.forEach((panel) => {
          const isMatch = panel.getAttribute("data-model-panel") === target;
          panel.toggleAttribute("hidden", !isMatch);
          panel.classList.toggle("is-active", isMatch);
        });
        button.classList.add("is-active");
        button.setAttribute("aria-selected", "true");

        const gallery = document.querySelector("[data-product-gallery]");
        if (gallery) {
          gallery.dispatchEvent(
            new CustomEvent("gallery:update", {
              detail: { images, name },
            }),
          );
        }
      });
    });
  };

  if (document.readyState === "loading") {
    document.addEventListener("DOMContentLoaded", setupVariantSwitcher, { once: true });
  } else {
    setupVariantSwitcher();
  }

  document.addEventListener("astro:page-load", setupVariantSwitcher);
</script>

<style>
  .product-hero {
    padding-bottom: 1rem;
  }

  .product-hero__navrow {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    margin-bottom: 0.6rem;
  }

  .product-hero__category-tag {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    border-radius: 999px;
    padding: 0.46rem 0.8rem;
    background: rgba(25, 77, 128, 0.08);
    color: var(--color-primary);
    font-size: 0.75rem;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    white-space: nowrap;
  }

  .product-hero__grid {
    display: grid;
    grid-template-columns: 1.35fr 0.8fr;
    gap: 1.6rem;
  }

  .product-hero__content {
    display: grid;
    gap: 1rem;
  }

  .product-hero__content h1 {
    font-size: clamp(2.7rem, 5vw, 4.4rem);
    line-height: 0.94;
    letter-spacing: -0.05em;
    max-width: 12ch;
  }

  .product-hero__summary {
    color: var(--color-text-muted);
    line-height: 1.85;
    max-width: 52rem;
  }

  .product-hero__meta {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 0.9rem;
  }

  .product-hero__meta .panel,
  .product-hero__aside {
    padding: 1rem;
  }

  .product-hero__meta strong {
    display: block;
    margin-bottom: 0.35rem;
    font-size: 1.2rem;
  }

  .product-hero__meta span,
  .product-hero__aside p {
    color: var(--color-text-muted);
    line-height: 1.7;
  }

  .product-hero__aside {
    display: grid;
    gap: 0.8rem;
    align-content: start;
    align-self: start;
    justify-items: start;
  }

  .product-hero__aside-kicker,
  .variant-panel__eyebrow {
    color: var(--color-primary);
    font-size: 0.76rem;
    font-weight: 700;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    margin: 0;
  }

  .product-hero__aside h2 {
    font-size: 1.55rem;
  }

  .gallery-empty {
    display: grid;
    gap: 0.8rem;
    padding: 1.4rem;
  }

  .gallery-empty p {
    color: var(--color-text-muted);
    line-height: 1.7;
  }

  .section--product-highlights {
    padding-top: 0.25rem;
    padding-bottom: 0.75rem;
  }

  .product-highlights {
    display: grid;
    gap: 1.25rem;
    padding: 1.35rem;
  }

  .product-highlights__intro {
    display: grid;
    gap: 0.55rem;
    max-width: 34rem;
  }

  .product-highlights__intro h2 {
    font-size: clamp(1.6rem, 3.6vw, 2.25rem);
  }

  .product-highlights__grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 0.9rem;
  }

  .product-highlight-item {
    display: grid;
    grid-template-columns: auto 1fr;
    gap: 0.8rem;
    align-items: start;
    padding: 1rem;
    border-radius: 1rem;
    background: rgba(255, 255, 255, 0.72);
    border: 1px solid rgba(84, 96, 109, 0.12);
  }

  .product-highlight-item__marker {
    width: 0.7rem;
    height: 0.7rem;
    margin-top: 0.45rem;
    border-radius: 999px;
    background: linear-gradient(135deg, rgba(201, 111, 40, 0.95), rgba(25, 77, 128, 0.9));
    box-shadow: 0 0 0 0.28rem rgba(25, 77, 128, 0.08);
  }

  .product-highlight-item p {
    margin: 0;
    color: var(--color-text);
    font-size: 1rem;
    line-height: 1.72;
  }

  .section--band {
    background: linear-gradient(180deg, rgba(25, 77, 128, 0.04), rgba(25, 77, 128, 0.01));
  }

  .matrix {
    overflow: hidden;
  }

  .matrix__table-wrap {
    overflow-x: auto;
  }

  .matrix__cards {
    display: none;
  }

  table {
    width: 100%;
    border-collapse: collapse;
    min-width: 38rem;
  }

  th,
  td {
    padding: 0.95rem 1rem;
    border-bottom: 1px solid rgba(84, 96, 109, 0.14);
    text-align: left;
    vertical-align: top;
  }

  th {
    background: rgba(25, 77, 128, 0.06);
    font-size: 0.82rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
  }

  td {
    color: var(--color-text-muted);
  }

  td:first-child {
    color: var(--color-text);
    font-weight: 700;
  }

  .variant-switcher {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
    margin-bottom: 1.1rem;
  }

  .variant-switcher__button {
    border: 1px solid rgba(84, 96, 109, 0.18);
    border-radius: 999px;
    padding: 0.7rem 0.95rem;
    background: rgba(255, 255, 255, 0.86);
    color: var(--color-text-muted);
  }

  .variant-switcher__button.is-active {
    background: var(--color-primary);
    border-color: var(--color-primary);
    color: white;
  }

  .variant-panel {
    padding: 1.3rem;
  }

  .variant-panel__header {
    display: flex;
    justify-content: space-between;
    gap: 1rem;
    padding-bottom: 1rem;
    border-bottom: 1px solid rgba(84, 96, 109, 0.14);
  }

  .variant-panel__header h2 {
    margin-top: 0.35rem;
    font-size: 2rem;
  }

  .variant-panel__model-code {
    margin: 0.35rem 0 0;
    color: var(--color-text-muted);
    font-size: 0.92rem;
  }

  .variant-panel__tag {
    display: inline-flex;
    align-items: center;
    align-self: start;
    border-radius: 999px;
    padding: 0.45rem 0.75rem;
    background: rgba(25, 77, 128, 0.08);
    color: var(--color-primary);
    font-size: 0.78rem;
    font-weight: 700;
  }

  .variant-panel__grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1.4rem;
    padding-top: 1rem;
  }

  .variant-panel__specs {
    display: grid;
    gap: 0.8rem;
  }

  .variant-panel__spec {
    display: flex;
    justify-content: space-between;
    gap: 1rem;
    padding-bottom: 0.7rem;
    border-bottom: 1px solid rgba(84, 96, 109, 0.1);
  }

  .variant-panel__spec span {
    color: var(--color-text-muted);
  }

  .variant-panel__spec strong {
    text-align: right;
  }

  .variant-panel__notes h3 {
    margin-bottom: 0.8rem;
    font-size: 1.05rem;
  }

  .variant-panel__notes ul {
    display: grid;
    gap: 0.7rem;
    margin: 0;
    padding-left: 1.1rem;
    color: var(--color-text-muted);
    line-height: 1.65;
  }

  .variant-panel__notes p {
    color: var(--color-text-muted);
    line-height: 1.7;
  }

  .matrix-card {
    display: grid;
    gap: 0.95rem;
    padding: 1rem;
    border-radius: 1rem;
    border: 1px solid rgba(84, 96, 109, 0.12);
    background: rgba(255, 255, 255, 0.74);
  }

  .matrix-card__head {
    display: grid;
    gap: 0.28rem;
  }

  .matrix-card__eyebrow {
    margin: 0;
    color: var(--color-primary);
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }

  .matrix-card__head h3 {
    font-size: 1.08rem;
    line-height: 1.28;
  }

  .matrix-card__rows {
    display: grid;
    gap: 0.72rem;
  }

  .matrix-card__row {
    display: grid;
    gap: 0.18rem;
    padding-bottom: 0.7rem;
    border-bottom: 1px solid rgba(84, 96, 109, 0.1);
  }

  .matrix-card__row:last-child {
    padding-bottom: 0;
    border-bottom: 0;
  }

  .matrix-card__row span {
    color: var(--color-text-muted);
    font-size: 0.76rem;
    line-height: 1.35;
    text-transform: uppercase;
    letter-spacing: 0.08em;
  }

  .matrix-card__row strong {
    color: var(--color-text);
    font-size: 0.92rem;
    line-height: 1.45;
  }

  .related-grid {
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    gap: 1.2rem;
  }

  @media (max-width: 1100px) {
    .product-hero__navrow {
      align-items: flex-start;
      flex-direction: column;
      gap: 0.45rem;
    }

    .product-hero__grid {
      grid-template-columns: 1fr;
    }

    .product-hero__summary {
      max-width: 46rem;
    }

    .product-hero__content {
      gap: 0.85rem;
    }

    .variant-panel__grid,
    .related-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }

    .gallery-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  @media (max-width: 760px) {
    .product-hero__navrow {
      margin-bottom: 0.4rem;
    }

    .product-hero__category-tag {
      font-size: 0.7rem;
      padding: 0.42rem 0.68rem;
      letter-spacing: 0.1em;
    }

    .product-hero__grid,
    .product-hero__meta,
    .product-highlights__grid,
    .variant-panel__grid,
    .related-grid,
    .gallery-grid {
      grid-template-columns: 1fr;
    }

    .variant-panel__header {
      flex-direction: column;
    }

    .product-hero {
      padding-bottom: 0.25rem;
    }

    .product-hero__content h1 {
      font-size: clamp(2rem, 10vw, 3rem);
      line-height: 1;
      max-width: 11ch;
    }

    .product-hero__summary {
      font-size: 0.94rem;
      line-height: 1.58;
      max-width: 100%;
    }

    .product-hero__meta .panel,
    .product-hero__aside,
    .product-highlights,
    .variant-panel {
      padding: 0.95rem;
    }

    .product-hero__aside h2,
    .variant-panel__header h2 {
      font-size: 1.32rem;
    }

    .product-highlights__intro h2 {
      font-size: clamp(1.35rem, 7.5vw, 1.9rem);
    }

    .product-highlight-item {
      gap: 0.7rem;
      padding: 0.9rem;
    }

    .product-highlight-item p {
      font-size: 0.94rem;
      line-height: 1.6;
    }

    th,
    td {
      padding: 0.65rem 0.7rem;
      font-size: 0.84rem;
    }

    .matrix__table-wrap {
      display: none;
    }

    .matrix__cards {
      display: grid;
      gap: 0.85rem;
      padding: 0.95rem;
    }

    .variant-switcher {
      overflow-x: auto;
      flex-wrap: nowrap;
      padding-bottom: 0.15rem;
      scrollbar-width: thin;
    }

    .variant-switcher__button {
      white-space: normal;
      flex: 0 0 auto;
      min-width: 10.25rem;
      max-width: 14rem;
      padding: 0.62rem 0.82rem;
      font-size: 0.84rem;
      line-height: 1.28;
      text-align: left;
    }

    .variant-panel__spec {
      flex-direction: column;
      gap: 0.28rem;
    }

    .variant-panel__spec strong {
      text-align: left;
    }
  }

  @media (max-width: 980px) {
    .product-hero__grid {
      grid-template-columns: 1fr;
    }

    .product-hero__meta {
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: 0.75rem;
    }

    .product-highlights__grid {
      grid-template-columns: 1fr;
    }

    .variant-panel__grid {
      grid-template-columns: 1fr;
    }

    .variant-panel__header {
      align-items: start;
    }

    .variant-panel__header h2 {
      font-size: 1.65rem;
      max-width: 18ch;
    }

    .variant-panel__tag {
      white-space: nowrap;
    }

    .product-hero__aside {
      gap: 0.7rem;
    }
  }

  @media (max-width: 860px) {
    .product-hero__meta {
      grid-template-columns: 1fr;
    }

    .variant-switcher {
      gap: 0.55rem;
    }

    .variant-switcher__button {
      padding-inline: 0.82rem;
    }

    .variant-panel {
      padding: 1.05rem;
    }
  }
</style>
