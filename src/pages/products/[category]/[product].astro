---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import Breadcrumbs from "../../../components/Breadcrumbs.astro";
import ProductCard from "../../../components/ProductCard.astro";
import ProductGallery from "../../../components/ProductGallery.astro";
import SectionTitle from "../../../components/SectionTitle.astro";
import {
  getAllFamilies,
  getCategoryBySlug,
  getRelatedFamilies,
} from "../../../data/catalogue";
import { business } from "../../../data/business";

export function getStaticPaths() {
  return getAllFamilies().map((family) => ({
    params: { category: family.categorySlug, product: family.slug },
    props: { family },
  }));
}

const { family } = Astro.props;
const category = getCategoryBySlug(family.categorySlug);
const relatedFamilies = getRelatedFamilies(family, 4);
const activeVariant = family.variants[0];
const matrixColumns = family.tableColumns.length > 0 ? family.tableColumns : ["Model"];
const galleryImages = Array.from(
  new Set([...(family.images.length > 0 ? family.images : []), ...(activeVariant?.images ?? [])]),
);
const detailNotes = [...family.highlights, ...family.notes].filter(Boolean).slice(0, 6);

function getAttributeValue(
  variant: { attributes: { label: string; value: string }[] },
  label: string,
) {
  return variant.attributes.find((attribute) => attribute.label === label)?.value ?? "Not listed";
}
---

<BaseLayout title={family.name} description={family.summary}>
  <section class="section product-hero">
    <div class="container">
      <Breadcrumbs
        breadcrumbs={[
          { label: "Catalogue", href: "/products" },
          category ? { label: category.name, href: `/products/${category.slug}` } : { label: family.categorySlug },
          { label: family.name },
        ]}
      />

      <div class="product-hero__grid">
        <div class="product-hero__content">
          <span class="eyebrow">{category?.name ?? "Catalogue Family"}</span>
          <h1>{family.name}</h1>
          <p class="product-hero__summary">{family.description}</p>

          <div class="product-hero__meta">
            <div class="panel">
              <strong>{family.variants.length}</strong>
              <span>available models</span>
            </div>
            <div class="panel">
              <strong>{category?.name ?? "Catalogue"}</strong>
              <span>business section</span>
            </div>
            <div class="panel">
              <strong>Quote only</strong>
              <span>pricing on request</span>
            </div>
          </div>

          {detailNotes.length > 0 && (
            <ul class="product-hero__notes">
              {detailNotes.map((item) => (
                <li>{item}</li>
              ))}
            </ul>
          )}
        </div>

        <aside class="product-hero__aside panel">
          <p class="product-hero__aside-kicker">Commercial mode</p>
          <h2>Family specifications are public. Quotations remain direct and request-based.</h2>
          <p>{business.quoteOnlyNote}</p>
          <p>{business.contactNote}</p>
          <a href="/contact" class="button button--primary">Open contact page</a>
        </aside>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      {galleryImages.length > 0 ? (
        <ProductGallery images={galleryImages} name={family.name} />
      ) : (
        <div class="gallery-empty panel">
          <h2>Product imagery is being mapped into this family.</h2>
          <p>The specification structure is already live. Additional approved images will continue to be attached to the relevant family and model records.</p>
        </div>
      )}
    </div>
  </section>

  <section class="section section--band">
    <div class="container">
      <SectionTitle
        kicker="Variant Matrix"
        title="Compare the model lineup at a glance."
        subtitle="This table surfaces the shared decision columns for the family so procurement teams can compare capacities, sizes, and configuration differences quickly."
      />

      <div class="matrix panel">
        <div class="matrix__table-wrap">
          <table>
            <thead>
              <tr>
                {matrixColumns.map((column) => (
                  <th>{column}</th>
                ))}
              </tr>
            </thead>
            <tbody>
              {family.variants.map((variant) => (
                <tr>
                  <td>{variant.model}</td>
                  {matrixColumns.slice(1).map((column) => (
                    <td>{getAttributeValue(variant, column)}</td>
                  ))}
                </tr>
              ))}
            </tbody>
          </table>
        </div>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container variant-section">
      <SectionTitle
        kicker="Model Details"
        title="Switch between models for specification-level review."
        subtitle="Each model keeps its own attributes, supporting notes, and approved imagery under the same family page."
      />

      <div class="variant-switcher" role="tablist" aria-label="Model selector">
        {family.variants.map((variant, index) => (
          <button
            class:list={["variant-switcher__button", { "is-active": index === 0 }]}
            data-model-target={variant.slug}
            role="tab"
            aria-selected={index === 0 ? "true" : "false"}
          >
            {variant.model}
          </button>
        ))}
      </div>

      <div class="variant-panels">
        {family.variants.map((variant, index) => (
          <article
            class:list={["variant-panel panel", { "is-active": index === 0 }]}
            data-model-panel={variant.slug}
            hidden={index === 0 ? undefined : true}
          >
            <div class="variant-panel__header">
              <div>
                <p class="variant-panel__eyebrow">Model</p>
                <h2>{variant.model}</h2>
              </div>
              <span class="variant-panel__tag">{family.name}</span>
            </div>

            <div class="variant-panel__grid">
              <div class="variant-panel__specs">
                {variant.attributes.map((attribute) => (
                  <div class="variant-panel__spec">
                    <span>{attribute.label}</span>
                    <strong>{attribute.value}</strong>
                  </div>
                ))}
              </div>

              <div class="variant-panel__notes">
                <h3>Supporting details</h3>
                {variant.descriptionLines.length > 0 ? (
                  <ul>
                    {variant.descriptionLines.map((line) => (
                      <li>{line}</li>
                    ))}
                  </ul>
                ) : (
                  <p>Additional line-level notes will continue to be expanded from the approved source files for this model.</p>
                )}
              </div>
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>

  {relatedFamilies.length > 0 && (
    <section class="section">
      <div class="container">
        <SectionTitle
          kicker="Related Families"
          title={`More from ${category?.name ?? "this catalogue section"}.`}
          subtitle="These families sit in the same business section and are commonly reviewed together during planning and procurement."
        />

        <div class="related-grid">
          {relatedFamilies.map((relatedFamily) => (
            <ProductCard family={relatedFamily} />
          ))}
        </div>
      </div>
    </section>
  )}
</BaseLayout>

<script>
  const buttons = Array.from(document.querySelectorAll("[data-model-target]"));
  const panels = Array.from(document.querySelectorAll("[data-model-panel]"));

  buttons.forEach((button) => {
    button.addEventListener("click", () => {
      const target = button.getAttribute("data-model-target");
      buttons.forEach((candidate) => {
        candidate.classList.remove("is-active");
        candidate.setAttribute("aria-selected", "false");
      });
      panels.forEach((panel) => {
        const isMatch = panel.getAttribute("data-model-panel") === target;
        panel.toggleAttribute("hidden", !isMatch);
        panel.classList.toggle("is-active", isMatch);
      });
      button.classList.add("is-active");
      button.setAttribute("aria-selected", "true");
    });
  });
</script>

<style>
  .product-hero {
    padding-bottom: 1rem;
  }

  .product-hero__grid {
    display: grid;
    grid-template-columns: 1.35fr 0.8fr;
    gap: 1.6rem;
  }

  .product-hero__content {
    display: grid;
    gap: 1rem;
  }

  .product-hero__content h1 {
    font-size: clamp(2.7rem, 5vw, 4.4rem);
    line-height: 0.94;
    letter-spacing: -0.05em;
    max-width: 12ch;
  }

  .product-hero__summary {
    color: var(--color-text-muted);
    line-height: 1.85;
    max-width: 58rem;
  }

  .product-hero__meta {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 0.9rem;
  }

  .product-hero__meta .panel,
  .product-hero__aside {
    padding: 1rem;
  }

  .product-hero__meta strong {
    display: block;
    margin-bottom: 0.35rem;
    font-size: 1.2rem;
  }

  .product-hero__meta span,
  .product-hero__aside p {
    color: var(--color-text-muted);
    line-height: 1.7;
  }

  .product-hero__notes {
    display: grid;
    gap: 0.65rem;
    margin: 0;
    padding-left: 1.15rem;
    color: var(--color-text-muted);
    line-height: 1.65;
  }

  .product-hero__aside {
    display: grid;
    gap: 0.8rem;
    align-content: start;
  }

  .product-hero__aside-kicker,
  .variant-panel__eyebrow {
    color: var(--color-primary);
    font-size: 0.76rem;
    font-weight: 700;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    margin: 0;
  }

  .product-hero__aside h2 {
    font-size: 1.55rem;
  }

  .gallery-empty {
    display: grid;
    gap: 0.8rem;
    padding: 1.4rem;
  }

  .gallery-empty p {
    color: var(--color-text-muted);
    line-height: 1.7;
  }

  .section--band {
    background: linear-gradient(180deg, rgba(25, 77, 128, 0.04), rgba(25, 77, 128, 0.01));
  }

  .matrix {
    overflow: hidden;
  }

  .matrix__table-wrap {
    overflow-x: auto;
  }

  table {
    width: 100%;
    border-collapse: collapse;
    min-width: 42rem;
  }

  th,
  td {
    padding: 0.95rem 1rem;
    border-bottom: 1px solid rgba(84, 96, 109, 0.14);
    text-align: left;
    vertical-align: top;
  }

  th {
    background: rgba(25, 77, 128, 0.06);
    font-size: 0.82rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
  }

  td {
    color: var(--color-text-muted);
  }

  td:first-child {
    color: var(--color-text);
    font-weight: 700;
  }

  .variant-switcher {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
    margin-bottom: 1.1rem;
  }

  .variant-switcher__button {
    border: 1px solid rgba(84, 96, 109, 0.18);
    border-radius: 999px;
    padding: 0.7rem 0.95rem;
    background: rgba(255, 255, 255, 0.86);
    color: var(--color-text-muted);
  }

  .variant-switcher__button.is-active {
    background: var(--color-primary);
    border-color: var(--color-primary);
    color: white;
  }

  .variant-panel {
    padding: 1.3rem;
  }

  .variant-panel__header {
    display: flex;
    justify-content: space-between;
    gap: 1rem;
    padding-bottom: 1rem;
    border-bottom: 1px solid rgba(84, 96, 109, 0.14);
  }

  .variant-panel__header h2 {
    margin-top: 0.35rem;
    font-size: 2rem;
  }

  .variant-panel__tag {
    display: inline-flex;
    align-items: center;
    align-self: start;
    border-radius: 999px;
    padding: 0.45rem 0.75rem;
    background: rgba(25, 77, 128, 0.08);
    color: var(--color-primary);
    font-size: 0.78rem;
    font-weight: 700;
  }

  .variant-panel__grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1.4rem;
    padding-top: 1rem;
  }

  .variant-panel__specs {
    display: grid;
    gap: 0.8rem;
  }

  .variant-panel__spec {
    display: flex;
    justify-content: space-between;
    gap: 1rem;
    padding-bottom: 0.7rem;
    border-bottom: 1px solid rgba(84, 96, 109, 0.1);
  }

  .variant-panel__spec span {
    color: var(--color-text-muted);
  }

  .variant-panel__spec strong {
    text-align: right;
  }

  .variant-panel__notes h3 {
    margin-bottom: 0.8rem;
    font-size: 1.05rem;
  }

  .variant-panel__notes ul {
    display: grid;
    gap: 0.7rem;
    margin: 0;
    padding-left: 1.1rem;
    color: var(--color-text-muted);
    line-height: 1.65;
  }

  .variant-panel__notes p {
    color: var(--color-text-muted);
    line-height: 1.7;
  }

  .related-grid {
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    gap: 1.2rem;
  }

  @media (max-width: 1100px) {
    .product-hero__grid,
    .variant-panel__grid,
    .related-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }

    .gallery-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  @media (max-width: 760px) {
    .product-hero__grid,
    .product-hero__meta,
    .variant-panel__grid,
    .related-grid,
    .gallery-grid {
      grid-template-columns: 1fr;
    }

    .variant-panel__header {
      flex-direction: column;
    }
  }
</style>
