---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import Breadcrumbs from "../../../components/Breadcrumbs.astro";
import ProductCard from "../../../components/ProductCard.astro";
import SectionTitle from "../../../components/SectionTitle.astro";
import { getAllCategories, getFamiliesByCategory } from "../../../data/catalogue";

export function getStaticPaths() {
  return getAllCategories().map((category) => ({
    params: { category: category.slug },
    props: { category },
  }));
}

const { category } = Astro.props;
const families = getFamiliesByCategory(category.slug);
const subheadings = [...new Set(families.map((family) => family.subheading).filter(Boolean))];
---

<BaseLayout title={category.name} description={category.summary}>
  <section class="section category-hero">
    <div class="container">
      <Breadcrumbs breadcrumbs={[{ label: "Catalogue", href: "/products" }, { label: category.name }]} />

      <div class="category-hero__panel panel">
        <div class="category-hero__copy" data-parallax-group>
          <span class="eyebrow" data-parallax-speed="0.08">Category</span>
          <h1>{category.name}</h1>
          <p data-parallax-speed="0.1">{category.intro}</p>
        </div>

        <dl class="category-hero__stats">
          <div>
            <dt>Product families</dt>
            <dd>{category.familyCount}</dd>
          </div>
          <div>
            <dt>Listed models</dt>
            <dd>{category.variantCount}</dd>
          </div>
        </dl>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <SectionTitle
        kicker="Products in This Category"
        title={`${category.name} Product Families`}
        subtitle="Open the relevant product family to review photos, listed models, and enquiry-ready details."
      />

      {subheadings.length > 0 && (
        <div class="subcategory-row">
          {subheadings.map((subheading) => (
            <span>{subheading}</span>
          ))}
        </div>
      )}

      <div class="family-grid">
        {families.map((family) => (
          <ProductCard family={family} />
        ))}
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .category-hero {
    padding-bottom: 1rem;
  }

  .category-hero__panel {
    display: grid;
    grid-template-columns: 1.2fr 0.8fr;
    gap: 1.5rem;
    padding: 1.45rem;
  }

  .category-hero__copy {
    display: grid;
    gap: 0.8rem;
  }

  .category-hero__copy h1 {
    font-size: clamp(2.6rem, 5vw, 4.1rem);
    line-height: 0.94;
    letter-spacing: -0.05em;
  }

  .category-hero__copy p {
    color: var(--color-text-muted);
    max-width: 50rem;
    line-height: 1.8;
  }

  .category-hero__stats {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 1rem;
    margin: 0;
  }

  .category-hero__stats div {
    padding: 1rem;
    border-radius: 1rem;
    background: rgba(25, 77, 128, 0.06);
  }

  .category-hero__stats dt {
    color: var(--color-text-muted);
    font-size: 0.8rem;
    margin-bottom: 0.4rem;
  }

  .category-hero__stats dd {
    margin: 0;
    font-family: var(--font-heading);
    font-size: 1.55rem;
  }

  .subcategory-row {
    display: flex;
    flex-wrap: wrap;
    gap: 0.65rem;
    margin-bottom: 1.2rem;
  }

  .subcategory-row span {
    display: inline-flex;
    border-radius: 999px;
    padding: 0.5rem 0.8rem;
    background: rgba(25, 77, 128, 0.08);
    color: var(--color-primary);
    font-size: 0.8rem;
    font-weight: 700;
  }

  .family-grid {
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    gap: 1.2rem;
  }

  @media (max-width: 1280px) {
    .family-grid {
      grid-template-columns: repeat(3, minmax(0, 1fr));
    }
  }

  @media (max-width: 1100px) {
    .category-hero__panel {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }

    .family-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  @media (max-width: 760px) {
    .category-hero {
      padding-top: 2.5rem;
      padding-bottom: 0.5rem;
    }

    .category-hero__panel,
    .family-grid {
      grid-template-columns: 1fr;
    }

    .category-hero__panel {
      gap: 1rem;
      padding: 1.1rem;
    }

    .category-hero__copy {
      gap: 0.65rem;
    }

    .category-hero__copy h1 {
      font-size: clamp(2.05rem, 9vw, 2.8rem);
      line-height: 0.98;
    }

    .category-hero__copy p {
      line-height: 1.65;
    }

    .category-hero__stats {
      grid-template-columns: 1fr;
      gap: 0.75rem;
    }

    .category-hero__stats div {
      padding: 0.85rem;
    }

    .subcategory-row {
      flex-wrap: nowrap;
      overflow-x: auto;
      padding-bottom: 0.1rem;
      margin-bottom: 1rem;
      scrollbar-width: thin;
    }

    .subcategory-row span {
      white-space: nowrap;
      flex: 0 0 auto;
      padding: 0.44rem 0.72rem;
      font-size: 0.76rem;
    }
  }
</style>
