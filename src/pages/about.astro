---
import BaseLayout from "../layouts/BaseLayout.astro";
import SectionTitle from "../components/SectionTitle.astro";
import { business } from "../data/business";
import { getAllCategories, getCatalogueStats } from "../data/catalogue";

const categories = getAllCategories();
const stats = getCatalogueStats();
---

<BaseLayout
  title="About Indian Surgical Industries"
  description="Indian Surgical Industries is a legacy medical equipment manufacturer with 40+ years of experience across autoclaves and sterilizers, vertical autoclaves, hospital hollowares, beds, operation tables, suction machines, trays, and allied hospital products."
>
  <section class="section about-hero">
    <div class="container about-hero__grid">
      <div class="about-hero__content" data-parallax-group>
        <span class="eyebrow" data-parallax-speed="0.08">{business.brandMark}</span>
        <h1 data-parallax-speed="0.16">Indian Surgical Industries has been manufacturing medical and hospital equipment for more than four decades.</h1>
        <p class="about-hero__copy" data-parallax-speed="0.1">{business.story[0]}</p>
        <p class="about-hero__copy" data-parallax-speed="0.08">{business.story[1]}</p>

        <div class="about-hero__actions" data-parallax-speed="0.08">
          <a href="/products" class="button button--primary">View product range</a>
          <a href="/contact" class="button button--secondary">Contact the team</a>
        </div>

        <ul class="about-hero__tags" data-parallax-speed="0.06">
          {business.certifications.map((item) => (
            <li>{item}</li>
          ))}
        </ul>
      </div>

      <aside class="about-hero__panel panel">
        <p class="about-hero__panel-kicker">Company Profile</p>
        <dl class="about-hero__stats">
          <div>
            <dt>Manufacturing legacy</dt>
            <dd>{business.experienceClaim}</dd>
          </div>
          <div>
            <dt>Product categories</dt>
            <dd>{stats.categoryCount}</dd>
          </div>
          <div>
            <dt>Product families</dt>
            <dd>{stats.familyCount}</dd>
          </div>
          <div>
            <dt>Model variants</dt>
            <dd>{stats.variantCount}</dd>
          </div>
        </dl>

        <div class="about-hero__facts">
          <div>
            <span>Manufacturing base</span>
            <strong>{business.manufacturingBase}</strong>
          </div>
          <div>
            <span>Market presence</span>
            <strong>{business.marketPresence}</strong>
          </div>
          <div>
            <span>Buying support</span>
            <strong>Direct quotation on request</strong>
          </div>
        </div>
      </aside>
    </div>
  </section>

  <section class="section section--band">
    <div class="container narrative-grid">
      <div>
        <SectionTitle
          kicker="Manufacturing Profile"
          title="Built for sterilization, patient care, ward utility, and OT support."
          subtitle={business.story[2]}
          align="left"
        />
        <div class="narrative-copy">
          <p>{business.story[3]}</p>
          <p>
            The company works with hospitals, distributors, procurement teams, and export buyers looking
            for dependable supply, practical product selection, and direct quotation support.
          </p>
        </div>
      </div>

      <div class="narrative-panels">
        <article class="panel narrative-card">
          <h2>Focus areas</h2>
          <ul>
            {business.focusAreas.map((item) => (
              <li>{item}</li>
            ))}
          </ul>
        </article>

        <article class="panel narrative-card">
          <h2>Who the range serves</h2>
          <ul>
            {business.customerSegments.map((item) => (
              <li>{item}</li>
            ))}
          </ul>
        </article>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <SectionTitle
        kicker="Product Categories"
        title="Major product categories across the company range."
        subtitle="Open the category that matches your requirement to review the relevant product families."
        align="left"
      />

      <div class="category-grid">
        {categories.map((category) => (
          <a href={`/products/${category.slug}`} class="category-tile panel">
            <span>{category.familyCount} families</span>
            <h3>{category.name}</h3>
            <p>{category.summary}</p>
          </a>
        ))}
      </div>
    </div>
  </section>

  <section class="section section--cta">
    <div class="container cta panel">
      <div>
        <span class="eyebrow">Enquiry and Quotation Support</span>
        <h2>Product specifications are available online. Quotations are shared directly based on model, quantity, and dispatch location.</h2>
      </div>
      <p>
        Review the relevant product family first, then contact the team with your shortlisted model,
        quantity, and dispatch requirement.
      </p>
      <div class="cta__actions">
        <a href="/products" class="button button--primary">View product range</a>
        <a href="/contact" class="button button--secondary">View contact details</a>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .about-hero {
    padding-top: 4.4rem;
  }

  .about-hero__grid {
    display: grid;
    grid-template-columns: 1.3fr 0.9fr;
    gap: 2rem;
    align-items: start;
  }

  .about-hero__content {
    display: grid;
    gap: 1.2rem;
  }

  .about-hero__content h1 {
    font-size: clamp(2.7rem, 5vw, 4.8rem);
    line-height: 0.95;
    letter-spacing: -0.05em;
    max-width: 13ch;
  }

  .about-hero__copy {
    max-width: 52rem;
    color: var(--color-text-muted);
    line-height: 1.8;
    margin: 0;
  }

  .about-hero__actions,
  .cta__actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.9rem;
  }

  .about-hero__tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.55rem;
    padding: 0;
    margin: 0;
    list-style: none;
  }

  .about-hero__tags li {
    border-radius: 999px;
    padding: 0.45rem 0.8rem;
    background: rgba(25, 77, 128, 0.08);
    color: var(--color-primary);
    font-size: 0.78rem;
    font-weight: 700;
  }

  .about-hero__panel {
    display: grid;
    gap: 1.1rem;
    padding: 1.35rem;
  }

  .about-hero__panel-kicker {
    margin: 0;
    color: var(--color-primary);
    font-size: 0.78rem;
    font-weight: 700;
    letter-spacing: 0.16em;
    text-transform: uppercase;
  }

  .about-hero__stats {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 0.9rem;
    margin: 0;
  }

  .about-hero__stats div,
  .about-hero__facts div {
    padding: 1rem;
    border-radius: 1rem;
    background: rgba(25, 77, 128, 0.06);
  }

  .about-hero__stats dt,
  .about-hero__facts span {
    display: block;
    color: var(--color-text-muted);
    font-size: 0.8rem;
    margin-bottom: 0.35rem;
  }

  .about-hero__stats dd,
  .about-hero__facts strong {
    margin: 0;
    font-family: var(--font-heading);
    font-size: 1.45rem;
  }

  .about-hero__facts {
    display: grid;
    gap: 0.8rem;
  }

  .section--band {
    background: linear-gradient(180deg, rgba(25, 77, 128, 0.04), rgba(25, 77, 128, 0.01));
  }

  .narrative-grid {
    display: grid;
    grid-template-columns: 1.05fr 0.95fr;
    gap: 2rem;
  }

  .narrative-copy {
    display: grid;
    gap: 1rem;
    color: var(--color-text-muted);
    line-height: 1.8;
  }

  .narrative-panels {
    display: grid;
    gap: 1rem;
  }

  .narrative-card {
    padding: 1.2rem;
  }

  .narrative-card h2 {
    margin-bottom: 0.9rem;
    font-size: 1.1rem;
  }

  .narrative-card ul {
    display: grid;
    gap: 0.7rem;
    margin: 0;
    padding-left: 1.1rem;
    color: var(--color-text-muted);
    line-height: 1.65;
  }

  .category-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 1rem;
  }

  .category-tile {
    display: grid;
    gap: 0.7rem;
    padding: 1.2rem;
  }

  .category-tile span {
    color: var(--color-primary);
    font-size: 0.76rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
  }

  .category-tile h3 {
    font-size: 1.2rem;
  }

  .category-tile p,
  .cta p {
    color: var(--color-text-muted);
    line-height: 1.7;
    margin: 0;
  }

  .section--cta {
    padding-bottom: 5.5rem;
  }

  .cta {
    display: grid;
    gap: 1rem;
    padding: 1.5rem;
  }

  .cta h2 {
    margin-top: 0.8rem;
    max-width: 18ch;
    font-size: clamp(1.8rem, 4vw, 2.5rem);
  }

  @media (max-width: 1100px) {
    .about-hero__grid,
    .narrative-grid,
    .category-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  @media (max-width: 760px) {
    .about-hero__grid,
    .narrative-grid,
    .category-grid,
    .about-hero__stats {
      grid-template-columns: 1fr;
    }
  }
</style>
