---
import BaseLayout from "../layouts/BaseLayout.astro";
import CatalogueDownloadPanel from "../components/CatalogueDownloadPanel.astro";
import CategoryCard from "../components/CategoryCard.astro";
import SectionTitle from "../components/SectionTitle.astro";
import { business, getPrimaryContactHref } from "../data/business";
import {
  getAllCategories,
  getFamiliesByCategory,
  type ProductFamily,
} from "../data/catalogue";

const categories = getAllCategories();
const categoryNames = new Map(categories.map((category) => [category.slug, category.name]));
const showcaseFamilies = categories
  .reduce<ProductFamily[]>((collection, category) => {
    const leadFamily = [...getFamiliesByCategory(category.slug)]
      .filter((family) => family.images.length > 0)
      .sort(
        (left, right) =>
          right.images.length - left.images.length || right.variants.length - left.variants.length,
      )[0];

    if (leadFamily) {
      collection.push(leadFamily);
    }

    return collection;
  }, [])
  .slice(0, 8);
const primaryContactHref = getPrimaryContactHref();
---

<BaseLayout
  title="Industrial Medical Equipment Catalogue"
  description="Indian Surgical Industries manufactures autoclaves, sterilizers, hospital hollowares, hospital furniture, suction units, OT equipment, and allied medical products."
>
  <section class="hero section">
    <div class="container hero__grid">
      <div class="hero__content panel">
        <span class="eyebrow">Indian Surgical Industries</span>
        <h1>Greetings from Indian Surgical Industries!</h1>
        <div class="hero__copy hero__copy--stacked">
          <p>
            We are a leading Manufacturing Company of Medical and Surgical Equipments. We
            are an ISO Certified Organization.
          </p>
          <p>
            We provide products keeping in mind the latest technology, knowledge and best
            possible resources available along with continuously updating ourselves as per
            the market standards. Our Manufacturing process is a blend of tradition,
            innovative capabilities, modern machinery and experienced craftsmen.
          </p>
        </div>

        <div class="hero__actions">
          <a href="/products" class="button button--primary">Browse full catalogue</a>
          <a href="/about" class="button button--secondary">Read company profile</a>
        </div>

        <div class="hero__metrics">
          {business.heroMetrics.map((metric) =>
            metric.label === "Commercial model" ? (
              <a href="/get-quote" class="hero__metric hero__metric--cta panel">
                <strong>{metric.value}</strong>
              </a>
            ) : (
              <article class="hero__metric panel">
                <strong>{metric.value}</strong>
                <span>{metric.label}</span>
              </article>
            ),
          )}
        </div>
      </div>
    </div>
  </section>

  <section class="section section--categories">
    <div class="container">
      <SectionTitle
        kicker="Major Product Categories"
        title="Browse by Product Category"
        subtitle="Select the required product group and open the relevant product range directly."
        align="left"
      />

      <div class="category-strip">
        {categories.map((category) => (
          <CategoryCard category={category} />
        ))}
      </div>
    </div>
  </section>

  <section class="section section--band">
    <div class="container split">
      <div class="split__copy">
        <SectionTitle
          kicker="Company Positioning"
          title="A manufacturing-led medical equipment business with depth across sterilization, utility, and patient care."
          subtitle={business.story[0]}
          align="left"
        />
        <div class="story-list">
          {business.story.slice(1).map((line) => (
            <p>{line}</p>
          ))}
        </div>
      </div>

      <div class="focus-grid">
        {business.focusAreas.map((item) => (
          <article class="focus-card panel">
            <h3>{item}</h3>
            <p>Manufactured for hospitals, clinics, institutions, distributors, and export enquiries.</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="section section--explore">
    <div class="container">
      <SectionTitle
        kicker="Explore Our Products"
        title="Explore our Products"
        subtitle="A representative selection from our manufacturing range to help buyers identify the right product group and move into detailed specifications."
        align="center"
      />

      <div class="showcase-grid">
        {showcaseFamilies.map((family) => (
          <a href={`/products/${family.categorySlug}/${family.slug}`} class="showcase-card">
            <div class="showcase-card__media">
              {family.images[0] ? (
                <img src={family.images[0]} alt={family.name} loading="lazy" />
              ) : (
                <div class="showcase-card__placeholder"></div>
              )}
            </div>

            <div class="showcase-card__body">
              <p class="showcase-card__category">{categoryNames.get(family.categorySlug)}</p>
              <h3>{family.name}</h3>
              <span class="showcase-card__link">More products</span>
            </div>
          </a>
        ))}
      </div>

      <div class="showcase-cta">
        <a href="/products" class="button button--secondary">Browse the complete range</a>
      </div>
    </div>
  </section>

  <section class="section section--band">
    <div class="container">
      <CatalogueDownloadPanel
        title="Download the official company catalogue."
        subtitle="Open the online catalogue or download the official 72-page company catalogue PDF for product reference, distributor sharing, and institutional enquiries."
      />
    </div>
  </section>

  <section class="section section--trust">
    <div class="container">
      <div class="trust-shell panel">
        <div class="trust-shell__intro">
          <SectionTitle
            kicker="Leadership And Confidence"
            title="Trusted by hospitals, channel partners, and buyers across markets."
            subtitle="Our manufacturing background, product range, and customer experience reflect long-standing confidence in the business."
            align="left"
          />
        </div>

        <div class="leadership-grid">
          {business.leadershipHighlights.map((item) => (
            <article class="leadership-card">
              <strong>{item.value}</strong>
              <h3>{item.label}</h3>
              <p>{item.note}</p>
            </article>
          ))}
        </div>
      </div>

      <div class="review-block">
        <div class="review-block__intro">
          <span class="eyebrow">Customer Reviews</span>
          <h2>What customers say about working with us.</h2>
          <p>
            Feedback from procurement teams, distributors, and international buyers reflects confidence in
            product quality, service support, and long-term business reliability.
          </p>
        </div>

        <div class="review-grid">
          {business.testimonials.map((item) => (
            <article class="review-card panel">
              <div class="review-card__meta">
                <div class="review-card__avatar" aria-hidden="true">{item.name.charAt(0)}</div>
                <div>
                  <strong>{item.name}</strong>
                  <span>{item.role}</span>
                  {item.location && <small>{item.location}</small>}
                </div>
              </div>

              <p class="review-card__stars">★★★★★</p>
              <p class="review-card__stars-fixed">{"\u2605".repeat(item.rating)}</p>
              <blockquote>{item.quote}</blockquote>
            </article>
          ))}
        </div>
      </div>
    </div>
  </section>

  <section class="section section--cta">
    <div class="container cta panel">
      <div>
        <span class="eyebrow">Works And Enquiries</span>
        <h2>Contact Indian Surgical Industries for product selection and quotations.</h2>
      </div>
      <p>
        {business.quoteOnlyNote} {business.contact.addressLines.join(", ")}. Primary contact:
        {" "}{business.contact.phones[0]} | {business.contact.email}
      </p>
      <div class="cta__actions">
        <a href={primaryContactHref} class="button button--primary">Request quotation</a>
        <a href="/contact" class="button button--secondary">View full contact details</a>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .hero {
    position: relative;
    padding-top: 4.4rem;
    padding-bottom: 4.4rem;
    background:
      linear-gradient(115deg, rgba(8, 29, 51, 0.8) 0%, rgba(19, 74, 123, 0.58) 42%, rgba(223, 241, 255, 0.14) 100%),
      linear-gradient(180deg, rgba(245, 248, 250, 0.08), rgba(245, 248, 250, 0.02));
    overflow: hidden;
  }

  .hero::before {
    content: "";
    position: absolute;
    inset: 0;
    background:
      radial-gradient(circle at 18% 22%, rgba(255, 255, 255, 0.12), transparent 18%),
      linear-gradient(90deg, rgba(7, 31, 53, 0.26), transparent 48%);
    pointer-events: none;
  }

  .hero::after {
    content: "";
    position: absolute;
    inset: auto 0 0;
    height: 7rem;
    background: linear-gradient(180deg, rgba(245, 248, 250, 0), rgba(245, 248, 250, 1));
    pointer-events: none;
  }

  .hero__grid {
    position: relative;
    z-index: 1;
    display: grid;
    grid-template-columns: 1fr;
    align-items: start;
  }

  .hero__content {
    display: grid;
    gap: 1.4rem;
    max-width: 76rem;
    padding: 1.6rem;
    background:
      linear-gradient(180deg, rgba(6, 26, 44, 0.66), rgba(10, 39, 64, 0.74)),
      rgba(8, 29, 51, 0.58);
    border: 1px solid rgba(255, 255, 255, 0.16);
    box-shadow: 0 24px 60px rgba(8, 29, 51, 0.28);
  }

  .hero h1 {
    font-size: clamp(3rem, 7vw, 5.7rem);
    line-height: 0.92;
    letter-spacing: -0.06em;
    max-width: 13ch;
    color: white;
  }

  .hero__copy {
    max-width: 50rem;
    color: rgba(236, 244, 250, 0.88);
    font-size: 1.06rem;
    line-height: 1.85;
  }

  .hero__copy--stacked {
    display: grid;
    gap: 1rem;
  }

  .hero__copy--stacked p {
    margin: 0;
  }

  .hero__actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.9rem;
  }

  .hero__metrics {
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    gap: 0.9rem;
    margin-top: 0.6rem;
  }

  .hero__metric {
    display: grid;
    gap: 0.45rem;
    padding: 1rem;
    background: rgba(255, 255, 255, 0.1);
    border: 1px solid rgba(255, 255, 255, 0.08);
    box-shadow: none;
  }

  .hero__metric strong {
    font-size: 1.65rem;
    line-height: 1;
    color: white;
  }

  .hero__metric span {
    color: rgba(223, 235, 245, 0.84);
    font-size: 0.87rem;
  }

  .hero__metric--cta {
    align-items: center;
    justify-content: center;
    min-height: 100%;
    background: linear-gradient(135deg, rgba(201, 111, 40, 0.94), rgba(229, 141, 63, 0.92));
    border-color: rgba(255, 255, 255, 0.14);
    box-shadow: 0 18px 34px rgba(201, 111, 40, 0.28);
    transition:
      transform 180ms ease,
      box-shadow 180ms ease,
      filter 180ms ease;
  }

  .hero__metric--cta:hover {
    transform: translateY(-4px);
    box-shadow: 0 24px 40px rgba(201, 111, 40, 0.34);
    filter: saturate(1.05);
  }

  .hero__metric--cta strong {
    font-size: 1.45rem;
    text-align: center;
  }

  .hero .eyebrow {
    color: rgba(228, 241, 249, 0.88);
  }

  .section--categories {
    background:
      linear-gradient(180deg, rgba(255, 255, 255, 0.95), rgba(247, 249, 251, 0.98)),
      radial-gradient(circle at top left, rgba(25, 77, 128, 0.05), transparent 48%);
  }

  .category-strip {
    display: flex;
    gap: 1rem;
    margin-top: 1.5rem;
    overflow-x: auto;
    padding-bottom: 0.45rem;
    scrollbar-width: none;
    scroll-snap-type: x proximity;
  }

  .category-strip::-webkit-scrollbar {
    display: none;
  }

  .category-strip :global(.category-card) {
    width: clamp(220px, 16vw, 250px);
    flex: 0 0 auto;
    scroll-snap-align: start;
  }

  .section--explore {
    background:
      linear-gradient(180deg, rgba(255, 255, 255, 0.96), rgba(247, 249, 251, 0.98)),
      radial-gradient(circle at top center, rgba(25, 77, 128, 0.04), transparent 58%);
  }

  .showcase-grid {
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    gap: 1rem;
  }

  .showcase-card {
    display: grid;
    grid-template-rows: 17rem 1fr;
    min-height: 100%;
    border: 1px solid rgba(84, 96, 109, 0.12);
    border-radius: 1.1rem;
    overflow: hidden;
    background: rgba(255, 255, 255, 0.94);
    box-shadow: var(--shadow-card);
    transition:
      transform 180ms ease,
      box-shadow 180ms ease,
      border-color 180ms ease;
  }

  .showcase-card:hover {
    transform: translateY(-4px);
    border-color: rgba(25, 77, 128, 0.2);
    box-shadow: var(--shadow-card-hover);
  }

  .showcase-card__media {
    display: grid;
    place-items: end center;
    min-height: 17rem;
    padding: 1.15rem 1rem 0.85rem;
    overflow: hidden;
    background:
      radial-gradient(circle at top left, rgba(25, 77, 128, 0.1), transparent 48%),
      linear-gradient(180deg, rgba(255, 255, 255, 0.98), rgba(243, 247, 249, 0.98));
  }

  .showcase-card__media img,
  .showcase-card__placeholder {
    width: auto;
    height: auto;
    max-width: 92%;
    max-height: 92%;
    object-fit: contain;
    object-position: center bottom;
  }

  .showcase-card__placeholder {
    border-radius: 0.8rem;
    background:
      linear-gradient(135deg, rgba(25, 77, 128, 0.1), rgba(201, 111, 40, 0.06)),
      repeating-linear-gradient(
        90deg,
        rgba(255, 255, 255, 0.08) 0,
        rgba(255, 255, 255, 0.08) 1px,
        transparent 1px,
        transparent 20px
      );
  }

  .showcase-card__body {
    display: grid;
    grid-template-rows: auto minmax(4.2rem, auto) auto;
    gap: 0.45rem;
    padding: 0.95rem 1rem 1rem;
    border-top: 1px solid rgba(84, 96, 109, 0.08);
  }

  .showcase-card__category {
    margin: 0;
    color: var(--color-primary);
    font-size: 0.7rem;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }

  .showcase-card h3 {
    margin: 0;
    font-size: 1rem;
    line-height: 1.3;
    min-height: 4.2rem;
    display: -webkit-box;
    -webkit-box-orient: vertical;
    -webkit-line-clamp: 3;
    overflow: hidden;
  }

  .showcase-card__link {
    margin-top: auto;
    color: var(--color-text-muted);
    font-size: 0.78rem;
  }

  .showcase-cta {
    display: flex;
    justify-content: center;
    margin-top: 1.5rem;
  }

  .section--band {
    background: linear-gradient(180deg, rgba(25, 77, 128, 0.04), rgba(25, 77, 128, 0.01));
  }

  .section--trust {
    background:
      radial-gradient(circle at top right, rgba(201, 111, 40, 0.08), transparent 28%),
      linear-gradient(180deg, rgba(25, 77, 128, 0.04), rgba(25, 77, 128, 0.01));
  }

  .split {
    display: grid;
    grid-template-columns: 1.05fr 1fr;
    gap: 2rem;
  }

  .story-list {
    display: grid;
    gap: 1rem;
    color: var(--color-text-muted);
    line-height: 1.8;
  }

  .focus-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 1rem;
  }

  .focus-card {
    display: grid;
    gap: 0.8rem;
    padding: 1.2rem;
  }

  .focus-card h3 {
    font-size: 1.04rem;
  }

  .focus-card p {
    color: var(--color-text-muted);
    line-height: 1.7;
    font-size: 0.93rem;
  }

  .trust-shell {
    display: grid;
    gap: 1.25rem;
    padding: 1.45rem;
    margin-bottom: 1.2rem;
  }

  .leadership-grid,
  .review-grid {
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    gap: 1rem;
  }

  .leadership-card {
    display: grid;
    gap: 0.7rem;
    padding: 1rem;
    border-radius: 1rem;
    background: rgba(255, 255, 255, 0.72);
    border: 1px solid rgba(84, 96, 109, 0.12);
  }

  .leadership-card strong {
    font-family: var(--font-heading);
    font-size: 2rem;
    color: var(--color-primary);
  }

  .leadership-card h3 {
    font-size: 1rem;
  }

  .leadership-card p,
  .review-block__intro p,
  .review-card blockquote {
    color: var(--color-text-muted);
    line-height: 1.7;
    margin: 0;
  }

  .review-block {
    display: grid;
    gap: 1rem;
  }

  .review-block__intro {
    display: grid;
    gap: 0.75rem;
    max-width: 50rem;
  }

  .review-block__intro h2 {
    font-size: clamp(1.9rem, 4vw, 3rem);
    max-width: 16ch;
  }

  .review-card {
    display: grid;
    gap: 0.95rem;
    padding: 1.2rem;
  }

  .review-card__meta {
    display: flex;
    gap: 0.8rem;
    align-items: center;
  }

  .review-card__avatar {
    width: 3rem;
    height: 3rem;
    border-radius: 999px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    background: linear-gradient(135deg, rgba(25, 77, 128, 0.12), rgba(201, 111, 40, 0.16));
    color: var(--color-primary);
    font-family: var(--font-heading);
    font-size: 1.15rem;
  }

  .review-card__meta div {
    display: grid;
    gap: 0.15rem;
  }

  .review-card__meta span,
  .review-card__meta small {
    color: var(--color-text-muted);
  }

  .review-card__stars {
    display: none;
  }

  .review-card__stars-fixed {
    margin: 0;
    letter-spacing: 0.2em;
    color: var(--color-accent);
    font-size: 0.95rem;
  }

  .section--cta {
    padding-bottom: 5.5rem;
  }

  .cta {
    display: grid;
    gap: 1rem;
    padding: 1.6rem;
  }

  .cta h2 {
    font-size: clamp(1.8rem, 4vw, 2.6rem);
    margin-top: 0.8rem;
    max-width: 16ch;
  }

  .cta p {
    color: var(--color-text-muted);
    line-height: 1.7;
    max-width: 58rem;
  }

  .cta__actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.9rem;
  }

  @media (max-width: 1280px) {
    .showcase-grid {
      grid-template-columns: repeat(3, minmax(0, 1fr));
    }
  }

  @media (max-width: 1100px) {
    .hero__grid,
    .split {
      grid-template-columns: 1fr;
    }

    .hero {
      padding-bottom: 3.4rem;
      background-position: center;
    }

    .hero__metrics,
    .focus-grid,
    .leadership-grid,
    .review-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }

    .showcase-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  @media (max-width: 700px) {
    .hero {
      padding-top: 3.2rem;
      padding-bottom: 2.8rem;
    }

    .hero__content {
      padding: 1.2rem;
    }

    .hero__metrics,
    .showcase-grid,
    .focus-grid,
    .leadership-grid,
    .review-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
