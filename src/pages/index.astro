---
import BaseLayout from "../layouts/BaseLayout.astro";
import CategoryCard from "../components/CategoryCard.astro";
import ProductCard from "../components/ProductCard.astro";
import SectionTitle from "../components/SectionTitle.astro";
import { business, getPrimaryContactHref } from "../data/business";
import { getAllCategories, getCatalogueStats, getFeaturedFamilies } from "../data/catalogue";

const categories = getAllCategories();
const stats = getCatalogueStats();
const featuredFamilies = getFeaturedFamilies(9);
const primaryContactHref = getPrimaryContactHref();
---

<BaseLayout
  title="Industrial Medical Equipment Catalogue"
  description="Indian Surgical Industries presents a modern web catalogue for autoclaves, sterilizers, hollowares, hospital furniture, OT lights, transfer equipment, and allied medical products."
>
  <section class="hero section">
    <div class="container hero__grid">
      <div class="hero__content">
        <span class="eyebrow">Indian Surgical Industries</span>
        <h1>Built for procurement teams, hospitals, and institutions that need a serious catalogue.</h1>
        <p class="hero__copy">
          {business.shortDescription} This website is a display-first catalogue with model-led product
          navigation, detailed specification views, and future-ready data that can also power a modern
          export catalogue later.
        </p>

        <div class="hero__actions">
          <a href="/products" class="button button--primary">Browse full catalogue</a>
          <a href="/about" class="button button--secondary">Read company profile</a>
        </div>

        <div class="hero__metrics">
          {business.heroMetrics.map((metric) => (
            <article class="hero__metric panel">
              <strong>{metric.value}</strong>
              <span>{metric.label}</span>
            </article>
          ))}
        </div>
      </div>

      <aside class="hero__panel panel">
        <p class="hero__panel-kicker">Catalogue Scope</p>
        <dl class="hero__statlist">
          <div>
            <dt>Categories</dt>
            <dd>{stats.categoryCount}</dd>
          </div>
          <div>
            <dt>Product families</dt>
            <dd>{stats.familyCount}</dd>
          </div>
          <div>
            <dt>Model variants</dt>
            <dd>{stats.variantCount}</dd>
          </div>
          <div>
            <dt>Commercial mode</dt>
            <dd>Quote only</dd>
          </div>
        </dl>

        <div class="hero__panel-copy">
          <h2>Legacy manufacturing, modern presentation.</h2>
          <p>
            The website is now structured around normalized catalogue data rather than placeholder
            brochure cards, so each family can later feed better PDFs, sales decks, and updated product
            collateral as well.
          </p>
        </div>
      </aside>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <SectionTitle
        kicker="Catalogue Structure"
        title="Navigate the product range by real business categories."
        subtitle="The site follows the approved Indian Surgical Industries product structure so hospitals and procurement teams can move from category to family to model without guessing."
        align="left"
      />

      <div class="category-grid">
        {categories.map((category) => (
          <CategoryCard category={category} />
        ))}
      </div>
    </div>
  </section>

  <section class="section section--band">
    <div class="container split">
      <div class="split__copy">
        <SectionTitle
          kicker="Company Positioning"
          title="A manufacturing-led medical equipment business with depth across sterilization, utility, and patient care."
          subtitle={business.story[0]}
          align="left"
        />
        <div class="story-list">
          {business.story.slice(1).map((line) => (
            <p>{line}</p>
          ))}
        </div>
      </div>

      <div class="focus-grid">
        {business.focusAreas.map((item) => (
          <article class="focus-card panel">
            <h3>{item}</h3>
            <p>Part of the current digital catalogue prepared for web presentation and future export collateral.</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <SectionTitle
        kicker="Featured Range"
        title="Model-led product families from across the catalogue."
        subtitle="Every family page is built to handle model differences, selector flows, and structured specifications without exposing pricing."
        align="left"
      />

      <div class="family-grid">
        {featuredFamilies.map((family) => (
          <ProductCard family={family} />
        ))}
      </div>
    </div>
  </section>

  <section class="section section--trust">
    <div class="container">
      <div class="trust-shell panel">
        <div class="trust-shell__intro">
          <SectionTitle
            kicker="Leadership And Confidence"
            title="A strong place for achievements, market leadership signals, and customer proof."
            subtitle="This section is positioned near the end of the homepage so future review copy, awards, institutional proof, and leadership signals close the page with authority."
            align="left"
          />
        </div>

        <div class="leadership-grid">
          {business.leadershipHighlights.map((item) => (
            <article class="leadership-card">
              <strong>{item.value}</strong>
              <h3>{item.label}</h3>
              <p>{item.note}</p>
            </article>
          ))}
        </div>
      </div>

      <div class="review-block">
        <div class="review-block__intro">
          <span class="eyebrow">Customer Reviews</span>
          <h2>Customer confidence belongs here, right before the homepage closes.</h2>
          <p>
            Placeholder cards are live now. When you send the exact approved review copy, names, and
            locations, this block can be updated without moving the layout again.
          </p>
        </div>

        <div class="review-grid">
          {business.testimonialPlaceholders.map((item) => (
            <article class="review-card panel">
              <div class="review-card__meta">
                <div class="review-card__avatar" aria-hidden="true">{item.name.charAt(0)}</div>
                <div>
                  <strong>{item.name}</strong>
                  <span>{item.role}</span>
                  <small>{item.location}</small>
                </div>
              </div>

              <p class="review-card__stars">★★★★★</p>
              <blockquote>{item.quote}</blockquote>
            </article>
          ))}
        </div>
      </div>
    </div>
  </section>

  <section class="section section--cta">
    <div class="container cta panel">
      <div>
        <span class="eyebrow">Works And Enquiries</span>
        <h2>Speak with Indian Surgical Industries for quotations, product selection, and works-level contact.</h2>
      </div>
      <p>
        {business.quoteOnlyNote} {business.contact.addressLines.join(", ")}. Primary contact:
        {" "}{business.contact.phones[0]} | {business.contact.email}
      </p>
      <div class="cta__actions">
        <a href={primaryContactHref} class="button button--primary">Request quotation</a>
        <a href="/contact" class="button button--secondary">View full contact details</a>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .hero {
    padding-top: 4.4rem;
  }

  .hero__grid {
    display: grid;
    grid-template-columns: 1.35fr 0.95fr;
    gap: 2rem;
    align-items: start;
  }

  .hero__content {
    display: grid;
    gap: 1.4rem;
  }

  .hero h1 {
    font-size: clamp(3rem, 7vw, 5.7rem);
    line-height: 0.92;
    letter-spacing: -0.06em;
    max-width: 12ch;
  }

  .hero__copy {
    max-width: 50rem;
    color: var(--color-text-muted);
    font-size: 1.06rem;
    line-height: 1.85;
  }

  .hero__actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.9rem;
  }

  .hero__metrics {
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    gap: 0.9rem;
    margin-top: 0.6rem;
  }

  .hero__metric {
    display: grid;
    gap: 0.45rem;
    padding: 1rem;
  }

  .hero__metric strong {
    font-size: 1.65rem;
    line-height: 1;
  }

  .hero__metric span {
    color: var(--color-text-muted);
    font-size: 0.87rem;
  }

  .hero__panel {
    display: grid;
    gap: 1.2rem;
    padding: 1.4rem;
    background:
      radial-gradient(circle at top right, rgba(201, 111, 40, 0.18), transparent 28%),
      linear-gradient(180deg, rgba(255, 255, 255, 0.98), rgba(241, 245, 248, 0.96));
  }

  .hero__panel-kicker {
    color: var(--color-primary);
    font-size: 0.78rem;
    font-weight: 700;
    letter-spacing: 0.16em;
    text-transform: uppercase;
  }

  .hero__statlist {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 1rem;
    margin: 0;
  }

  .hero__statlist div {
    padding-bottom: 1rem;
    border-bottom: 1px solid rgba(84, 96, 109, 0.14);
  }

  .hero__statlist dt {
    color: var(--color-text-muted);
    font-size: 0.82rem;
    margin-bottom: 0.35rem;
  }

  .hero__statlist dd {
    margin: 0;
    font-family: var(--font-heading);
    font-size: 1.5rem;
  }

  .hero__panel-copy {
    display: grid;
    gap: 0.8rem;
  }

  .hero__panel-copy h2 {
    font-size: 1.6rem;
  }

  .hero__panel-copy p {
    color: var(--color-text-muted);
    line-height: 1.7;
  }

  .category-grid,
  .family-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 1.2rem;
  }

  .section--band {
    background: linear-gradient(180deg, rgba(25, 77, 128, 0.04), rgba(25, 77, 128, 0.01));
  }

  .section--trust {
    background:
      radial-gradient(circle at top right, rgba(201, 111, 40, 0.08), transparent 28%),
      linear-gradient(180deg, rgba(25, 77, 128, 0.04), rgba(25, 77, 128, 0.01));
  }

  .split {
    display: grid;
    grid-template-columns: 1.05fr 1fr;
    gap: 2rem;
  }

  .story-list {
    display: grid;
    gap: 1rem;
    color: var(--color-text-muted);
    line-height: 1.8;
  }

  .focus-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 1rem;
  }

  .focus-card {
    display: grid;
    gap: 0.8rem;
    padding: 1.2rem;
  }

  .focus-card h3 {
    font-size: 1.04rem;
  }

  .focus-card p {
    color: var(--color-text-muted);
    line-height: 1.7;
    font-size: 0.93rem;
  }

  .trust-shell {
    display: grid;
    gap: 1.25rem;
    padding: 1.45rem;
    margin-bottom: 1.2rem;
  }

  .leadership-grid,
  .review-grid {
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    gap: 1rem;
  }

  .leadership-card {
    display: grid;
    gap: 0.7rem;
    padding: 1rem;
    border-radius: 1rem;
    background: rgba(255, 255, 255, 0.72);
    border: 1px solid rgba(84, 96, 109, 0.12);
  }

  .leadership-card strong {
    font-family: var(--font-heading);
    font-size: 2rem;
    color: var(--color-primary);
  }

  .leadership-card h3 {
    font-size: 1rem;
  }

  .leadership-card p,
  .review-block__intro p,
  .review-card blockquote {
    color: var(--color-text-muted);
    line-height: 1.7;
    margin: 0;
  }

  .review-block {
    display: grid;
    gap: 1rem;
  }

  .review-block__intro {
    display: grid;
    gap: 0.75rem;
    max-width: 50rem;
  }

  .review-block__intro h2 {
    font-size: clamp(1.9rem, 4vw, 3rem);
    max-width: 16ch;
  }

  .review-card {
    display: grid;
    gap: 0.95rem;
    padding: 1.2rem;
  }

  .review-card__meta {
    display: flex;
    gap: 0.8rem;
    align-items: center;
  }

  .review-card__avatar {
    width: 3rem;
    height: 3rem;
    border-radius: 999px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    background: linear-gradient(135deg, rgba(25, 77, 128, 0.12), rgba(201, 111, 40, 0.16));
    color: var(--color-primary);
    font-family: var(--font-heading);
    font-size: 1.15rem;
  }

  .review-card__meta div {
    display: grid;
    gap: 0.15rem;
  }

  .review-card__meta span,
  .review-card__meta small {
    color: var(--color-text-muted);
  }

  .review-card__stars {
    margin: 0;
    letter-spacing: 0.2em;
    color: var(--color-accent);
    font-size: 0.95rem;
  }

  .section--cta {
    padding-bottom: 5.5rem;
  }

  .cta {
    display: grid;
    gap: 1rem;
    padding: 1.6rem;
  }

  .cta h2 {
    font-size: clamp(1.8rem, 4vw, 2.6rem);
    margin-top: 0.8rem;
    max-width: 16ch;
  }

  .cta p {
    color: var(--color-text-muted);
    line-height: 1.7;
    max-width: 58rem;
  }

  .cta__actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.9rem;
  }

  @media (max-width: 1100px) {
    .hero__grid,
    .split {
      grid-template-columns: 1fr;
    }

    .hero__metrics,
    .category-grid,
    .family-grid,
    .focus-grid,
    .leadership-grid,
    .review-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  @media (max-width: 700px) {
    .hero__metrics,
    .category-grid,
    .family-grid,
    .focus-grid,
    .leadership-grid,
    .review-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
