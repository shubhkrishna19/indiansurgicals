---
import BaseLayout from "../layouts/BaseLayout.astro";
import CatalogueDownloadPanel from "../components/CatalogueDownloadPanel.astro";
import CategoryCard from "../components/CategoryCard.astro";
import SectionTitle from "../components/SectionTitle.astro";
import { business } from "../data/business";
import {
  getAllCategories,
  getCatalogueStats,
  getFamiliesByCategory,
  type ProductFamily,
} from "../data/catalogue";

const categories = getAllCategories();
const catalogueStats = getCatalogueStats();
const categoryCarousel = [...categories, ...categories, ...categories];
const categoryNames = new Map(categories.map((category) => [category.slug, category.name]));
const showcaseLeadOverrides = new Map([
  ["autoclaves-and-sterilizers", "autoclave-triple-wall-horizontal"],
  ["vertical-autoclave", "auto-exhaust-vertical-autoclave"],
  ["hospital-utensils", "multipurpose-fumigator"],
]);
const showcaseMediaAdjustmentClass = new Map([
  ["autoclave-triple-wall-horizontal", "showcase-card__media--autoclave-fit"],
  ["multipurpose-fumigator", "showcase-card__media--fumigator-fit"],
]);
const getShowcaseMediaClass = (family: ProductFamily) => {
  if (showcaseMediaAdjustmentClass.has(family.slug)) {
    return showcaseMediaAdjustmentClass.get(family.slug);
  }

  if (family.slug.includes("autoclave")) {
    return "showcase-card__media--autoclave-fit";
  }

  if (family.slug.includes("fumigator")) {
    return "showcase-card__media--fumigator-fit";
  }

  return undefined;
};
const showcaseFamilies = categories
  .reduce<ProductFamily[]>((collection, category) => {
    const categoryFamilies = [...getFamiliesByCategory(category.slug)].filter(
      (family) => family.images.length > 0,
    );
    const preferredSlug = showcaseLeadOverrides.get(category.slug);
    const leadFamily =
      categoryFamilies.find((family) => family.slug === preferredSlug) ??
      categoryFamilies.sort(
        (left, right) =>
          right.images.length - left.images.length || right.variants.length - left.variants.length,
      )[0];

    if (leadFamily) {
      collection.push(leadFamily);
    }

    return collection;
  }, [])
  .slice(0, 8);
const heroMetrics = [
  { value: business.experienceClaim, label: "Years of manufacturing" },
  { value: `${catalogueStats.familyCount}`, label: "Product families" },
  { value: `${catalogueStats.categoryCount}`, label: "Product categories" },
  { value: "ISO / CE", label: "Quality certifications" },
];
const leadershipHighlights = [
  {
    value: business.experienceClaim,
    label: "Manufacturing continuity",
    note: "A long-standing operating base across sterilization, utility, patient care, and OT support products.",
  },
  {
    value: `${catalogueStats.familyCount}`,
    label: "Product families",
    note: "A broad manufacturing range across sterilization, furniture, ward utility, transfer systems, and OT support.",
  },
  {
    value: `${catalogueStats.categoryCount}`,
    label: "Major product categories",
    note: "From autoclaves and vertical autoclaves to hollowares, trays, beds, ward equipment, and OT lighting.",
  },
  {
    value: "ISO / CE",
    label: "Quality certifications",
    note: "Manufacturing aligned with institutional, dealer, and export requirements.",
  },
];
---

<BaseLayout
  title="Industrial Medical Equipment Catalogue"
  description="Indian Surgical Industries manufactures autoclaves and sterilizers, vertical autoclaves, hospital hollowares, stainless steel trays, suction machines, hospital beds, operation tables, and allied medical products."
>
  <section class="hero section">
    <div class="container hero__grid">
      <div class="hero__content panel" data-parallax-group>
        <span class="eyebrow" data-parallax-speed="0.08">Best in town.</span>
        <h1 data-parallax-speed="0.16">Greetings from Indian Surgical Industries!</h1>
        <div class="hero__copy hero__copy--stacked" data-parallax-speed="0.12">
          <p>
            We are a leading manufacturer of medical and surgical equipment and an ISO
            certified organization.
          </p>
          <p>
            Our range is built around dependable performance, practical design, and
            manufacturing experience across sterilization, ward utility, patient care, and
            OT support products.
          </p>
        </div>

        <div class="hero__actions" data-parallax-speed="0.1">
          <a href="/products" class="button button--primary">Browse full catalogue</a>
          <a href="/about" class="button button--secondary">Company Overview</a>
        </div>

        <div class="hero__metrics" data-parallax-speed="0.08">
          {heroMetrics.map((metric) => (
            <article class="hero__metric panel">
              <strong>{metric.value}</strong>
              <span>{metric.label}</span>
            </article>
          ))}
        </div>
      </div>
    </div>
  </section>

  <section class="section section--categories">
    <div class="container">
        <SectionTitle
          kicker="Major Product Categories"
          title="Choose the Product Category You Need"
          subtitle="Open the relevant section to compare product families, images, and available models."
          align="left"
        />

      <div class="category-strip js-category-carousel">
        <div class="category-strip__track">
          {categoryCarousel.map((category, index) => (
            <CategoryCard
              category={category}
              inert={index < categories.length || index >= categories.length * 2}
            />
          ))}
        </div>
      </div>
    </div>
  </section>

  <section class="section section--explore">
    <div class="container">
      <SectionTitle
        kicker="Explore Our Products"
        title="Featured Products Across Our Range"
        subtitle="Review representative products from major categories before opening the full catalogue."
        align="center"
      />

      <div class="showcase-grid">
        {showcaseFamilies.map((family) => (
          <a href={`/products/${family.categorySlug}/${family.slug}`} class="showcase-card">
            <div
              class:list={[
                "showcase-card__media",
                getShowcaseMediaClass(family),
              ]}
            >
              {family.images[0] ? (
                <img src={family.images[0]} alt={family.name} loading="lazy" />
              ) : (
                <div class="showcase-card__placeholder"></div>
              )}
            </div>

            <div class="showcase-card__body">
              <p class="showcase-card__category">{categoryNames.get(family.categorySlug)}</p>
              <h3>{family.name}</h3>
            </div>
          </a>
        ))}
      </div>

      <div class="showcase-cta">
        <a href="/products" class="button button--secondary">View complete product range</a>
      </div>
    </div>
  </section>

  <section class="section section--trust">
    <div class="container">
      <div class="trust-shell panel">
        <div class="trust-shell__intro">
          <SectionTitle
            kicker="Why Buyers Trust Us"
            title="Preferred by hospitals, channel partners, and institutional buyers."
            subtitle="A long manufacturing track record, broad product range, and dependable support help buyers source with confidence."
            align="left"
          />
        </div>

        <div class="leadership-grid">
          {leadershipHighlights.map((item) => (
            <article class="leadership-card">
              <strong>{item.value}</strong>
              <h3>{item.label}</h3>
              <p>{item.note}</p>
            </article>
          ))}
        </div>
      </div>

      <div class="review-block">
        <div class="review-block__intro">
          <span class="eyebrow">Customer Reviews</span>
          <h2>What buyers say about working <span class="review-block__nowrap">with us.</span></h2>
          <p>
            Feedback from procurement teams, distributors, and international buyers reflects confidence in
            product quality, service support, and long-term supply reliability.
          </p>
        </div>

        <div class="review-grid">
          {business.testimonials.map((item) => (
            <article class="review-card panel">
              <div class="review-card__meta">
                {item.image ? (
                  <img
                    class="review-card__avatar review-card__avatar--image"
                    src={item.image}
                    alt={item.name}
                    loading="lazy"
                  />
                ) : (
                  <div class="review-card__avatar" aria-hidden="true">{item.name.charAt(0)}</div>
                )}
                <div class="review-card__identity">
                  <small class="review-card__type">{item.type}</small>
                  <strong>{item.name}</strong>
                  <span>{item.role}</span>
                  {item.location && <small>{item.location}</small>}
                </div>
              </div>
              <div class="review-card__rating" aria-label={`${item.rating} out of 5 stars`}>
                <div class="review-card__stars" aria-hidden="true">
                  {Array.from({ length: item.rating }).map(() => (
                    <span>&#9733;</span>
                  ))}
                </div>
                <span class="review-card__rating-label">Verified review</span>
              </div>
              <blockquote>{item.quote}</blockquote>
            </article>
          ))}
        </div>
      </div>
    </div>
  </section>

  <section class="section section--band">
    <div class="container">
      <CatalogueDownloadPanel
        title="Official Company Catalogue"
        subtitle="View online or download the official PDF."
      />
    </div>
  </section>

</BaseLayout>

<script is:inline>
  const setupCategoryCarousel = () => {
    if (window.__isiCategoryCarouselCleanup) {
      window.__isiCategoryCarouselCleanup();
    }

    const cleanups = [];

    document.querySelectorAll(".js-category-carousel").forEach((strip) => {
      const track = strip.querySelector(".category-strip__track");
      if (!track) {
        return;
      }
      const prefersNativeScroll = window.matchMedia("(max-width: 900px)");

      if (prefersNativeScroll.matches) {
        strip.classList.add("is-native");
        track.style.transform = "";
        cleanups.push(() => {
          strip.classList.remove("is-native");
          track.style.transform = "";
        });
        return;
      }

      let pointerDown = false;
      let isDragging = false;
      let activePointerId = null;
      let startX = 0;
      let startOffset = 0;
      let suppressClick = false;
      let rafId = 0;
      let lastTime = performance.now();
      let segmentWidth = 0;
      let offset = 0;
      let pendingDragOffset = null;
      let pendingWheelDelta = 0;
      let frameQueued = false;

      const cycleDurationSeconds = 36;
      const dragThreshold = 8;
      let baseSpeed = 0;

      const applyOffset = () => {
        track.style.transform = `translate3d(${-offset}px, 0, 0)`;
      };

      const queueFrame = () => {
        if (frameQueued) {
          return;
        }

        frameQueued = true;
        window.requestAnimationFrame(() => {
          frameQueued = false;

          let mutated = false;

          if (pendingDragOffset !== null) {
            offset = pendingDragOffset;
            pendingDragOffset = null;
            mutated = true;
          }

          if (pendingWheelDelta !== 0) {
            offset += pendingWheelDelta;
            pendingWheelDelta = 0;
            mutated = true;
          }

          if (mutated) {
            normalizeLoop();
            applyOffset();
          }
        });
      };

      const normalizeLoop = () => {
        if (!segmentWidth) {
          return;
        }

        while (offset < segmentWidth * 0.5) {
          offset += segmentWidth;
        }

        while (offset >= segmentWidth * 1.5) {
          offset -= segmentWidth;
        }
      };

      const syncRailMetrics = (resetPosition = false) => {
        const nextSegmentWidth = track.scrollWidth / 3;
        if (!nextSegmentWidth) {
          return false;
        }

        const previousSegmentWidth = segmentWidth || nextSegmentWidth;
        segmentWidth = nextSegmentWidth;
        baseSpeed = segmentWidth / cycleDurationSeconds;

        if (resetPosition || !offset) {
          offset = segmentWidth;
        } else {
          offset = (offset / previousSegmentWidth) * segmentWidth;
        }

        normalizeLoop();
        applyOffset();
        return true;
      };

      const releaseDrag = () => {
        if (isDragging) {
          suppressClick = true;
        }

        pointerDown = false;
        isDragging = false;
        activePointerId = null;
        pendingDragOffset = null;
        pendingWheelDelta = 0;
        strip.classList.remove("is-dragging");
      };

      const tick = (time) => {
        const deltaSeconds = Math.min((time - lastTime) / 1000, 0.04);
        lastTime = time;

        if (!pointerDown && baseSpeed > 0 && segmentWidth > 0) {
          offset += baseSpeed * deltaSeconds;
          normalizeLoop();
          applyOffset();
        }

        rafId = window.requestAnimationFrame(tick);
      };

      const onPointerDown = (event) => {
        if (event.pointerType === "mouse" && event.button !== 0) {
          return;
        }

        pointerDown = true;
        isDragging = false;
        activePointerId = event.pointerId;
        startX = event.clientX;
        startOffset = offset;
        suppressClick = false;
      };

      const onPointerMove = (event) => {
        if (!pointerDown || event.pointerId !== activePointerId) {
          return;
        }

        if (event.pointerType === "mouse" && event.buttons === 0) {
          releaseDrag();
          return;
        }

        const delta = event.clientX - startX;
        if (!isDragging && Math.abs(delta) > dragThreshold) {
          isDragging = true;
          strip.classList.add("is-dragging");
          strip.setPointerCapture?.(event.pointerId);
        }

        if (!isDragging) {
          return;
        }

        pendingDragOffset = startOffset - delta;
        queueFrame();
      };

      const onWheel = (event) => {
        const delta = Math.abs(event.deltaX) > Math.abs(event.deltaY) ? event.deltaX : event.deltaY;
        if (!delta) {
          return;
        }

        pendingWheelDelta += delta;
        queueFrame();
      };

      const onRailClick = (event) => {
        if (suppressClick) {
          event.preventDefault();
          event.stopPropagation();
          suppressClick = false;
        }
      };

      const onPointerUp = (event) => {
        if (activePointerId !== null && event.pointerId !== activePointerId) {
          return;
        }

        if (activePointerId !== null && strip.hasPointerCapture?.(activePointerId)) {
          strip.releasePointerCapture?.(activePointerId);
        }

        releaseDrag();
      };

      const onDragStart = (event) => {
        event.preventDefault();
      };

      const onVisibilityChange = () => {
        lastTime = performance.now();
      };

      const onWindowBlur = () => {
        releaseDrag();
      };

      const resizeObserver = new ResizeObserver(() => {
        syncRailMetrics(false);
      });

      resizeObserver.observe(track);
      syncRailMetrics(true);

      strip.addEventListener("pointerdown", onPointerDown);
      strip.addEventListener("pointermove", onPointerMove);
      strip.addEventListener("pointerup", onPointerUp);
      strip.addEventListener("pointercancel", releaseDrag);
      strip.addEventListener("lostpointercapture", releaseDrag);
      strip.addEventListener("wheel", onWheel, { passive: true });
      strip.addEventListener("click", onRailClick);
      strip.addEventListener("dragstart", onDragStart);
      window.addEventListener("pointerup", onPointerUp);
      window.addEventListener("pointercancel", releaseDrag);
      window.addEventListener("blur", onWindowBlur);
      document.addEventListener("visibilitychange", onVisibilityChange);

      rafId = window.requestAnimationFrame(tick);

      cleanups.push(() => {
        window.cancelAnimationFrame(rafId);
        resizeObserver.disconnect();
        pendingDragOffset = null;
        pendingWheelDelta = 0;
        frameQueued = false;
        track.style.transform = "";
        strip.removeEventListener("pointerdown", onPointerDown);
        strip.removeEventListener("pointermove", onPointerMove);
        strip.removeEventListener("pointerup", onPointerUp);
        strip.removeEventListener("pointercancel", releaseDrag);
        strip.removeEventListener("lostpointercapture", releaseDrag);
        strip.removeEventListener("wheel", onWheel);
        strip.removeEventListener("click", onRailClick);
        strip.removeEventListener("dragstart", onDragStart);
        window.removeEventListener("pointerup", onPointerUp);
        window.removeEventListener("pointercancel", releaseDrag);
        window.removeEventListener("blur", onWindowBlur);
        document.removeEventListener("visibilitychange", onVisibilityChange);
      });
    });

    window.__isiCategoryCarouselCleanup = () => {
      cleanups.forEach((cleanup) => cleanup());
    };
  };

  const runCategoryCarousel = () => window.requestAnimationFrame(setupCategoryCarousel);

  if (document.readyState === "loading") {
    document.addEventListener("DOMContentLoaded", runCategoryCarousel, { once: true });
  } else {
    runCategoryCarousel();
  }

  document.addEventListener("astro:page-load", runCategoryCarousel);
  document.addEventListener("astro:before-preparation", () => {
    window.__isiCategoryCarouselCleanup?.();
  });
</script>

<style>
  .hero {
    position: relative;
    padding-top: 4.4rem;
    padding-bottom: 4.4rem;
    background:
      linear-gradient(115deg, rgba(8, 29, 51, 0.8) 0%, rgba(19, 74, 123, 0.58) 42%, rgba(223, 241, 255, 0.14) 100%),
      linear-gradient(180deg, rgba(245, 248, 250, 0.08), rgba(245, 248, 250, 0.02));
    overflow: hidden;
  }

  .hero::before {
    content: "";
    position: absolute;
    inset: 0;
    background:
      radial-gradient(circle at 18% 22%, rgba(255, 255, 255, 0.12), transparent 18%),
      linear-gradient(90deg, rgba(7, 31, 53, 0.26), transparent 48%);
    pointer-events: none;
  }

  .hero::after {
    content: "";
    position: absolute;
    inset: auto 0 0;
    height: 7rem;
    background: linear-gradient(180deg, rgba(245, 248, 250, 0), rgba(245, 248, 250, 1));
    pointer-events: none;
  }

  .hero__grid {
    position: relative;
    z-index: 1;
    display: grid;
    grid-template-columns: 1fr;
    align-items: start;
  }

  .hero__content {
    display: grid;
    gap: 1.4rem;
    max-width: 76rem;
    padding: 1.6rem;
    background:
      linear-gradient(180deg, rgba(6, 26, 44, 0.66), rgba(10, 39, 64, 0.74)),
      rgba(8, 29, 51, 0.58);
    border: 1px solid rgba(255, 255, 255, 0.16);
    box-shadow: 0 24px 60px rgba(8, 29, 51, 0.28);
  }

  .hero h1 {
    font-size: clamp(3rem, 7vw, 5.7rem);
    line-height: 0.92;
    letter-spacing: -0.06em;
    max-width: 13ch;
    color: white;
  }

  .hero__copy {
    max-width: 50rem;
    color: rgba(236, 244, 250, 0.88);
    font-size: 1.06rem;
    line-height: 1.85;
  }

  .hero__copy--stacked {
    display: grid;
    gap: 1rem;
  }

  .hero__copy--stacked p {
    margin: 0;
  }

  .hero__actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.9rem;
  }

  .hero__metrics {
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    gap: 0.9rem;
    margin-top: 0.6rem;
  }

  .hero__metric {
    display: grid;
    gap: 0.45rem;
    padding: 1rem;
    background: rgba(255, 255, 255, 0.1);
    border: 1px solid rgba(255, 255, 255, 0.08);
    box-shadow: none;
  }

  .hero__metric strong {
    font-size: 1.65rem;
    line-height: 1;
    color: white;
  }

  .hero__metric span {
    color: rgba(223, 235, 245, 0.84);
    font-size: 0.87rem;
  }

  .hero__metric--cta {
    align-items: center;
    justify-content: center;
    min-height: 100%;
    background: linear-gradient(135deg, rgba(201, 111, 40, 0.94), rgba(229, 141, 63, 0.92));
    border-color: rgba(255, 255, 255, 0.14);
    box-shadow: 0 18px 34px rgba(201, 111, 40, 0.28);
    transition:
      transform 180ms ease,
      box-shadow 180ms ease,
      filter 180ms ease;
  }

  .hero__metric--cta:hover {
    transform: translateY(-4px);
    box-shadow: 0 24px 40px rgba(201, 111, 40, 0.34);
    filter: saturate(1.05);
  }

  .hero__metric--cta strong {
    font-size: 1.45rem;
    text-align: center;
  }

  .hero .eyebrow {
    color: rgba(228, 241, 249, 0.88);
  }

  .section--categories {
    padding-bottom: 2.15rem;
    background:
      linear-gradient(180deg, rgba(255, 255, 255, 0.95), rgba(247, 249, 251, 0.98)),
      radial-gradient(circle at top left, rgba(25, 77, 128, 0.05), transparent 48%);
  }

  .section--categories :global(.section-title) {
    max-width: 68rem;
    margin-bottom: 1.9rem;
  }

  .section--categories :global(.section-title h2) {
    font-size: clamp(1.85rem, 3vw, 2.7rem);
  }

  .category-strip {
    margin-top: 1.5rem;
    overflow: hidden;
    padding: 0.15rem 0 0.55rem;
    cursor: grab;
    touch-action: pan-y;
    mask-image: linear-gradient(90deg, transparent, black 4%, black 96%, transparent);
  }

  .category-strip__track {
    display: flex;
    gap: 0.72rem;
    width: max-content;
    will-change: transform;
  }

  .category-strip.is-dragging {
    cursor: grabbing;
    user-select: none;
  }

  .category-strip :global(.category-card) {
    width: clamp(138px, 9.8vw, 166px);
    flex: 0 0 auto;
  }

  .section--explore {
    padding-top: 2.1rem;
    background:
      linear-gradient(180deg, rgba(241, 246, 249, 0.92), rgba(232, 238, 242, 0.96)),
      radial-gradient(circle at top center, rgba(25, 77, 128, 0.04), transparent 58%);
  }

  .showcase-grid {
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    gap: 1rem;
  }

  .showcase-card {
    display: grid;
    grid-template-rows: minmax(15rem, 17rem) 1fr;
    min-height: 100%;
    border: 1px solid rgba(25, 77, 128, 0.17);
    border-radius: 1.1rem;
    overflow: hidden;
    background:
      linear-gradient(180deg, rgba(252, 253, 254, 0.96), rgba(241, 245, 248, 0.95));
    box-shadow:
      0 16px 30px rgba(13, 45, 76, 0.1),
      inset 0 1px 0 rgba(255, 255, 255, 0.68);
    transition:
      transform 180ms ease,
      box-shadow 180ms ease,
      border-color 180ms ease;
  }

  .showcase-card:hover {
    transform: translateY(-4px);
    border-color: rgba(25, 77, 128, 0.24);
    box-shadow:
      0 24px 42px rgba(13, 45, 76, 0.14),
      inset 0 1px 0 rgba(255, 255, 255, 0.72);
  }

  .showcase-card__media {
    display: grid;
    place-items: center;
    min-height: 15rem;
    padding: 1.15rem 1rem 0.85rem;
    overflow: hidden;
    background:
      radial-gradient(circle at top left, rgba(25, 77, 128, 0.08), transparent 48%),
      linear-gradient(180deg, rgba(248, 251, 253, 0.98), rgba(236, 241, 245, 0.98));
  }

  .showcase-card__media img,
  .showcase-card__placeholder {
    width: auto;
    height: auto;
    max-width: 84%;
    max-height: 84%;
    object-fit: contain;
    object-position: center center;
  }

  .showcase-card__media--autoclave-fit img {
    max-width: 66%;
    max-height: 74%;
    object-position: center center;
  }

  .showcase-card__media--fumigator-fit img {
    max-width: 68%;
    max-height: 76%;
    object-position: center center;
  }

  .showcase-card__placeholder {
    border-radius: 0.8rem;
    background:
      linear-gradient(135deg, rgba(25, 77, 128, 0.1), rgba(201, 111, 40, 0.06)),
      repeating-linear-gradient(
        90deg,
        rgba(255, 255, 255, 0.08) 0,
        rgba(255, 255, 255, 0.08) 1px,
        transparent 1px,
        transparent 20px
      );
  }

  .showcase-card__body {
    display: grid;
    grid-template-rows: auto minmax(4.2rem, auto);
    gap: 0.45rem;
    padding: 0.95rem 1rem 1rem;
    border-top: 1px solid rgba(25, 77, 128, 0.08);
    background: linear-gradient(180deg, rgba(250, 252, 253, 0.76), rgba(240, 245, 248, 0.9));
  }

  .showcase-card__category {
    margin: 0;
    color: var(--color-primary);
    font-size: 0.7rem;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }

  .showcase-card h3 {
    margin: 0;
    font-size: 1rem;
    line-height: 1.3;
    min-height: 4.2rem;
    display: -webkit-box;
    -webkit-box-orient: vertical;
    -webkit-line-clamp: 3;
    overflow: hidden;
  }

  .showcase-cta {
    display: flex;
    justify-content: center;
    margin-top: 1.5rem;
  }

  .section--band {
    padding-top: 1.85rem;
    padding-bottom: 3.1rem;
