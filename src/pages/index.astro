---
import BaseLayout from "../layouts/BaseLayout.astro";
import CategoryCard from "../components/CategoryCard.astro";
import ProductCard from "../components/ProductCard.astro";
import SectionTitle from "../components/SectionTitle.astro";
import { business } from "../data/business";
import { getAllCategories, getCatalogueStats, getFeaturedFamilies } from "../data/catalogue";

const categories = getAllCategories();
const stats = getCatalogueStats();
const featuredFamilies = getFeaturedFamilies(9);
---

<BaseLayout
  title="Industrial Medical Equipment Catalogue"
  description="Indian Surgical Industries presents a modern web catalogue for autoclaves, sterilizers, hollowares, hospital furniture, OT lights, transfer equipment, and allied medical products."
>
  <section class="hero section">
    <div class="container hero__grid">
      <div class="hero__content">
        <span class="eyebrow">Indian Surgical Industries</span>
        <h1>Built for procurement teams, hospitals, and institutions that need a serious catalogue.</h1>
        <p class="hero__copy">
          {business.shortDescription} This website is a display-first catalogue with model-led product
          navigation, detailed specification views, and future-ready data that can also power a modern
          export catalogue later.
        </p>

        <div class="hero__actions">
          <a href="/products" class="button button--primary">Browse full catalogue</a>
          <a href="/about" class="button button--secondary">Read company profile</a>
        </div>

        <div class="hero__metrics">
          {business.heroMetrics.map((metric) => (
            <article class="hero__metric panel">
              <strong>{metric.value}</strong>
              <span>{metric.label}</span>
            </article>
          ))}
        </div>
      </div>

      <aside class="hero__panel panel">
        <p class="hero__panel-kicker">Catalogue Scope</p>
        <dl class="hero__statlist">
          <div>
            <dt>Categories</dt>
            <dd>{stats.categoryCount}</dd>
          </div>
          <div>
            <dt>Product families</dt>
            <dd>{stats.familyCount}</dd>
          </div>
          <div>
            <dt>Model variants</dt>
            <dd>{stats.variantCount}</dd>
          </div>
          <div>
            <dt>Commercial mode</dt>
            <dd>Quote only</dd>
          </div>
        </dl>

        <div class="hero__panel-copy">
          <h2>Legacy manufacturing, modern presentation.</h2>
          <p>
            The website is now structured around normalized catalogue data rather than placeholder
            brochure cards, so each family can later feed better PDFs, sales decks, and updated product
            collateral as well.
          </p>
        </div>
      </aside>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <SectionTitle
        kicker="Catalogue Structure"
        title="Navigate the product range by real business categories."
        subtitle="The site follows the approved Indian Surgical Industries product structure so hospitals and procurement teams can move from category to family to model without guessing."
        align="left"
      />

      <div class="category-grid">
        {categories.map((category) => (
          <CategoryCard category={category} />
        ))}
      </div>
    </div>
  </section>

  <section class="section section--band">
    <div class="container split">
      <div class="split__copy">
        <SectionTitle
          kicker="Company Positioning"
          title="A manufacturing-led medical equipment business with depth across sterilization, utility, and patient care."
          subtitle={business.story[0]}
          align="left"
        />
        <div class="story-list">
          {business.story.slice(1).map((line) => (
            <p>{line}</p>
          ))}
        </div>
      </div>

      <div class="focus-grid">
        {business.focusAreas.map((item) => (
          <article class="focus-card panel">
            <h3>{item}</h3>
            <p>Part of the current digital catalogue prepared for web presentation and future export collateral.</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <SectionTitle
        kicker="Featured Range"
        title="Model-led product families from across the catalogue."
        subtitle="Every family page is built to handle model differences, selector flows, and structured specifications without exposing pricing."
        align="left"
      />

      <div class="family-grid">
        {featuredFamilies.map((family) => (
          <ProductCard family={family} />
        ))}
      </div>
    </div>
  </section>

  <section class="section section--cta">
    <div class="container cta panel">
      <div>
        <span class="eyebrow">Public Contact Layer Pending</span>
        <h2>Catalogue, structure, and product data are live first. Final contact publishing comes next.</h2>
      </div>
      <p>{business.contactNote}</p>
      <div class="cta__actions">
        <a href="/products" class="button button--primary">Explore product families</a>
        <a href="/contact" class="button button--secondary">Open contact page</a>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .hero {
    padding-top: 4.4rem;
  }

  .hero__grid {
    display: grid;
    grid-template-columns: 1.35fr 0.95fr;
    gap: 2rem;
    align-items: start;
  }

  .hero__content {
    display: grid;
    gap: 1.4rem;
  }

  .hero h1 {
    font-size: clamp(3rem, 7vw, 5.7rem);
    line-height: 0.92;
    letter-spacing: -0.06em;
    max-width: 12ch;
  }

  .hero__copy {
    max-width: 50rem;
    color: var(--color-text-muted);
    font-size: 1.06rem;
    line-height: 1.85;
  }

  .hero__actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.9rem;
  }

  .hero__metrics {
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    gap: 0.9rem;
    margin-top: 0.6rem;
  }

  .hero__metric {
    display: grid;
    gap: 0.45rem;
    padding: 1rem;
  }

  .hero__metric strong {
    font-size: 1.65rem;
    line-height: 1;
  }

  .hero__metric span {
    color: var(--color-text-muted);
    font-size: 0.87rem;
  }

  .hero__panel {
    display: grid;
    gap: 1.2rem;
    padding: 1.4rem;
    background:
      radial-gradient(circle at top right, rgba(201, 111, 40, 0.18), transparent 28%),
      linear-gradient(180deg, rgba(255, 255, 255, 0.98), rgba(241, 245, 248, 0.96));
  }

  .hero__panel-kicker {
    color: var(--color-primary);
    font-size: 0.78rem;
    font-weight: 700;
    letter-spacing: 0.16em;
    text-transform: uppercase;
  }

  .hero__statlist {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 1rem;
    margin: 0;
  }

  .hero__statlist div {
    padding-bottom: 1rem;
    border-bottom: 1px solid rgba(84, 96, 109, 0.14);
  }

  .hero__statlist dt {
    color: var(--color-text-muted);
    font-size: 0.82rem;
    margin-bottom: 0.35rem;
  }

  .hero__statlist dd {
    margin: 0;
    font-family: var(--font-heading);
    font-size: 1.5rem;
  }

  .hero__panel-copy {
    display: grid;
    gap: 0.8rem;
  }

  .hero__panel-copy h2 {
    font-size: 1.6rem;
  }

  .hero__panel-copy p {
    color: var(--color-text-muted);
    line-height: 1.7;
  }

  .category-grid,
  .family-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 1.2rem;
  }

  .section--band {
    background: linear-gradient(180deg, rgba(25, 77, 128, 0.04), rgba(25, 77, 128, 0.01));
  }

  .split {
    display: grid;
    grid-template-columns: 1.05fr 1fr;
    gap: 2rem;
  }

  .story-list {
    display: grid;
    gap: 1rem;
    color: var(--color-text-muted);
    line-height: 1.8;
  }

  .focus-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 1rem;
  }

  .focus-card {
    display: grid;
    gap: 0.8rem;
    padding: 1.2rem;
  }

  .focus-card h3 {
    font-size: 1.04rem;
  }

  .focus-card p {
    color: var(--color-text-muted);
    line-height: 1.7;
    font-size: 0.93rem;
  }

  .section--cta {
    padding-bottom: 5.5rem;
  }

  .cta {
    display: grid;
    gap: 1rem;
    padding: 1.6rem;
  }

  .cta h2 {
    font-size: clamp(1.8rem, 4vw, 2.6rem);
    margin-top: 0.8rem;
    max-width: 16ch;
  }

  .cta p {
    color: var(--color-text-muted);
    line-height: 1.7;
    max-width: 58rem;
  }

  .cta__actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.9rem;
  }

  @media (max-width: 1100px) {
    .hero__grid,
    .split {
      grid-template-columns: 1fr;
    }

    .hero__metrics,
    .category-grid,
    .family-grid,
    .focus-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  @media (max-width: 700px) {
    .hero__metrics,
    .category-grid,
    .family-grid,
    .focus-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
