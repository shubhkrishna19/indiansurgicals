---
import BaseLayout from "../layouts/BaseLayout.astro";
import { getAllCategories } from "../data/catalogue";

const categories = getAllCategories().slice(0, 6);
---

<BaseLayout
  title="Page Not Found"
  description="The requested page is not available. Return to the Indian Surgical Industries homepage, product range, or contact page."
>
  <section class="section error-page">
    <div class="container error-page__content">
      <span class="eyebrow">404</span>
      <h1>This page is not available.</h1>
      <p>
        Return to the homepage, browse the product range, or open a major category below.
      </p>

      <div class="error-page__actions">
        <a href="/" class="button button--primary">Return home</a>
        <a href="/products" class="button button--secondary">View product range</a>
        <a href="/contact" class="button button--secondary">Contact the team</a>
      </div>
    </div>
  </section>

  <section class="section section--band">
    <div class="container">
      <div class="fallback-grid">
        {categories.map((category) => (
          <a href={`/products/${category.slug}`} class="panel fallback-card">
            <span>{category.familyCount} families</span>
            <h2>{category.name}</h2>
            <p>{category.summary}</p>
          </a>
        ))}
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .error-page {
    padding-top: 5rem;
    text-align: center;
  }

  .error-page__content {
    display: grid;
    gap: 1rem;
    justify-items: center;
  }

  .error-page h1 {
    font-size: clamp(2.8rem, 6vw, 5rem);
    line-height: 0.94;
    letter-spacing: -0.05em;
    max-width: 12ch;
  }

  .error-page p {
    max-width: 44rem;
    color: var(--color-text-muted);
    line-height: 1.8;
    margin: 0;
  }

  .error-page__actions {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 0.9rem;
    margin-top: 0.4rem;
  }

  .section--band {
    background: linear-gradient(180deg, rgba(25, 77, 128, 0.04), rgba(25, 77, 128, 0.01));
  }

  .fallback-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 1rem;
  }

  .fallback-card {
    display: grid;
    gap: 0.75rem;
    padding: 1.2rem;
  }

  .fallback-card span {
    color: var(--color-primary);
    font-size: 0.76rem;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }

  .fallback-card h2 {
    font-size: 1.2rem;
  }

  .fallback-card p {
    margin: 0;
    color: var(--color-text-muted);
    line-height: 1.65;
  }

  @media (max-width: 1100px) {
    .fallback-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  @media (max-width: 760px) {
    .fallback-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
