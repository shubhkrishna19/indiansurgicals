---
import BaseLayout from '../layouts/BaseLayout.astro';
import CTAButtons from '../components/CTAButtons.astro';
import MotionController from '../components/MotionController.astro';
import { getWhatsAppLink } from '../data/business';

// Suggested links for the user
const suggestedLinks = [
  { href: '/', label: 'Home', description: 'Browse our homepage' },
  { href: '/products', label: 'Products', description: 'View all medical equipment' },
  { href: '/products/surgical-instruments', label: 'Surgical Instruments', description: 'Precision surgical tools' },
  { href: '/products/hospital-furniture', label: 'Hospital Furniture', description: 'Quality hospital furniture' },
  { href: '/about', label: 'About Us', description: 'Learn more about us' }
];
---

<BaseLayout title="Page Not Found" description="The page you're looking for doesn't exist. Browse our medical equipment products or contact us for assistance.">
  <!-- 404 Hero Section -->
  <section class="error-hero">
    <div class="error-hero__bg">
      <div class="error-hero__pattern"></div>
    </div>
    <div class="container">
      <div class="error-content">
        <div class="error-code reveal">
          <span class="error-code__number">4</span>
          <span class="error-code__icon">
            <svg xmlns="http://www.w3.org/2000/svg" width="64" height="64" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <circle cx="12" cy="12" r="10"></circle>
              <line x1="12" y1="8" x2="12" y2="12"></line>
              <line x1="12" y1="16" x2="12.01" y2="16"></line>
            </svg>
          </span>
          <span class="error-code__number">4</span>
        </div>
        <h1 class="error-title reveal">Oops! Page Not Found</h1>
        <p class="error-message reveal">We couldn't find the page you were looking for.</p>
        <p class="error-description reveal">
          The page may have been moved, deleted, or never existed. Try browsing our main sections or get in touch with us for assistance.
        </p>
        <div class="error-cta reveal">
          <CTAButtons variant="primary" href="/" icon="arrow">
            Back to Home
          </CTAButtons>
          <CTAButtons variant="whatsapp" href={getWhatsAppLink('Hi, I need help finding products')} icon="whatsapp">
            Get Help on WhatsApp
          </CTAButtons>
        </div>
      </div>
    </div>
  </section>

  <!-- Suggested Links Section -->
  <section class="suggested-section">
    <div class="container">
      <h2 class="suggested-title reveal">Explore Our Site</h2>
      <p class="suggested-desc reveal">Here are some helpful links to get you started:</p>
      <div class="suggested-grid reveal-stagger">
        {suggestedLinks.map((link) => (
          <a href={link.href} class="suggested-card">
            <span class="suggested-card__label">{link.label}</span>
            <span class="suggested-card__desc">{link.description}</span>
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="suggested-card__arrow">
              <line x1="5" y1="12" x2="19" y2="12"></line>
              <polyline points="12 5 19 12 12 19"></polyline>
            </svg>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- Quick Help Section -->
  <section class="help-section">
    <div class="container">
      <div class="help-content reveal">
        <div class="help-icon">
          <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"></path>
          </svg>
        </div>
        <h2 class="help-title">Still Need Help?</h2>
        <p class="help-desc">
          Can't find what you're looking for? Our team is ready to assist you with product recommendations and quotes.
        </p>
        <div class="help-buttons">
          <a href="tel:+919876543210" class="help-button">
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"></path>
            </svg>
            Call Us
          </a>
          <a href={getWhatsAppLink('Hi, I need help finding products')} class="help-button help-button--whatsapp">
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M21 11.5a8.38 8.38 0 0 1-.9 3.8 8.5 8.5 0 0 1-7.6 4.7 8.38 8.38 0 0 1-3.8-.9L3 21l1.9-5.7a8.38 8.38 0 0 1-.9-3.8 8.5 8.5 0 0 1 4.7-7.6 8.38 8.38 0 0 1 3.8-.9h.5a8.48 8.48 0 0 1 8 8v.5z"></path>
            </svg>
            WhatsApp
          </a>
        </div>
      </div>
    </div>
  </section>

  <MotionController />
</BaseLayout>

<style>
  /* Error Hero */
  .error-hero {
    position: relative;
    padding: var(--space-24) 0;
    min-height: 70vh;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
  }

  .error-hero__bg {
    position: absolute;
    inset: 0;
    z-index: -1;
  }

  .error-hero__pattern {
    position: absolute;
    inset: 0;
    background:
      radial-gradient(ellipse 80% 50% at 50% -20%, rgba(13, 148, 136, 0.1), transparent),
      radial-gradient(ellipse 60% 40% at 80% 60%, rgba(249, 115, 22, 0.08), transparent);
  }

  .error-content {
    text-align: center;
    max-width: 600px;
  }

  .error-code {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: var(--space-4);
    margin-bottom: var(--space-6);
  }

  .error-code__number {
    font-family: var(--font-heading);
    font-size: 8rem;
    font-weight: 700;
    color: var(--color-border);
    line-height: 1;
    opacity: 0.5;
  }

  .error-code__icon {
    color: var(--color-primary);
    opacity: 0.5;
  }

  .error-title {
    font-family: var(--font-heading);
    font-size: clamp(1.75rem, 4vw, 2.5rem);
    font-weight: 600;
    color: var(--color-text);
    margin-bottom: var(--space-4);
  }

  .error-message {
    font-size: 1.25rem;
    font-weight: 600;
    color: var(--color-text);
    margin-bottom: var(--space-4);
  }

  .error-description {
    font-size: 1rem;
    line-height: 1.7;
    color: var(--color-text-muted);
    margin-bottom: var(--space-8);
  }

  .error-cta {
    display: flex;
    justify-content: center;
    gap: var(--space-4);
  }

  /* Suggested Section */
  .suggested-section {
    padding: var(--space-20) 0;
    background: var(--color-bg-alt);
  }

  .suggested-title {
    font-family: var(--font-heading);
    font-size: 1.75rem;
    font-weight: 600;
    color: var(--color-text);
    text-align: center;
    margin-bottom: var(--space-2);
  }

  .suggested-desc {
    font-size: 1rem;
    color: var(--color-text-muted);
    text-align: center;
    margin-bottom: var(--space-8);
  }

  .suggested-grid {
    display: grid;
    grid-template-columns: repeat(5, 1fr);
    gap: var(--space-4);
  }

  .suggested-card {
    display: flex;
    flex-direction: column;
    padding: var(--space-4);
    background: var(--color-surface);
    border-radius: var(--radius-lg);
    text-decoration: none;
    border: 1px solid var(--color-border);
    transition: all 0.3s var(--ease-out-expo);
    position: relative;
  }

  .suggested-card:hover {
    border-color: var(--color-primary);
    box-shadow: var(--shadow-md);
    transform: translateY(-2px);
  }

  .suggested-card__label {
    font-weight: 600;
    font-size: 0.9375rem;
    color: var(--color-text);
    margin-bottom: var(--space-1);
  }

  .suggested-card__desc {
    font-size: 0.75rem;
    color: var(--color-text-muted);
  }

  .suggested-card__arrow {
    position: absolute;
    bottom: var(--space-3);
    right: var(--space-3);
    color: var(--color-primary);
    opacity: 0;
    transform: translateX(-4px);
    transition: all 0.3s var(--ease-out-expo);
  }

  .suggested-card:hover .suggested-card__arrow {
    opacity: 1;
    transform: translateX(0);
  }

  /* Help Section */
  .help-section {
    padding: var(--space-20) 0;
  }

  .help-content {
    text-align: center;
    max-width: 500px;
    margin: 0 auto;
    padding: var(--space-10);
    background: var(--color-surface);
    border-radius: var(--radius-xl);
    box-shadow: var(--shadow-lg);
  }

  .help-icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 64px;
    height: 64px;
    background: var(--color-primary-50);
    border-radius: var(--radius-full);
    color: var(--color-primary);
    margin-bottom: var(--space-6);
  }

  .help-title {
    font-family: var(--font-heading);
    font-size: 1.5rem;
    font-weight: 600;
    color: var(--color-text);
    margin-bottom: var(--space-3);
  }

  .help-desc {
    font-size: 0.9375rem;
    line-height: 1.6;
    color: var(--color-text-muted);
    margin-bottom: var(--space-6);
  }

  .help-buttons {
    display: flex;
    justify-content: center;
    gap: var(--space-3);
  }

  .help-button {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    padding: var(--space-3) var(--space-5);
    background: var(--color-primary);
    color: white;
    border-radius: var(--radius-lg);
    font-size: 0.9375rem;
    font-weight: 600;
    text-decoration: none;
    transition: all 0.2s;
  }

  .help-button:hover {
    background: var(--color-primary-dark);
    transform: translateY(-2px);
  }

  .help-button--whatsapp {
    background: #25D366;
  }

  .help-button--whatsapp:hover {
    background: #128C7E;
  }

  /* Responsive */
  @media (max-width: 1024px) {
    .suggested-grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  @media (max-width: 768px) {
    .error-hero {
      min-height: 60vh;
    }

    .error-code__number {
      font-size: 5rem;
    }

    .error-code__icon svg {
      width: 48px;
      height: 48px;
    }

    .suggested-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 640px) {
    .error-hero {
      padding: var(--space-16) 0;
      min-height: auto;
    }

    .error-code {
      gap: var(--space-2);
    }

    .error-code__number {
      font-size: 4rem;
    }

    .error-cta {
      flex-direction: column;
    }

    .suggested-grid {
      grid-template-columns: 1fr;
    }

    .help-buttons {
      flex-direction: column;
    }

    .help-button {
      justify-content: center;
    }
  }
</style>
