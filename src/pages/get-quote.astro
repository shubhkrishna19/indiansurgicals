---
import BaseLayout from "../layouts/BaseLayout.astro";
import SectionTitle from "../components/SectionTitle.astro";
import { business, getWhatsAppLink } from "../data/business";
import { getAllCategories } from "../data/catalogue";

const categories = getAllCategories();
const whatsappLink = getWhatsAppLink();
---

<BaseLayout
  title="Get Quote"
  description="Contact Indian Surgical Industries for quotation support, product selection, works address, and direct buying communication."
>
  <section class="section quote-hero">
    <div class="container quote-hero__grid">
      <div class="quote-hero__content">
        <span class="eyebrow">Get Quote</span>
        <h1>Get direct quotation support from Indian Surgical Industries.</h1>
        <p class="quote-hero__copy">{business.quoteOnlyNote}</p>

        <div class="quote-hero__actions">
          <a href={whatsappLink} class="button button--primary">WhatsApp for quotation</a>
          <a href={`mailto:${business.contact.email}`} class="button button--secondary">Email the team</a>
        </div>

        <div class="quote-hero__highlights">
          <article class="quote-chip panel">
            <strong>{business.contact.phones[0]}</strong>
            <span>Primary mobile</span>
          </article>
          <article class="quote-chip panel">
            <strong>{business.contact.email}</strong>
            <span>Primary email</span>
          </article>
          <article class="quote-chip panel">
            <strong>{business.experienceClaim}</strong>
            <span>Manufacturing legacy</span>
          </article>
        </div>
      </div>

      <aside class="quote-hero__panel panel">
        <p class="quote-hero__panel-kicker">Fast Contact Routes</p>
        <div class="quote-hero__facts">
          <div>
            <span>Works base</span>
            <strong>{business.manufacturingBase}</strong>
          </div>
          <div>
            <span>Commercial mode</span>
            <strong>Quote only</strong>
          </div>
          <div>
            <span>Main mobile</span>
            <strong>{business.contact.phones.join(" / ")}</strong>
          </div>
          <div>
            <span>Telephone</span>
            <strong>{business.contact.telephones.join(" / ")}</strong>
          </div>
        </div>
      </aside>
    </div>
  </section>

  <section class="section section--band">
    <div class="container">
      <SectionTitle
        kicker="Contact Channels"
        title="Choose the easiest route to connect with the team."
        subtitle="Use WhatsApp for fast discussion, call for urgent buying requirements, or email your shortlisted models and quantities."
        align="left"
      />

      <div class="quote-grid">
        <article class="panel quote-card">
          <span>WhatsApp</span>
          <h2>Start a direct quote conversation</h2>
          <p>Best for quick model confirmation, quantity discussion, and follow-up on urgent institutional requirements.</p>
          <a href={whatsappLink}>Open WhatsApp</a>
        </article>

        <article class="panel quote-card">
          <span>Mobile Numbers</span>
          <h2>Call the sales contact line</h2>
          <p>Use the published mobile numbers for immediate coordination and quotation support.</p>
          {business.contact.phones.map((phone) => (
            <a href={`tel:${phone}`}>{phone}</a>
          ))}
        </article>

        <article class="panel quote-card">
          <span>Telephone</span>
          <h2>Reach the works line</h2>
          <p>Use the telephone line for general calling and office-level product communication.</p>
          {business.contact.telephones.map((phone) => (
            <a href={`tel:${phone}`}>{phone}</a>
          ))}
        </article>

        <article class="panel quote-card">
          <span>Email</span>
          <h2>Share your shortlist by email</h2>
          <p>Useful for distributor requirements, institutional lists, and model-by-model enquiry references.</p>
          {business.contact.emails.map((email) => (
            <a href={`mailto:${email}`}>{email}</a>
          ))}
        </article>

        <article class="panel quote-card">
          <span>Works Address</span>
          <h2>Manufacturing and works contact base</h2>
          <p>{business.contact.addressLines.join(", ")}</p>
          <a href="/contact">Open the full contact page</a>
        </article>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container quote-guide">
      <div>
        <SectionTitle
          kicker="Before You Contact"
          title="A cleaner enquiry gets a faster quotation."
          subtitle="Send the right details once so the team can respond with the correct family, model, and commercial guidance."
          align="left"
        />

        <div class="quote-steps">
          <article class="panel quote-step">
            <strong>01</strong>
            <h3>Share the product family or model</h3>
            <p>Mention the exact family page or model variant you shortlisted from the catalogue.</p>
          </article>

          <article class="panel quote-step">
            <strong>02</strong>
            <h3>Add quantity and use case</h3>
            <p>Include expected quantity, application, and whether the requirement is hospital, dealer, or export-led.</p>
          </article>

          <article class="panel quote-step">
            <strong>03</strong>
            <h3>Include dispatch city or country</h3>
            <p>Location helps the team guide model suitability, packing expectations, and the next commercial step.</p>
          </article>
        </div>
      </div>

      <aside class="panel quote-sections">
        <h2>Open a product section first</h2>
        <p>Browse a section before contacting so your enquiry starts with a clearer shortlist.</p>
        <ul>
          {categories.slice(0, 8).map((category) => (
            <li><a href={`/products/${category.slug}`}>{category.name}</a></li>
          ))}
        </ul>
        <a href="/products" class="button button--secondary">Browse full catalogue</a>
      </aside>
    </div>
  </section>
</BaseLayout>

<style>
  .quote-hero {
    padding-top: 4.4rem;
  }

  .quote-hero__grid {
    display: grid;
    grid-template-columns: 1.2fr 0.85fr;
    gap: 2rem;
    align-items: start;
  }

  .quote-hero__content {
    display: grid;
    gap: 1.2rem;
  }

  .quote-hero__content h1 {
    font-size: clamp(2.7rem, 5.4vw, 4.9rem);
    line-height: 0.95;
    letter-spacing: -0.05em;
    max-width: 12ch;
  }

  .quote-hero__copy {
    margin: 0;
    color: var(--color-text-muted);
    line-height: 1.8;
    max-width: 50rem;
  }

  .quote-hero__actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.9rem;
  }

  .quote-hero__highlights {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 0.9rem;
  }

  .quote-chip {
    display: grid;
    gap: 0.35rem;
    padding: 1rem;
  }

  .quote-chip strong {
    font-size: 1rem;
    line-height: 1.35;
    word-break: break-word;
  }

  .quote-chip span {
    color: var(--color-text-muted);
    font-size: 0.82rem;
  }

  .quote-hero__panel {
    display: grid;
    gap: 1rem;
    padding: 1.35rem;
    background:
      radial-gradient(circle at top right, rgba(201, 111, 40, 0.16), transparent 28%),
      linear-gradient(180deg, rgba(255, 255, 255, 0.98), rgba(242, 246, 249, 0.96));
  }

  .quote-hero__panel-kicker,
  .quote-card span {
    color: var(--color-primary);
    font-size: 0.76rem;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }

  .quote-hero__facts {
    display: grid;
    gap: 0.85rem;
  }

  .quote-hero__facts div {
    padding: 1rem;
    border-radius: 1rem;
    background: rgba(25, 77, 128, 0.05);
  }

  .quote-hero__facts span {
    display: block;
    color: var(--color-text-muted);
    font-size: 0.82rem;
    margin-bottom: 0.32rem;
  }

  .quote-hero__facts strong {
    font-family: var(--font-heading);
    font-size: 1.22rem;
    line-height: 1.35;
  }

  .section--band {
    background: linear-gradient(180deg, rgba(25, 77, 128, 0.04), rgba(25, 77, 128, 0.01));
  }

  .quote-grid {
    display: grid;
    grid-template-columns: repeat(5, minmax(0, 1fr));
    gap: 1rem;
  }

  .quote-card,
  .quote-step,
  .quote-sections {
    display: grid;
    gap: 0.8rem;
    padding: 1.2rem;
  }

  .quote-card h2,
  .quote-sections h2 {
    font-size: 1.16rem;
    line-height: 1.25;
  }

  .quote-card p,
  .quote-step p,
  .quote-sections p {
    margin: 0;
    color: var(--color-text-muted);
    line-height: 1.7;
  }

  .quote-card a,
  .quote-sections a {
    color: var(--color-text);
    font-weight: 600;
    word-break: break-word;
  }

  .quote-guide {
    display: grid;
    grid-template-columns: 1.15fr 0.85fr;
    gap: 2rem;
  }

  .quote-steps {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 1rem;
  }

  .quote-step strong {
    color: var(--color-primary);
    font-family: var(--font-heading);
    font-size: 1.65rem;
  }

  .quote-step h3 {
    font-size: 1.02rem;
    line-height: 1.35;
  }

  .quote-sections ul {
    display: grid;
    gap: 0.7rem;
    margin: 0;
    padding-left: 1rem;
    color: var(--color-text-muted);
  }

  @media (max-width: 1100px) {
    .quote-hero__grid,
    .quote-guide {
      grid-template-columns: 1fr;
    }

    .quote-grid,
    .quote-steps {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  @media (max-width: 760px) {
    .quote-hero__highlights,
    .quote-grid,
    .quote-steps {
      grid-template-columns: 1fr;
    }
  }
</style>
