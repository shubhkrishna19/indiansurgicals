---
import { business } from "../data/business";

const currentPath = Astro.url.pathname;
const navItems = [
  { href: "/", label: "Home" },
  { href: "/products", label: "Catalogue" },
  { href: "/about", label: "About" },
  { href: "/contact", label: "Contact" },
];

function isActive(href: string) {
  if (href === "/") {
    return currentPath === "/";
  }
  return currentPath.startsWith(href);
}
---

<header class="site-header">
  <div class="site-header__notice">
    <div class="container site-header__notice-inner">
      <span>{business.experienceClaim} manufacturing legacy</span>
      <span>{business.quoteOnlyNote}</span>
    </div>
  </div>

  <div class="container site-header__bar">
    <a href="/" class="site-header__brand">
      <span class="site-header__mark">
        <img src="/life-equip-logo.svg" alt={`${business.brandMark} logo`} />
      </span>
      <span class="site-header__brand-copy">
        <strong>{business.brand}</strong>
        <small>Industrial medical equipment catalogue</small>
      </span>
    </a>

    <nav class="site-header__nav" aria-label="Primary">
      {navItems.map((item) => (
        <a href={item.href} class:list={["site-header__link", { "is-active": isActive(item.href) }]}>
          {item.label}
        </a>
      ))}
    </nav>

    <a href="/contact" class="site-header__cta">Request details</a>
  </div>
</header>

<style>
  .site-header {
    position: sticky;
    top: 0;
    z-index: 50;
    backdrop-filter: blur(16px);
    background: rgba(245, 248, 250, 0.92);
    border-bottom: 1px solid rgba(84, 96, 109, 0.14);
  }

  .site-header__notice {
    border-bottom: 1px solid rgba(84, 96, 109, 0.1);
    background: linear-gradient(90deg, rgba(11, 27, 43, 0.98), rgba(25, 77, 128, 0.92));
    color: rgba(255, 255, 255, 0.88);
    font-size: 0.78rem;
  }

  .site-header__notice-inner {
    display: flex;
    justify-content: space-between;
    gap: 1rem;
    padding-block: 0.55rem;
  }

  .site-header__bar {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1.5rem;
    min-height: 5.2rem;
  }

  .site-header__brand {
    display: flex;
    align-items: center;
    gap: 0.95rem;
    min-width: 0;
  }

  .site-header__mark {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 3.55rem;
    height: 3.55rem;
    flex: 0 0 3.55rem;
    border-radius: 1rem;
    padding: 0.18rem;
    background: rgba(255, 255, 255, 0.96);
    box-shadow:
      0 12px 22px rgba(201, 111, 40, 0.16),
      inset 0 0 0 1px rgba(84, 96, 109, 0.08);
  }

  .site-header__mark img {
    width: 100%;
    height: 100%;
    display: block;
    object-fit: contain;
  }

  .site-header__brand-copy {
    display: grid;
    min-width: 0;
  }

  .site-header__brand-copy strong {
    font-size: 1rem;
    line-height: 1.1;
  }

  .site-header__brand-copy small {
    color: var(--color-text-muted);
    font-size: 0.8rem;
  }

  .site-header__nav {
    display: flex;
    align-items: center;
    gap: 1.2rem;
  }

  .site-header__link {
    position: relative;
    color: var(--color-text-muted);
    font-size: 0.92rem;
    font-weight: 600;
  }

  .site-header__link::after {
    content: "";
    position: absolute;
    left: 0;
    right: 0;
    bottom: -0.55rem;
    height: 2px;
    border-radius: 999px;
    background: var(--color-primary);
    opacity: 0;
    transform: scaleX(0.5);
    transition:
      opacity 160ms ease,
      transform 160ms ease;
  }

  .site-header__link:hover,
  .site-header__link.is-active {
    color: var(--color-text);
  }

  .site-header__link:hover::after,
  .site-header__link.is-active::after {
    opacity: 1;
    transform: scaleX(1);
  }

  .site-header__cta {
    display: inline-flex;
    align-items: center;
    border-radius: 999px;
    padding: 0.8rem 1.1rem;
    background: var(--color-primary);
    color: white;
    font-size: 0.86rem;
    font-weight: 700;
    box-shadow: 0 14px 24px rgba(25, 77, 128, 0.22);
  }

  @media (max-width: 920px) {
    .site-header__notice-inner {
      flex-direction: column;
    }

    .site-header__bar {
      flex-wrap: wrap;
      padding-block: 0.8rem;
    }

    .site-header__nav {
      order: 3;
      width: 100%;
      justify-content: space-between;
      overflow-x: auto;
      padding-bottom: 0.3rem;
    }
  }

  @media (max-width: 640px) {
    .site-header__mark {
      width: 3rem;
      height: 3rem;
      flex-basis: 3rem;
    }

    .site-header__cta {
      width: 100%;
      justify-content: center;
    }
  }
</style>
