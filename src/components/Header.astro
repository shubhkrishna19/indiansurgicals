---
import { business } from "../data/business";
import { getAllCategories } from "../data/catalogue";

const currentPath = Astro.url.pathname;
const categories = getAllCategories();
const contactSummary = `Call ${business.contact.phones[0]} | Email ${business.contact.email}`;

const catalogueMenu = [
  {
    href: "/products",
    label: "Browse full catalogue",
    note: `${categories.length} core product sections`,
  },
  ...categories.map((category) => ({
    href: `/products/${category.slug}`,
    label: category.name,
    note: `${category.familyCount} families`,
  })),
  {
    href: "/catalogue-preview",
    label: "Catalogue preview and download",
    note: "Preview page and workbook export",
  },
];

const aboutMenu = [
  {
    href: "/about",
    label: "About the manufacturer",
    note: `${business.experienceClaim} manufacturing background`,
  },
  {
    href: "/get-quote",
    label: "Get quote and contact",
    note: "Fast WhatsApp, call, and email options",
  },
  {
    href: "/contact",
    label: "Contact and enquiry desk",
    note: "Works address, phones, and email contacts",
  },
  {
    href: "/catalogue-preview",
    label: "Public catalogue preview",
    note: "Shareable product overview for circulation",
  },
];

function isActive(href: string) {
  if (href === "/") {
    return currentPath === "/";
  }
  return currentPath.startsWith(href);
}

const isCatalogueActive = currentPath.startsWith("/products") || currentPath.startsWith("/catalogue-preview");
const isAboutActive = currentPath.startsWith("/about");
---

<header class="site-header">
  <div class="site-header__notice">
    <div class="container site-header__notice-inner">
      <span>{business.experienceClaim} manufacturing legacy</span>
      <span>{contactSummary}</span>
    </div>
  </div>

  <div class="container site-header__bar">
    <a href="/" class="site-header__brand">
      <span class="site-header__mark">
        <img src="/life-equip-logo.png" alt={`${business.brandMark} logo`} />
      </span>
      <span class="site-header__brand-copy">
        <strong>{business.brand}</strong>
        <small>{business.tagline}</small>
      </span>
    </a>

    <nav class="site-header__nav" aria-label="Primary">
      <a href="/" class:list={["site-header__link", { "is-active": isActive("/") }]}>
        Home
      </a>

      <details class:list={["site-header__menu", { "is-active": isCatalogueActive }]}>
        <summary class="site-header__summary">
          Catalogue
          <span class="site-header__chevron" aria-hidden="true"></span>
        </summary>

        <div class="site-header__dropdown site-header__dropdown--catalogue">
          <div class="site-header__dropdown-grid site-header__dropdown-grid--catalogue">
            {catalogueMenu.map((item) => (
              <a href={item.href} class="site-header__dropdown-link">
                <strong>{item.label}</strong>
                <small>{item.note}</small>
              </a>
            ))}
          </div>
        </div>
      </details>

      <details class:list={["site-header__menu", { "is-active": isAboutActive }]}>
        <summary class="site-header__summary">
          About
          <span class="site-header__chevron" aria-hidden="true"></span>
        </summary>

        <div class="site-header__dropdown">
          <div class="site-header__dropdown-grid">
            {aboutMenu.map((item) => (
              <a href={item.href} class="site-header__dropdown-link">
                <strong>{item.label}</strong>
                <small>{item.note}</small>
              </a>
            ))}
          </div>
        </div>
      </details>

      <a href="/contact" class:list={["site-header__link", { "is-active": isActive("/contact") }]}>
        Contact
      </a>
    </nav>

      <a href="/get-quote" class="site-header__cta">
        <span class="site-header__cta-kicker">Quote-only support</span>
        <strong>Get Quote</strong>
      </a>
  </div>
</header>

<style>
  .site-header {
    position: sticky;
    top: 0;
    z-index: 50;
    backdrop-filter: blur(16px);
    background: rgba(245, 248, 250, 0.92);
    border-bottom: 1px solid rgba(84, 96, 109, 0.14);
  }

  .site-header__notice {
    border-bottom: 1px solid rgba(84, 96, 109, 0.1);
    background: linear-gradient(90deg, rgba(11, 27, 43, 0.98), rgba(25, 77, 128, 0.92));
    color: rgba(255, 255, 255, 0.88);
    font-size: 0.78rem;
  }

  .site-header__notice-inner {
    display: flex;
    justify-content: space-between;
    gap: 1rem;
    padding-block: 0.55rem;
  }

  .site-header__bar {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1.5rem;
    min-height: 5.2rem;
  }

  .site-header__brand {
    display: flex;
    align-items: center;
    gap: 0.95rem;
    min-width: 0;
  }

  .site-header__mark {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 3.55rem;
    height: 3.55rem;
    flex: 0 0 3.55rem;
    border-radius: 1rem;
    padding: 0.18rem;
    background: rgba(255, 255, 255, 0.96);
    box-shadow:
      0 12px 22px rgba(201, 111, 40, 0.16),
      inset 0 0 0 1px rgba(84, 96, 109, 0.08);
  }

  .site-header__mark img {
    width: 100%;
    height: 100%;
    display: block;
    object-fit: contain;
  }

  .site-header__brand-copy {
    display: grid;
    min-width: 0;
  }

  .site-header__brand-copy strong {
    font-size: 1rem;
    line-height: 1.1;
  }

  .site-header__brand-copy small {
    color: var(--color-text-muted);
    font-size: 0.8rem;
    max-width: 28rem;
  }

  .site-header__nav {
    display: flex;
    align-items: center;
    gap: 1.2rem;
  }

  .site-header__menu {
    position: relative;
  }

  .site-header__summary,
  .site-header__link {
    position: relative;
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    color: var(--color-text-muted);
    font-size: 0.92rem;
    font-weight: 600;
  }

  .site-header__summary {
    cursor: pointer;
    list-style: none;
  }

  .site-header__summary::-webkit-details-marker {
    display: none;
  }

  .site-header__summary::after,
  .site-header__link::after {
    content: "";
    position: absolute;
    left: 0;
    right: 0;
    bottom: -0.55rem;
    height: 2px;
    border-radius: 999px;
    background: var(--color-primary);
    opacity: 0;
    transform: scaleX(0.5);
    transition:
      opacity 160ms ease,
      transform 160ms ease;
  }

  .site-header__chevron {
    width: 0.5rem;
    height: 0.5rem;
    border-right: 1.7px solid currentColor;
    border-bottom: 1.7px solid currentColor;
    transform: rotate(45deg) translateY(-1px);
    transition: transform 180ms ease;
  }

  .site-header__link:hover,
  .site-header__summary:hover,
  .site-header__link.is-active {
    color: var(--color-text);
  }

  .site-header__link:hover::after,
  .site-header__summary:hover::after,
  .site-header__link.is-active::after,
  .site-header__menu.is-active > .site-header__summary::after,
  .site-header__menu[open] > .site-header__summary::after {
    opacity: 1;
    transform: scaleX(1);
  }

  .site-header__menu.is-active > .site-header__summary,
  .site-header__menu[open] > .site-header__summary {
    color: var(--color-text);
  }

  .site-header__menu[open] > .site-header__summary .site-header__chevron,
  .site-header__menu:hover > .site-header__summary .site-header__chevron,
  .site-header__menu:focus-within > .site-header__summary .site-header__chevron {
    transform: rotate(225deg) translateY(1px);
  }

  .site-header__dropdown {
    position: absolute;
    top: calc(100% + 1rem);
    left: 50%;
    width: min(24rem, calc(100vw - 2rem));
    padding: 0.95rem;
    border: 1px solid rgba(84, 96, 109, 0.14);
    border-radius: 1.1rem;
    background:
      linear-gradient(180deg, rgba(255, 255, 255, 0.99), rgba(245, 248, 250, 0.98));
    box-shadow: 0 22px 42px rgba(11, 27, 43, 0.16);
    opacity: 0;
    visibility: hidden;
    pointer-events: none;
    transform: translate(-50%, -0.35rem);
    transition:
      opacity 180ms ease,
      transform 180ms ease,
      visibility 180ms ease;
  }

  .site-header__dropdown--catalogue {
    width: min(44rem, calc(100vw - 2rem));
  }

  .site-header__dropdown-grid {
    display: grid;
    gap: 0.6rem;
  }

  .site-header__dropdown-grid--catalogue {
    grid-template-columns: repeat(2, minmax(0, 1fr));
  }

  .site-header__dropdown-link {
    display: grid;
    gap: 0.2rem;
    padding: 0.8rem 0.9rem;
    border-radius: 0.9rem;
    border: 1px solid transparent;
    background: rgba(25, 77, 128, 0.03);
    transition:
      border-color 160ms ease,
      background 160ms ease,
      transform 160ms ease;
  }

  .site-header__dropdown-link:hover,
  .site-header__dropdown-link:focus-visible {
    border-color: rgba(25, 77, 128, 0.16);
    background: rgba(25, 77, 128, 0.08);
    transform: translateY(-2px);
  }

  .site-header__dropdown-link strong {
    font-size: 0.88rem;
    line-height: 1.3;
  }

  .site-header__dropdown-link small {
    color: var(--color-text-muted);
    font-size: 0.76rem;
    line-height: 1.45;
  }

  .site-header__menu:hover .site-header__dropdown,
  .site-header__menu:focus-within .site-header__dropdown,
  .site-header__menu[open] .site-header__dropdown {
    opacity: 1;
    visibility: visible;
    pointer-events: auto;
    transform: translate(-50%, 0);
  }

  .site-header__cta {
    display: grid;
    gap: 0.12rem;
    border-radius: 1.05rem;
    padding: 0.72rem 1rem 0.78rem;
    background:
      linear-gradient(135deg, rgba(25, 77, 128, 1), rgba(14, 52, 90, 0.96)),
      var(--color-primary);
    color: white;
    box-shadow:
      0 14px 24px rgba(25, 77, 128, 0.22),
      inset 0 0 0 1px rgba(255, 255, 255, 0.1);
    text-align: left;
  }

  .site-header__cta-kicker {
    font-size: 0.66rem;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: rgba(255, 255, 255, 0.72);
  }

  .site-header__cta strong {
    font-size: 1rem;
    line-height: 1;
  }

  @media (max-width: 920px) {
    .site-header__notice-inner {
      flex-direction: column;
    }

    .site-header__bar {
      flex-wrap: wrap;
      padding-block: 0.8rem;
    }

    .site-header__nav {
      order: 3;
      width: 100%;
      display: grid;
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: 0.8rem;
    }

    .site-header__brand-copy small {
      max-width: none;
    }

    .site-header__menu {
      min-width: 0;
    }

    .site-header__summary,
    .site-header__link {
      justify-content: space-between;
      width: 100%;
      padding: 0.82rem 0.95rem;
      border: 1px solid rgba(84, 96, 109, 0.14);
      border-radius: 0.95rem;
      background: rgba(255, 255, 255, 0.9);
    }

    .site-header__summary::after,
    .site-header__link::after {
      display: none;
    }

    .site-header__link.is-active,
    .site-header__menu.is-active > .site-header__summary {
      border-color: rgba(25, 77, 128, 0.24);
      background: rgba(25, 77, 128, 0.08);
    }

    .site-header__dropdown,
    .site-header__dropdown--catalogue {
      position: static;
      width: 100%;
      margin-top: 0.55rem;
      padding: 0.75rem;
      opacity: 1;
      visibility: visible;
      pointer-events: auto;
      transform: none;
      display: none;
      box-shadow: none;
    }

    .site-header__menu[open] .site-header__dropdown {
      display: block;
    }

    .site-header__dropdown-grid--catalogue {
      grid-template-columns: 1fr;
    }
  }

  @media (max-width: 640px) {
    .site-header__mark {
      width: 3rem;
      height: 3rem;
      flex-basis: 3rem;
    }

    .site-header__cta {
      width: 100%;
      text-align: center;
    }

    .site-header__nav {
      grid-template-columns: 1fr;
    }
  }
</style>
