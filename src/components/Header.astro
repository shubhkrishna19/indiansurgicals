---
import { business } from "../data/business";
import { getAllCategories, getAllFamilies, getCatalogueExports } from "../data/catalogue";

const currentPath = Astro.url.pathname;
const categories = getAllCategories();
const families = getAllFamilies();
const catalogueExports = getCatalogueExports();
const contactSummary = `Call ${business.contact.phones[0]} | Email ${business.contact.email}`;
const categoryNameBySlug = new Map(categories.map((category) => [category.slug, category.name]));

const catalogueMenu = [
  {
    href: "/products",
    label: "Full product catalogue",
    note: `${categories.length} major product categories`,
  },
  ...categories.map((category) => ({
    href: `/products/${category.slug}`,
    label: category.name,
    note: `${category.familyCount} product families`,
  })),
  {
    href: catalogueExports.workbookPath,
    label: "Download official catalogue PDF",
    note: "Direct download of the approved company catalogue",
    download: true,
  },
];

const aboutMenu = [
  {
    href: "/about",
    label: "About the manufacturer",
    note: `${business.experienceClaim} of manufacturing experience`,
  },
  {
    href: "/get-quote",
    label: "Get quotation support",
    note: "WhatsApp, phone, and email enquiry options",
  },
  {
    href: "/contact",
    label: "Contact and enquiry desk",
    note: "Published phone, WhatsApp, email, and enquiry details",
  },
  {
    href: catalogueExports.workbookPath,
    label: "Download official catalogue PDF",
    note: "Direct PDF download for offline reference",
    download: true,
  },
];

const siteSearchItems = [
  {
    href: "/",
    label: "Home",
    note: "Company overview and featured product range",
    type: "Page",
    keywords: ["home", "homepage", "overview", business.brand],
  },
  {
    href: "/products",
    label: "Full Product Catalogue",
    note: "Browse the complete product range",
    type: "Page",
    keywords: ["catalogue", "catalog", "products", "range", "all products"],
  },
  {
    href: "/about",
    label: "About Indian Surgical Industries",
    note: "Manufacturer profile and company overview",
    type: "Page",
    keywords: ["about", "company", "profile", "manufacturer"],
  },
  {
    href: "/contact",
    label: "Contact",
    note: "Direct contact details and enquiry options",
    type: "Page",
    keywords: ["contact", "email", "phone", "whatsapp"],
  },
  {
    href: "/get-quote",
    label: "Get Quote",
    note: "Quotation support for model selection and quantities",
    type: "Page",
    keywords: ["quote", "quotation", "enquiry", "pricing"],
  },
  ...categories.map((category) => ({
    href: `/products/${category.slug}`,
    label: category.name,
    note: `${category.familyCount} product families`,
    type: "Category",
    keywords: [category.name, category.summary, category.intro],
  })),
  ...families.map((family) => ({
    href: `/products/${family.categorySlug}/${family.slug}`,
    label: family.name,
    note: categoryNameBySlug.get(family.categorySlug) ?? "Product family",
    type: "Product",
    keywords: [
      family.name,
      family.summary,
      family.description,
      family.subheading,
      ...(family.highlights ?? []),
      ...(family.notes ?? []),
    ],
  })),
];
const siteSearchItemsJson = JSON.stringify(siteSearchItems);

function isActive(href: string) {
  if (href === "/") {
    return currentPath === "/";
  }
  return currentPath.startsWith(href);
}

const isCatalogueActive = currentPath.startsWith("/products");
const isAboutActive = currentPath.startsWith("/about");
---

<header class="site-header">
  <div class="site-header__notice">
    <div class="container site-header__notice-inner">
      <span>{business.experienceClaim} manufacturing legacy</span>
      <span>{contactSummary}</span>
    </div>
  </div>

  <div class="container site-header__bar">
    <a href="/" class="site-header__brand">
      <span class="site-header__mark">
        <img src="/life-equip-logo.png" alt={`${business.brandMark} logo`} />
      </span>
      <span class="site-header__brand-copy">
        <strong>{business.brand}</strong>
        <small>{business.tagline}</small>
      </span>
    </a>

    <nav class="site-header__nav" aria-label="Primary" id="primary-navigation" data-mobile-nav>
      <div class="site-header__mobile-search">
        <label class="site-header__search-field site-header__search-field--mobile">
          <span class="site-header__search-field-label">Search the website</span>
          <input
            type="search"
            placeholder="Search products, categories, or pages"
            autocomplete="off"
            data-mobile-site-search-input
          />
        </label>
        <div
          class="site-header__search-results site-header__search-results--mobile"
          data-mobile-site-search-results
          hidden
        ></div>
      </div>

      <a href="/" class:list={["site-header__link", { "is-active": isActive("/") }]}>
        Home
      </a>

      <details class:list={["site-header__menu", { "is-active": isCatalogueActive }]} data-nav-menu>
        <summary class="site-header__summary" data-nav-summary>
          Catalogue
          <span class="site-header__chevron" aria-hidden="true"></span>
        </summary>

        <div class="site-header__dropdown site-header__dropdown--catalogue">
          <div class="site-header__dropdown-grid site-header__dropdown-grid--catalogue">
            {catalogueMenu.map((item) => (
              <a href={item.href} class="site-header__dropdown-link" download={item.download ? true : undefined}>
                <strong>{item.label}</strong>
                <small>{item.note}</small>
              </a>
            ))}
          </div>
        </div>
      </details>

      <details class:list={["site-header__menu", { "is-active": isAboutActive }]} data-nav-menu>
        <summary class="site-header__summary" data-nav-summary>
          About
          <span class="site-header__chevron" aria-hidden="true"></span>
        </summary>

        <div class="site-header__dropdown">
          <div class="site-header__dropdown-grid">
            {aboutMenu.map((item) => (
              <a href={item.href} class="site-header__dropdown-link" download={item.download ? true : undefined}>
                <strong>{item.label}</strong>
                <small>{item.note}</small>
              </a>
            ))}
          </div>
        </div>
      </details>

      <a href="/contact" class:list={["site-header__link", { "is-active": isActive("/contact") }]}>
        Contact
      </a>

      <a href="/get-quote" class="site-header__cta site-header__cta--mobile">
        <strong>Get Quote</strong>
      </a>
    </nav>

    <div class="site-header__actions">
      <div class="site-header__search" data-site-search>
        <button
          class="site-header__search-toggle"
          type="button"
          aria-expanded="false"
          aria-controls="site-header-search-panel"
          data-site-search-toggle
        >
          <span class="site-header__search-icon" aria-hidden="true"></span>
          <span class="site-header__search-label">Search site</span>
        </button>

        <div
          class="site-header__search-panel"
          id="site-header-search-panel"
          hidden
          data-site-search-panel
        >
          <label class="site-header__search-field">
            <span class="site-header__search-field-label">Search the website</span>
            <input
              type="search"
              placeholder="Search products, categories, pages"
              autocomplete="off"
              data-site-search-input
            />
          </label>
          <div class="site-header__search-results" data-site-search-results></div>
        </div>
      </div>

      <a href="/get-quote" class="site-header__cta">
        <span class="site-header__cta-kicker">Quick enquiry support</span>
        <strong>Get Quote</strong>
      </a>

      <button
        class="site-header__toggle"
        type="button"
        aria-expanded="false"
        aria-controls="primary-navigation"
        data-mobile-nav-toggle
      >
        <span class="site-header__toggle-lines" aria-hidden="true"></span>
        <span class="site-header__toggle-label">Menu</span>
      </button>
    </div>
  </div>
</header>

<script
  is:inline
  type="application/json"
  id="site-header-search-data"
  set:html={siteSearchItemsJson}
></script>

<script>
  (() => {
    type SearchItem = {
      href: string;
      label: string;
      note: string;
      type: string;
      keywords?: string[];
    };

    const win = window as Window & {
      __isiHeaderCleanup?: () => void;
      __isiHeaderPageLoadBound?: boolean;
    };

    const setupHeader = () => {
      win.__isiHeaderCleanup?.();

      const header = document.querySelector(".site-header");
      if (!(header instanceof HTMLElement)) return;

      const desktopNav = window.matchMedia("(min-width: 1041px)");
      const mobileNav = window.matchMedia("(max-width: 1040px)");
      const mobileNavElement = header.querySelector<HTMLElement>("[data-mobile-nav]");
      const mobileToggle = header.querySelector<HTMLButtonElement>("[data-mobile-nav-toggle]");
      const navLinks = Array.from(header.querySelectorAll<HTMLAnchorElement>(".site-header__nav a"));
      const menus = Array.from(header.querySelectorAll<HTMLDetailsElement>("[data-nav-menu]"));
      const closeTimers = new WeakMap<HTMLDetailsElement, number>();
      const searchRoot = header.querySelector<HTMLElement>("[data-site-search]");
      const searchToggle = header.querySelector<HTMLButtonElement>("[data-site-search-toggle]");
      const searchPanel = header.querySelector<HTMLElement>("[data-site-search-panel]");
      const searchInput = header.querySelector<HTMLInputElement>("[data-site-search-input]");
      const searchResults = header.querySelector<HTMLElement>("[data-site-search-results]");
      const mobileSearchInput = header.querySelector<HTMLInputElement>("[data-mobile-site-search-input]");
      const mobileSearchResults = header.querySelector<HTMLElement>("[data-mobile-site-search-results]");
      const searchDataNode = document.getElementById("site-header-search-data");
      const searchItems: SearchItem[] = searchDataNode?.textContent
        ? (JSON.parse(searchDataNode.textContent) as SearchItem[])
        : [];

      if (
        !(mobileNavElement instanceof HTMLElement) ||
        !(mobileToggle instanceof HTMLButtonElement) ||
        !(searchToggle instanceof HTMLButtonElement) ||
        !(searchPanel instanceof HTMLElement)
      ) {
        return;
      }

      const cleanupFns: Array<() => void> = [];

      const isMenuToggleVisible = () =>
        window.getComputedStyle(mobileToggle).display !== "none";

      const rankSearchItem = (item: SearchItem, query: string) => {
        const label = String(item.label ?? "").toLowerCase();
        const note = String(item.note ?? "").toLowerCase();
        const keywords = Array.isArray(item.keywords) ? item.keywords.join(" ").toLowerCase() : "";

        if (label === query) return 0;
        if (label.startsWith(query)) return 1;
        if (label.includes(query)) return 2;
        if (keywords.includes(query)) return 3;
        if (note.includes(query)) return 4;
        return 5;
      };

      const renderSearchResults = (target: HTMLElement | null, query = "") => {
        if (!(target instanceof HTMLElement)) return;

        const normalizedQuery = query.trim().toLowerCase();
        target.hidden = !normalizedQuery;

        if (!normalizedQuery) {
          target.replaceChildren();
          return;
        }

        const results = searchItems
          .filter((item: SearchItem) => {
            const haystack = [
              item.label,
              item.note,
              item.type,
              ...(Array.isArray(item.keywords) ? item.keywords : []),
            ]
              .join(" ")
              .toLowerCase();

            return haystack.includes(normalizedQuery);
          })
          .sort(
            (left: SearchItem, right: SearchItem) =>
              rankSearchItem(left, normalizedQuery) - rankSearchItem(right, normalizedQuery),
          )
          .slice(0, 8);

        target.replaceChildren();

        const headerRow = document.createElement("div");
        headerRow.className = "site-header__search-results-head";
        const title = document.createElement("strong");
        title.textContent = results.length
          ? `${results.length} result${results.length === 1 ? "" : "s"} found`
          : "No results found";
        const hint = document.createElement("span");
        hint.textContent = results.length
          ? "Choose a page, category, or product family."
          : "Try a broader product name or a company page.";
        headerRow.append(title, hint);
        target.appendChild(headerRow);

        if (!results.length) {
          const empty = document.createElement("p");
          empty.className = "site-header__search-empty";
          empty.textContent = "No matching pages or products found.";
          target.appendChild(empty);
          return;
        }

        const list = document.createElement("div");
        list.className = "site-header__search-list";

        results.forEach((item: SearchItem) => {
          const link = document.createElement("a");
          link.href = item.href;
          link.className = "site-header__search-result";

          const body = document.createElement("div");
          body.className = "site-header__search-result-body";

          const label = document.createElement("strong");
          label.className = "site-header__search-result-title";
          label.textContent = item.label;

          const note = document.createElement("span");
          note.className = "site-header__search-result-note";
          note.textContent = item.note;

          body.append(label, note);
          link.append(body);
          list.appendChild(link);
        });

        target.appendChild(list);
      };

      const closeMenus = (except?: HTMLDetailsElement | null) => {
        menus.forEach((menu) => {
          if (menu === except) return;
          const timer = closeTimers.get(menu);
          if (timer) {
            window.clearTimeout(timer);
            closeTimers.delete(menu);
          }
          menu.removeAttribute("open");
        });
      };

      const setMobileMenuState = (open: boolean) => {
        const isCompactMenuView = mobileNav.matches || isMenuToggleVisible();
        mobileNavElement.classList.toggle("is-open", open && isCompactMenuView);
        mobileNavElement.hidden = isCompactMenuView ? !open : false;
        mobileToggle.setAttribute("aria-expanded", String(open));
        header.classList.toggle("is-mobile-open", open);
        document.body.classList.toggle("mobile-nav-open", open);

        if (!open) {
          menus.forEach((menu) => menu.removeAttribute("open"));
          if (mobileSearchInput instanceof HTMLInputElement) {
            mobileSearchInput.value = "";
          }
          renderSearchResults(mobileSearchResults, "");
        }
      };

      const setSearchOpen = (open: boolean) => {
        searchToggle.setAttribute("aria-expanded", String(open));
        searchRoot?.classList.toggle("is-open", open);
        searchPanel.hidden = !open;

        if (open) {
          closeMenus();
          renderSearchResults(searchResults, searchInput?.value ?? "");
          window.requestAnimationFrame(() => searchInput?.focus());
        }
      };

      const scheduleClose = (menu: HTMLDetailsElement) => {
        const timer = closeTimers.get(menu);
        if (timer) {
          window.clearTimeout(timer);
        }

        closeTimers.set(
          menu,
          window.setTimeout(() => {
            menu.removeAttribute("open");
            closeTimers.delete(menu);
          }, 220),
        );
      };

      menus.forEach((menu) => {
        const summary = menu.querySelector<HTMLElement>("[data-nav-summary]");
        if (!(summary instanceof HTMLElement)) return;

        const onPointerEnter = () => {
          if (!desktopNav.matches) return;
          closeMenus(menu);
          setSearchOpen(false);
          menu.setAttribute("open", "");
        };

        const onPointerLeave = () => {
          if (!desktopNav.matches) return;
          scheduleClose(menu);
        };

        const onFocusIn = () => {
          if (!desktopNav.matches) return;
          closeMenus(menu);
          setSearchOpen(false);
          menu.setAttribute("open", "");
        };

        const onFocusOut = (event: FocusEvent) => {
          if (!desktopNav.matches) return;
          const nextTarget = event.relatedTarget;
          if (nextTarget instanceof Node && menu.contains(nextTarget)) return;
          scheduleClose(menu);
        };

        const onSummaryClick = (event: MouseEvent) => {
          if (!desktopNav.matches) return;
          event.preventDefault();
          const willOpen = !menu.hasAttribute("open");
          closeMenus(menu);
          setSearchOpen(false);
          if (willOpen) {
            menu.setAttribute("open", "");
          } else {
            menu.removeAttribute("open");
          }
        };

        menu.addEventListener("pointerenter", onPointerEnter);
        menu.addEventListener("pointerleave", onPointerLeave);
        menu.addEventListener("focusin", onFocusIn);
        menu.addEventListener("focusout", onFocusOut);
        summary.addEventListener("click", onSummaryClick);

        cleanupFns.push(() => {
          menu.removeEventListener("pointerenter", onPointerEnter);
          menu.removeEventListener("pointerleave", onPointerLeave);
          menu.removeEventListener("focusin", onFocusIn);
          menu.removeEventListener("focusout", onFocusOut);
          summary.removeEventListener("click", onSummaryClick);
        });
      });

      const onMobileToggleClick = () => {
        if (!isMenuToggleVisible()) return;
        setSearchOpen(false);
        setMobileMenuState(!mobileNavElement.classList.contains("is-open"));
      };

      mobileToggle.addEventListener("click", onMobileToggleClick);
      cleanupFns.push(() => mobileToggle.removeEventListener("click", onMobileToggleClick));

      navLinks.forEach((link) => {
        const onNavLinkClick = () => {
          if (mobileNav.matches) {
            setMobileMenuState(false);
          }
          setSearchOpen(false);
        };

        link.addEventListener("click", onNavLinkClick);
        cleanupFns.push(() => link.removeEventListener("click", onNavLinkClick));
      });

      const onSearchToggleClick = () => {
        const isExpanded = searchToggle.getAttribute("aria-expanded") === "true";
        if (!isExpanded) {
          setMobileMenuState(false);
        }
        setSearchOpen(!isExpanded);
      };

      searchToggle.addEventListener("click", onSearchToggleClick);
      cleanupFns.push(() => searchToggle.removeEventListener("click", onSearchToggleClick));

      const onSearchInput = () => {
        renderSearchResults(searchResults, searchInput?.value ?? "");
      };

      const onMobileSearchInput = () => {
        renderSearchResults(mobileSearchResults, mobileSearchInput?.value ?? "");
      };

      searchInput?.addEventListener("input", onSearchInput);
      mobileSearchInput?.addEventListener("input", onMobileSearchInput);
      cleanupFns.push(() => searchInput?.removeEventListener("input", onSearchInput));
      cleanupFns.push(() => mobileSearchInput?.removeEventListener("input", onMobileSearchInput));

      const onDocumentClick = (event: MouseEvent) => {
        const target = event.target;
        if (!(target instanceof Node)) return;

        if (searchRoot && !searchRoot.contains(target)) {
          setSearchOpen(false);
        }

        if (mobileNav.matches) {
          if (header.contains(target)) return;
          setMobileMenuState(false);
          return;
        }

        if (menus.some((menu) => menu.contains(target))) return;
        closeMenus();
      };

      document.addEventListener("click", onDocumentClick);
      cleanupFns.push(() => document.removeEventListener("click", onDocumentClick));

      const onDesktopChange = (event: MediaQueryListEvent) => {
        if (!event.matches) {
          closeMenus();
        }
      };

      const onMobileChange = (event: MediaQueryListEvent) => {
        if (!event.matches) {
          setMobileMenuState(false);
        } else {
          mobileNavElement.hidden = true;
        }
      };

      desktopNav.addEventListener("change", onDesktopChange);
      mobileNav.addEventListener("change", onMobileChange);
      cleanupFns.push(() => desktopNav.removeEventListener("change", onDesktopChange));
      cleanupFns.push(() => mobileNav.removeEventListener("change", onMobileChange));

      const onKeyDown = (event: KeyboardEvent) => {
        if (event.key === "Escape") {
          setSearchOpen(false);
          setMobileMenuState(false);
          closeMenus();
        }
      };

      document.addEventListener("keydown", onKeyDown);
      cleanupFns.push(() => document.removeEventListener("keydown", onKeyDown));

      renderSearchResults(searchResults, "");
      renderSearchResults(mobileSearchResults, "");
      mobileNavElement.hidden = mobileNav.matches || isMenuToggleVisible();

      win.__isiHeaderCleanup = () => {
        cleanupFns.forEach((cleanup) => cleanup());
        closeMenus();
        setSearchOpen(false);
        setMobileMenuState(false);
      };
    };

    if (!win.__isiHeaderPageLoadBound) {
      document.addEventListener("astro:page-load", setupHeader);
      document.addEventListener("astro:before-preparation", () => win.__isiHeaderCleanup?.());
      win.__isiHeaderPageLoadBound = true;
    }

    setupHeader();
  })();
</script>

<style>
  .site-header {
    position: sticky;
    top: 0;
    z-index: 50;
    overflow: visible;
    backdrop-filter: blur(16px);
    background: rgba(245, 248, 250, 0.92);
    border-bottom: 1px solid rgba(84, 96, 109, 0.14);
  }

  .site-header__notice {
    border-bottom: 1px solid rgba(84, 96, 109, 0.1);
    background: linear-gradient(90deg, rgba(11, 27, 43, 0.98), rgba(25, 77, 128, 0.92));
    color: rgba(255, 255, 255, 0.88);
    font-size: 0.78rem;
  }

  .site-header__notice-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    padding-block: 0.55rem;
  }

  .site-header__bar {
    display: grid;
    grid-template-columns: minmax(0, 1.45fr) minmax(0, 1fr) auto;
    align-items: center;
    gap: 0.95rem;
    min-height: 5.35rem;
    padding-block: 0.68rem;
  }

  .site-header__brand {
    display: flex;
    align-items: center;
    gap: 0.78rem;
    min-width: 0;
    max-width: 100%;
  }

  .site-header__mark {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 3.1rem;
    height: 3.1rem;
    flex: 0 0 3.1rem;
    border-radius: 0.9rem;
    padding: 0.16rem;
    background: rgba(255, 255, 255, 0.96);
    box-shadow:
      0 12px 22px rgba(201, 111, 40, 0.16),
      inset 0 0 0 1px rgba(84, 96, 109, 0.08);
  }

  .site-header__mark img {
    width: 100%;
    height: 100%;
    display: block;
    object-fit: contain;
  }

  .site-header__brand-copy {
    display: grid;
    min-width: 0;
    gap: 0.14rem;
  }

  .site-header__brand-copy strong {
    font-size: 0.94rem;
    line-height: 1.1;
  }

  .site-header__brand-copy small {
    color: var(--color-text-muted);
    font-size: 0.72rem;
    line-height: 1.34;
    max-width: min(29rem, 40vw);
  }

  .site-header__nav {
    display: flex;
    align-items: center;
    justify-content: flex-start;
    gap: 0.92rem;
    white-space: nowrap;
    min-width: 0;
    margin-left: 0;
    justify-self: start;
  }

  .site-header__actions {
    display: flex;
    align-items: center;
    gap: 0.58rem;
    position: relative;
    margin-left: 0;
    justify-self: end;
  }

  .site-header__search {
    position: relative;
  }

  .site-header__mobile-search {
    display: none;
  }

  .site-header__mobile-search-head {
    display: none;
  }

  .site-header__search-toggle {
    display: inline-flex;
    align-items: center;
    gap: 0.55rem;
    border: 1px solid rgba(84, 96, 109, 0.16);
    border-radius: 999px;
    justify-content: center;
    min-width: 8rem;
    height: 2.8rem;
    padding: 0 0.9rem;
    background: rgba(255, 255, 255, 0.9);
    color: var(--color-text);
    box-shadow: 0 10px 22px rgba(11, 27, 43, 0.06);
    font-size: 0.78rem;
    font-weight: 700;
    transition:
      border-color 160ms ease,
      background 160ms ease,
      transform 160ms ease;
  }

  .site-header__search-toggle:hover,
  .site-header__search-toggle:focus-visible,
  .site-header__search.is-open .site-header__search-toggle {
    border-color: rgba(25, 77, 128, 0.22);
    background: rgba(255, 255, 255, 0.98);
    transform: translateY(-1px);
  }

  .site-header__search-icon {
    position: relative;
    width: 0.9rem;
    height: 0.9rem;
    border: 2px solid currentColor;
    border-radius: 50%;
    display: inline-block;
  }

  .site-header__search-icon::after {
    content: "";
    position: absolute;
    right: -0.3rem;
    bottom: -0.28rem;
    width: 0.45rem;
    height: 2px;
    border-radius: 999px;
    background: currentColor;
    transform: rotate(45deg);
    transform-origin: right center;
  }

  .site-header__search-panel {
    position: absolute;
    top: calc(100% + 0.75rem);
    right: 0;
    width: min(34rem, calc(100vw - 2rem));
    padding: 1rem;
    border: 1px solid rgba(84, 96, 109, 0.14);
    border-radius: 1.2rem;
    background:
