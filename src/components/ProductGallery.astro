---
interface Props {
  images: string[];
  name: string;
}

const { images, name } = Astro.props;
const galleryImages = [...new Set(images.filter(Boolean))];
---

{galleryImages.length > 0 && (
  <div class="product-gallery" data-product-gallery>
    <div class="product-gallery__stage panel">
      <div class="product-gallery__stage-head">
        <span class="product-gallery__eyebrow">Approved Product Views</span>
        <span class="product-gallery__count">{galleryImages.length} image{galleryImages.length === 1 ? "" : "s"}</span>
      </div>

      <div class="product-gallery__stage-frame">
        <img
          src={galleryImages[0]}
          alt={name}
          loading="eager"
          decoding="async"
          data-gallery-image
        />
      </div>
    </div>

    {galleryImages.length > 1 && (
      <div class="product-gallery__thumbs" role="tablist" aria-label={`${name} image selector`}>
        {galleryImages.map((image, index) => (
          <button
            class:list={["product-gallery__thumb", { "is-active": index === 0 }]}
            type="button"
            role="tab"
            aria-selected={index === 0 ? "true" : "false"}
            data-gallery-thumb={image}
            data-gallery-alt={index === 0 ? `${name} primary view` : `${name} view ${index + 1}`}
          >
            <img src={image} alt={`${name} thumbnail ${index + 1}`} loading="lazy" decoding="async" />
          </button>
        ))}
      </div>
    )}
  </div>
)}

<script>
  const galleries = Array.from(document.querySelectorAll("[data-product-gallery]"));

  galleries.forEach((gallery) => {
    const stageImage = gallery.querySelector("[data-gallery-image]");
    const thumbs = Array.from(gallery.querySelectorAll("[data-gallery-thumb]"));

    if (!(stageImage instanceof HTMLImageElement) || thumbs.length === 0) {
      return;
    }

    thumbs.forEach((thumb) => {
      thumb.addEventListener("click", () => {
        const src = thumb.getAttribute("data-gallery-thumb");
        const alt = thumb.getAttribute("data-gallery-alt");

        if (!src) {
          return;
        }

        stageImage.src = src;
        if (alt) {
          stageImage.alt = alt;
        }

        thumbs.forEach((candidate) => {
          candidate.classList.remove("is-active");
          candidate.setAttribute("aria-selected", "false");
        });

        thumb.classList.add("is-active");
        thumb.setAttribute("aria-selected", "true");
      });
    });
  });
</script>

<style>
  .product-gallery {
    display: grid;
    gap: 1rem;
  }

  .product-gallery__stage {
    display: grid;
    gap: 1rem;
    padding: 1.1rem;
    background:
      radial-gradient(circle at top right, rgba(201, 111, 40, 0.1), transparent 28%),
      linear-gradient(180deg, rgba(255, 255, 255, 0.96), rgba(246, 248, 250, 0.94));
  }

  .product-gallery__stage-head {
    display: flex;
    justify-content: space-between;
    gap: 0.8rem;
    align-items: center;
  }

  .product-gallery__eyebrow {
    color: var(--color-primary);
    font-size: 0.75rem;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }

  .product-gallery__count {
    color: var(--color-text-muted);
    font-size: 0.86rem;
  }

  .product-gallery__stage-frame {
    display: grid;
    place-items: center;
    aspect-ratio: 4 / 3;
    border-radius: 1.2rem;
    background:
      linear-gradient(180deg, rgba(255, 255, 255, 0.98), rgba(243, 246, 248, 0.98)),
      repeating-linear-gradient(
        90deg,
        rgba(15, 28, 43, 0.02) 0,
        rgba(15, 28, 43, 0.02) 1px,
        transparent 1px,
        transparent 34px
      );
    overflow: hidden;
  }

  .product-gallery__stage-frame img {
    width: 100%;
    height: 100%;
    object-fit: contain;
    padding: clamp(0.9rem, 2vw, 1.5rem);
    transition: transform 220ms ease;
  }

  .product-gallery__stage-frame:hover img {
    transform: scale(1.04);
  }

  .product-gallery__thumbs {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(7rem, 1fr));
    gap: 0.75rem;
  }

  .product-gallery__thumb {
    display: grid;
    place-items: center;
    aspect-ratio: 5 / 4;
    border: 1px solid rgba(84, 96, 109, 0.16);
    border-radius: 1rem;
    padding: 0.45rem;
    background: rgba(255, 255, 255, 0.96);
    transition:
      border-color 180ms ease,
      box-shadow 180ms ease,
      transform 180ms ease;
  }

  .product-gallery__thumb img {
    width: 100%;
    height: 100%;
    object-fit: contain;
  }

  .product-gallery__thumb:hover,
  .product-gallery__thumb.is-active {
    border-color: rgba(25, 77, 128, 0.34);
    box-shadow: 0 10px 22px rgba(11, 27, 43, 0.08);
    transform: translateY(-2px);
  }

  @media (max-width: 720px) {
    .product-gallery__stage-head {
      flex-direction: column;
      align-items: flex-start;
    }

    .product-gallery__thumbs {
      grid-template-columns: repeat(3, minmax(0, 1fr));
    }
  }
</style>
