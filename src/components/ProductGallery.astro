---
interface Props {
  images: string[];
  name: string;
}

const { images, name } = Astro.props;
const galleryImages = [...new Set(images.filter(Boolean))];
---

{galleryImages.length > 0 && (
  <div
    class="product-gallery"
    data-product-gallery
    data-gallery-images={JSON.stringify(galleryImages)}
    data-gallery-name={name}
  >
    <div class="product-gallery__stage panel">
      <div class="product-gallery__stage-head">
        <span class="product-gallery__eyebrow">Approved Product Views</span>
        <span class="product-gallery__count" data-gallery-count>{galleryImages.length} image{galleryImages.length === 1 ? "" : "s"}</span>
      </div>

      <div class="product-gallery__stage-frame" data-gallery-frame>
        <img
          src={galleryImages[0]}
          alt={name}
          loading="eager"
          decoding="async"
          data-gallery-image
        />
      </div>
    </div>

    <div
      class:list={["product-gallery__thumbs", { "is-hidden": galleryImages.length <= 1 }]}
      role="tablist"
      aria-label={`${name} image selector`}
      data-gallery-thumbs
    >
      {galleryImages.length > 1 &&
        galleryImages.map((image, index) => (
          <button
            class:list={["product-gallery__thumb", { "is-active": index === 0 }]}
            type="button"
            role="tab"
            aria-selected={index === 0 ? "true" : "false"}
            data-gallery-thumb={image}
            data-gallery-alt={index === 0 ? `${name} primary view` : `${name} view ${index + 1}`}
          >
            <img src={image} alt={`${name} thumbnail ${index + 1}`} loading="lazy" decoding="async" />
          </button>
        ))}
    </div>
  </div>
)}

<script>
  const galleries = Array.from(document.querySelectorAll("[data-product-gallery]"));

  function bindThumbs(gallery: Element) {
    const stageImage = gallery.querySelector("[data-gallery-image]");
    const thumbs = Array.from(gallery.querySelectorAll<HTMLElement>("[data-gallery-thumb]"));

    if (!(stageImage instanceof HTMLImageElement)) {
      return;
    }

    thumbs.forEach((thumb) => {
      thumb.addEventListener("click", () => {
        const src = thumb.getAttribute("data-gallery-thumb");
        const alt = thumb.getAttribute("data-gallery-alt");

        if (!src) {
          return;
        }

        stageImage.src = src;
        if (alt) {
          stageImage.alt = alt;
        }

        thumbs.forEach((candidate) => {
          candidate.classList.remove("is-active");
          candidate.setAttribute("aria-selected", "false");
        });

        thumb.classList.add("is-active");
        thumb.setAttribute("aria-selected", "true");
      });
    });
  }

  function renderGallery(gallery: Element, images: string[], name: string) {
    const stageImage = gallery.querySelector("[data-gallery-image]");
    const thumbsContainer = gallery.querySelector("[data-gallery-thumbs]");
    const count = gallery.querySelector("[data-gallery-count]");

    if (
      !(stageImage instanceof HTMLImageElement) ||
      !(thumbsContainer instanceof HTMLElement) ||
      !(count instanceof HTMLElement)
    ) {
      return;
    }

    const uniqueImages = Array.from(
      new Set((Array.isArray(images) ? images : []).filter((image): image is string => typeof image === "string" && image.length > 0)),
    );
    if (uniqueImages.length === 0) {
      return;
    }

    stageImage.src = uniqueImages[0];
    stageImage.alt = name;
    count.textContent = `${uniqueImages.length} image${uniqueImages.length === 1 ? "" : "s"}`;

    thumbsContainer.innerHTML = "";
    if (uniqueImages.length <= 1) {
      thumbsContainer.classList.add("is-hidden");
      return;
    }

    thumbsContainer.classList.remove("is-hidden");
    uniqueImages.forEach((image: string, index) => {
      const button = document.createElement("button");
      button.type = "button";
      button.className = `product-gallery__thumb${index === 0 ? " is-active" : ""}`;
      button.setAttribute("role", "tab");
      button.setAttribute("aria-selected", index === 0 ? "true" : "false");
      button.setAttribute("data-gallery-thumb", image);
      button.setAttribute("data-gallery-alt", index === 0 ? `${name} primary view` : `${name} view ${index + 1}`);

      const imageElement = document.createElement("img");
      imageElement.src = image;
      imageElement.alt = `${name} thumbnail ${index + 1}`;
      imageElement.loading = "lazy";
      imageElement.decoding = "async";
      button.appendChild(imageElement);
      thumbsContainer.appendChild(button);
    });

    bindThumbs(gallery);
  }

  galleries.forEach((gallery) => {
    bindThumbs(gallery);
    gallery.addEventListener("gallery:update", (event: Event) => {
      const detail = event instanceof CustomEvent ? event.detail ?? {} : {};
      const images = Array.isArray(detail.images) ? detail.images : [];
      const name = typeof detail.name === "string" ? detail.name : gallery.getAttribute("data-gallery-name") ?? "";
      renderGallery(gallery, images, name);
    });
  });
</script>

<style>
  .product-gallery {
    display: grid;
    gap: 1rem;
  }

  .product-gallery__stage {
    display: grid;
    gap: 1rem;
    padding: 1.1rem;
    background:
      radial-gradient(circle at top right, rgba(201, 111, 40, 0.1), transparent 28%),
      linear-gradient(180deg, rgba(255, 255, 255, 0.96), rgba(246, 248, 250, 0.94));
  }

  .product-gallery__stage-head {
    display: flex;
    justify-content: space-between;
    gap: 0.8rem;
    align-items: center;
  }

  .product-gallery__eyebrow {
    color: var(--color-primary);
    font-size: 0.75rem;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }

  .product-gallery__count {
    color: var(--color-text-muted);
    font-size: 0.86rem;
  }

  .product-gallery__stage-frame {
    display: grid;
    place-items: center;
    aspect-ratio: 16 / 10;
    min-height: clamp(18rem, 42vw, 28rem);
    border-radius: 1.2rem;
    padding: clamp(1rem, 2vw, 1.6rem);
    background:
      linear-gradient(180deg, rgba(255, 255, 255, 0.98), rgba(243, 246, 248, 0.98)),
      repeating-linear-gradient(
        90deg,
        rgba(15, 28, 43, 0.02) 0,
        rgba(15, 28, 43, 0.02) 1px,
        transparent 1px,
        transparent 34px
      );
    overflow: hidden;
  }

  .product-gallery__stage-frame img {
    width: auto;
    height: auto;
    max-width: min(100%, 34rem);
    max-height: min(100%, 24rem);
    object-fit: contain;
    transition: transform 220ms ease;
  }

  .product-gallery__stage-frame:hover img {
    transform: scale(1.02);
  }

  .product-gallery__thumbs {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(7rem, 1fr));
    gap: 0.75rem;
  }

  .product-gallery__thumbs.is-hidden {
    display: none;
  }

  .product-gallery__thumb {
    display: grid;
    place-items: center;
    aspect-ratio: 5 / 4;
    border: 1px solid rgba(84, 96, 109, 0.16);
    border-radius: 1rem;
    padding: 0.45rem;
    background: rgba(255, 255, 255, 0.96);
    transition:
      border-color 180ms ease,
      box-shadow 180ms ease,
      transform 180ms ease;
  }

  .product-gallery__thumb img {
    width: 100%;
    height: 100%;
    object-fit: contain;
  }

  .product-gallery__thumb:hover,
  .product-gallery__thumb.is-active {
    border-color: rgba(25, 77, 128, 0.34);
    box-shadow: 0 10px 22px rgba(11, 27, 43, 0.08);
    transform: translateY(-2px);
  }

  @media (max-width: 720px) {
    .product-gallery__stage-frame {
      aspect-ratio: 4 / 3;
      min-height: 16rem;
    }

    .product-gallery__stage-frame img {
      max-width: 100%;
      max-height: 18rem;
    }

    .product-gallery__stage-head {
      flex-direction: column;
      align-items: flex-start;
    }

    .product-gallery__thumbs {
      grid-template-columns: repeat(3, minmax(0, 1fr));
    }
  }
</style>
