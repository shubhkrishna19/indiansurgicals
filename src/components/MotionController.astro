<script>
  let cleanupAnimations = () => {};

  const REDUCED_MOTION_QUERY = "(prefers-reduced-motion: reduce)";
  const REVEAL_SELECTORS = [
    ".category-card",
    ".showcase-card",
    ".family-card",
    ".category-tile",
    ".section-title",
    ".catalogue-download",
    ".catalogue-toolbar",
    ".contact-card",
    ".gallery-empty",
    ".leadership-card",
    ".matrix",
    ".preview-category",
    ".product-gallery",
    ".quote-card",
    ".quote-chip",
    ".quote-step",
    ".review-card",
    ".section-list",
    ".status-card",
    ".trust-shell",
    ".variant-panel",
    ".preview-category",
    ".catalogue-grid__item",
    ".subcategory-row span",
    ".site-footer__grid > section",
    ".site-footer__shipping",
  ];

  const HERO_GROUPS = [
    ".hero__content > *",
    ".about-hero__content > *",
    ".about-hero__panel > *",
    ".contact-hero__content > *",
    ".contact-hero__panel > *",
    ".quote-hero__content > *",
    ".quote-hero__panel > *",
    ".preview-hero__copy > *",
    ".preview-hero__aside > *",
    ".category-hero__copy > *",
    ".category-hero__stats > *",
    ".product-hero__content > *",
    ".product-hero__aside > *",
  ];

  function prefersReducedMotion() {
    return window.matchMedia(REDUCED_MOTION_QUERY).matches;
  }

  async function initMotion() {
    cleanupAnimations();

    if (prefersReducedMotion()) {
      document.documentElement.classList.remove("motion-ready");
      document.documentElement.classList.add("motion-reduced");
      return;
    }

    document.documentElement.classList.add("motion-ready");
    document.documentElement.classList.remove("motion-reduced");

    const [{ gsap }, { ScrollTrigger }] = await Promise.all([
      import("gsap"),
      import("gsap/ScrollTrigger"),
    ]);

    gsap.registerPlugin(ScrollTrigger);

    const context = gsap.context(() => {
      gsap.set("main", { opacity: 1 });

      HERO_GROUPS.forEach((selector) => {
        const nodes = gsap.utils.toArray<HTMLElement>(selector);
        if (!nodes.length) return;

        gsap.fromTo(
          nodes,
          { autoAlpha: 0, y: 28 },
          {
            autoAlpha: 1,
            y: 0,
            duration: 0.9,
            ease: "power3.out",
            stagger: 0.09,
            clearProps: "opacity,visibility,transform",
          },
        );
      });

      const revealNodes = Array.from(
        new Set(REVEAL_SELECTORS.flatMap((selector) => gsap.utils.toArray<HTMLElement>(selector))),
      );

      if (revealNodes.length > 0) {
        gsap.set(revealNodes, { autoAlpha: 0, y: 28 });
        ScrollTrigger.batch(revealNodes, {
          start: "top 90%",
          once: true,
          onEnter: (batch) => {
            gsap.to(batch, {
              autoAlpha: 1,
              y: 0,
              duration: 0.72,
              ease: "power2.out",
              stagger: 0.07,
              overwrite: true,
              clearProps: "opacity,visibility,transform",
            });
          },
        });
      }

      gsap.utils.toArray<HTMLElement>("[data-parallax-group]").forEach((group) => {
        const items = Array.from(group.querySelectorAll<HTMLElement>("[data-parallax-speed]"));
        items.forEach((item) => {
          const speed = Number(item.getAttribute("data-parallax-speed") ?? "0.1");
          gsap.to(item, {
            yPercent: speed * -60,
            ease: "none",
            scrollTrigger: {
              trigger: group,
              start: "top bottom",
              end: "bottom top",
              scrub: 0.35,
            },
          });
        });
      });
    }, document.body);

    cleanupAnimations = () => {
      context.revert();
      ScrollTrigger.getAll().forEach((trigger) => trigger.kill());
    };
  }

  const scheduleInit = () => {
    window.requestAnimationFrame(() => {
      window.requestAnimationFrame(() => {
        initMotion().catch((error) => {
          console.warn("Motion initialization skipped:", error);
        });
      });
    });
  };

  if (document.readyState === "loading") {
    document.addEventListener("DOMContentLoaded", scheduleInit, { once: true });
  } else {
    scheduleInit();
  }

  document.addEventListener("astro:page-load", scheduleInit);
  document.addEventListener("astro:before-preparation", () => cleanupAnimations());
</script>
