<!-- MotionController - GSAP ScrollTrigger + Lenis Smooth Scroll -->
<script>
  import { gsap } from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';

  // Register GSAP plugins
  gsap.registerPlugin(ScrollTrigger);

  let lenis: any = null;
  let isReducedMotion = false;

  // Initialize Lenis smooth scroll
  function initLenis() {
    // Check for reduced motion preference
    isReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

    if (isReducedMotion) {
      console.log('Reduced motion detected, skipping Lenis initialization');
      return;
    }

    // Dynamic import for Lenis (client-side only)
    import('lenis').then((LenisModule) => {
      const Lenis = LenisModule.default || LenisModule;

      lenis = new Lenis({
        duration: 1.2,
        easing: (t: number) => Math.min(1, 1.001 - Math.pow(2, -10 * t)),
        orientation: 'vertical',
        gestureOrientation: 'vertical',
        smoothWheel: true,
        wheelMultiplier: 1,
        touchMultiplier: 2,
        infinite: false,
      });

      // Integrate Lenis with GSAP ScrollTrigger
      lenis.on('scroll', ScrollTrigger.update);

      gsap.ticker.add((time) => {
        lenis.raf(time * 1000);
      });

      gsap.ticker.lagSmoothing(0);
    }).catch((err) => {
      console.warn('Lenis not available:', err);
    });
  }

  // Initialize GSAP ScrollTrigger animations
  function initAnimations() {
    if (isReducedMotion) {
      // If reduced motion, just show elements without animation
      document.querySelectorAll('.reveal, .reveal-stagger, .counter').forEach((el) => {
        (el as HTMLElement).style.opacity = '1';
        (el as HTMLElement).style.transform = 'none';
      });
      return;
    }

    // Reveal animations (single elements)
    const revealElements = document.querySelectorAll('.reveal');
    revealElements.forEach((el) => {
      gsap.fromTo(
        el,
        {
          opacity: 0,
          y: 30,
          ease: 'power3.out',
        },
        {
          opacity: 1,
          y: 0,
          duration: 0.8,
          scrollTrigger: {
            trigger: el,
            start: 'top 85%',
            end: 'bottom 20%',
            toggleActions: 'play none none reverse',
          },
        }
      );
    });

    // Reveal stagger animations (child elements with stagger)
    const revealStaggerElements = document.querySelectorAll('.reveal-stagger');
    revealStaggerElements.forEach((container) => {
      const children = container.querySelectorAll(':scope > *');
      if (children.length > 0) {
        gsap.fromTo(
          children,
          {
            opacity: 0,
            y: 20,
          },
          {
            opacity: 1,
            y: 0,
            duration: 0.6,
            stagger: 0.1,
            ease: 'power3.out',
            scrollTrigger: {
              trigger: container,
              start: 'top 80%',
              end: 'bottom 20%',
              toggleActions: 'play none none reverse',
            },
          }
        );
      }
    });

    // Counter animations
    const counterElements = document.querySelectorAll('.counter');
    counterElements.forEach((el) => {
      const targetValue = el.getAttribute('data-value');
      const suffix = el.getAttribute('data-suffix') || '';

      if (targetValue) {
        const numericValue = parseFloat(targetValue.replace(/[^0-9.]/g, ''));

        gsap.fromTo(
          el,
          { innerText: 0 },
          {
            innerText: numericValue,
            duration: 2,
            ease: 'power2.out',
            snap: { innerText: 0.1 },
            scrollTrigger: {
              trigger: el,
              start: 'top 85%',
              toggleActions: 'play none none reverse',
            },
            onUpdate: function () {
              const progress = this.progress();
              const currentValue = numericValue * progress;
              if (targetValue.includes('+')) {
                el.textContent = Math.round(currentValue) + '+' + suffix;
              } else if (targetValue.includes('%')) {
                el.textContent = Math.round(currentValue) + '%' + suffix;
              } else if (targetValue.includes('<')) {
                el.textContent = '< ' + Math.round(currentValue) + suffix;
              } else {
                el.textContent = Math.round(currentValue) + suffix;
              }
            },
          }
        );
      }
    });
  }

  // Initialize tilt effect for cards
  function initTiltEffect() {
    const tiltCards = document.querySelectorAll('.tilt-card');

    tiltCards.forEach((card) => {
      const element = card as HTMLElement;

      element.addEventListener('mousemove', (e: Event) => {
        if (isReducedMotion) return;

        const mouseEvent = e as MouseEvent;
        const rect = element.getBoundingClientRect();
        const x = mouseEvent.clientX - rect.left;
        const y = mouseEvent.clientY - rect.top;

        const centerX = rect.width / 2;
        const centerY = rect.height / 2;

        const rotateX = (y - centerY) / 10;
        const rotateY = (centerX - x) / 10;

        gsap.to(element, {
          rotationX: rotateX,
          rotationY: rotateY,
          duration: 0.3,
          ease: 'power2.out',
        });
      });

      element.addEventListener('mouseleave', () => {
        if (isReducedMotion) return;

        gsap.to(element, {
          rotationX: 0,
          rotationY: 0,
          duration: 0.5,
          ease: 'elastic.out(1, 0.5)',
        });
      });
    });
  }

  // Cleanup function
  function cleanup() {
    // Kill all ScrollTriggers
    ScrollTrigger.getAll().forEach((trigger) => trigger.kill());

    // Stop Lenis
    if (lenis) {
      lenis.destroy();
      lenis = null;
    }

    // Remove GSAP ticker
    gsap.ticker.remove((time: number) => {
      if (lenis) lenis.raf(time * 1000);
    });
  }

  // Run on initial page load
  function init() {
    cleanup();
    initLenis();
    initAnimations();
    initTiltEffect();
  }

  // Initialize on page load
  init();

  // Re-initialize on Astro view transitions
  document.addEventListener('astro:page-load', () => {
    // Small delay to ensure DOM is ready
    setTimeout(init, 10);
  });

  // Cleanup before Astro navigation
  document.addEventListener('astro:before-preparation', cleanup);
</script>
