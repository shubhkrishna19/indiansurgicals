---
---

<script>
  let cleanupAnimations = () => {};
  let viewportModeCleanup = () => {};

  const REDUCED_MOTION_QUERY = "(prefers-reduced-motion: reduce)";
  const COMPACT_VIEWPORT_QUERY = "(max-width: 960px)";
  const SCRUB_SELECTORS = [
    ".showcase-card",
    ".family-card",
    ".category-tile",
    ".catalogue-download",
    ".contact-card",
    ".gallery-empty",
    ".leadership-card",
    ".matrix",
    ".preview-category",
    ".product-gallery",
    ".quote-card",
    ".quote-chip",
    ".quote-step",
    ".review-card",
    ".status-card",
    ".trust-shell",
    ".variant-panel",
    ".catalogue-grid__item",
  ];
  const COMPACT_SCRUB_SELECTORS = [
    ".showcase-card",
    ".family-card",
    ".review-card",
    ".product-gallery",
    ".variant-panel",
  ];

  const HERO_GROUPS = [
    ".hero__content > *",
    ".about-hero__content > *",
    ".about-hero__panel > *",
    ".contact-hero__content > *",
    ".contact-hero__panel > *",
    ".quote-hero__content > *",
    ".quote-hero__panel > *",
    ".preview-hero__copy > *",
    ".preview-hero__aside > *",
    ".category-hero__copy > *",
    ".category-hero__stats > *",
    ".product-hero__content > *",
    ".product-hero__aside > *",
  ];

  function prefersReducedMotion() {
    return window.matchMedia(REDUCED_MOTION_QUERY).matches;
  }

  async function initMotion() {
    cleanupAnimations();
    viewportModeCleanup();

    if (prefersReducedMotion()) {
      document.documentElement.classList.remove("motion-ready");
      document.documentElement.classList.add("motion-reduced");
      return;
    }

    document.documentElement.classList.add("motion-ready");
    document.documentElement.classList.remove("motion-reduced");

    const [{ gsap }, { ScrollTrigger }] = await Promise.all([
      import("gsap"),
      import("gsap/ScrollTrigger"),
    ]);

    gsap.registerPlugin(ScrollTrigger);
    ScrollTrigger.config({ ignoreMobileResize: true });
    gsap.ticker.lagSmoothing(500, 33);

    const context = gsap.context(() => {
      gsap.set("main", { opacity: 1 });
      const viewportQuery = window.matchMedia(COMPACT_VIEWPORT_QUERY);
      const isCompactViewport = viewportQuery.matches;

      const viewportListener = () => {
        scheduleInit();
      };

      viewportQuery.addEventListener("change", viewportListener);
      viewportModeCleanup = () => {
        viewportQuery.removeEventListener("change", viewportListener);
        viewportModeCleanup = () => {};
      };

      HERO_GROUPS.forEach((selector) => {
        const nodes = gsap.utils.toArray<HTMLElement>(selector);
        if (!nodes.length) return;

        gsap.fromTo(
          nodes,
          { autoAlpha: 0, y: isCompactViewport ? 12 : 22 },
          {
            autoAlpha: 1,
            y: 0,
            duration: isCompactViewport ? 0.42 : 0.58,
            ease: "power3.out",
            stagger: isCompactViewport ? 0.028 : 0.05,
            force3D: true,
            clearProps: "opacity,visibility,transform",
          },
        );
      });

      const scrubSelectors = isCompactViewport ? COMPACT_SCRUB_SELECTORS : SCRUB_SELECTORS;

      const scrubNodes = Array.from(
        new Set(scrubSelectors.flatMap((selector) => gsap.utils.toArray<HTMLElement>(selector))),
      );

      if (scrubNodes.length > 0) {
        scrubNodes.forEach((node) => {
          const isCardLike =
            node.matches(".category-card") ||
            node.matches(".showcase-card") ||
            node.matches(".family-card") ||
            node.matches(".catalogue-grid__item") ||
            node.matches(".review-card") ||
            node.matches(".leadership-card") ||
            node.matches(".quote-card") ||
            node.matches(".contact-card") ||
            node.matches(".preview-category");

          gsap.fromTo(
            node,
            {
              autoAlpha: isCardLike ? 0.82 : 0.9,
              y: isCardLike ? (isCompactViewport ? 10 : 16) : 8,
              scale: isCardLike ? 0.994 : 0.998,
              force3D: true,
            },
            {
              autoAlpha: 1,
              y: 0,
              scale: 1,
              ease: "none",
              force3D: true,
              scrollTrigger: {
                trigger: node,
                start: isCompactViewport ? "top 96%" : "top 94%",
                end: isCompactViewport ? "top 88%" : "top 80%",
                scrub: isCompactViewport ? 0.08 : 0.14,
                invalidateOnRefresh: true,
              },
            },
          );
        });
      }

      gsap.utils.toArray<HTMLElement>("[data-parallax-group]").forEach((group) => {
        const items = Array.from(group.querySelectorAll<HTMLElement>("[data-parallax-speed]"));
        items.forEach((item) => {
          const speed = Number(item.getAttribute("data-parallax-speed") ?? "0.1");
          gsap.to(item, {
            yPercent: speed * (isCompactViewport ? -8 : -18),
            ease: "none",
            scrollTrigger: {
              trigger: group,
              start: "top bottom",
              end: "bottom top",
              scrub: isCompactViewport ? 0.12 : 0.16,
              invalidateOnRefresh: true,
            },
          });
        });
      });

      ScrollTrigger.sort();
      ScrollTrigger.refresh();
    }, document.body);

    cleanupAnimations = () => {
      context.revert();
      ScrollTrigger.getAll().forEach((trigger) => trigger.kill());
      viewportModeCleanup();
    };
  }

  const scheduleInit = () => {
    window.requestAnimationFrame(() => {
      window.requestAnimationFrame(() => {
        initMotion().catch((error) => {
          console.warn("Motion initialization skipped:", error);
        });
      });
    });
  };

  if (document.readyState === "loading") {
    document.addEventListener("DOMContentLoaded", scheduleInit, { once: true });
  } else {
    scheduleInit();
  }

  document.addEventListener("astro:page-load", scheduleInit);
  document.addEventListener("astro:before-preparation", () => cleanupAnimations());
</script>
