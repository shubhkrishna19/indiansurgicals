---
interface Props {
  title: string;
  subtitle?: string;
  kicker?: string;
  align?: "left" | "center";
}

const { title, subtitle = "", kicker = "", align = "left" } = Astro.props;
---

<div class:list={["section-title", `section-title--${align}`]} data-parallax-group>
  {kicker && <p class="section-title__kicker" data-parallax-speed="0.08">{kicker}</p>}
  <h2 data-parallax-speed="0.14">{title}</h2>
  {subtitle && <p class="section-title__subtitle" data-parallax-speed="0.1">{subtitle}</p>}
</div>

<style>
  .section-title {
    display: grid;
    gap: 0.9rem;
    max-width: 52rem;
    margin-bottom: 2.4rem;
  }

  .section-title--center {
    margin-inline: auto;
    text-align: center;
  }

  .section-title__kicker {
    margin: 0;
    color: var(--color-primary);
    font-size: 0.78rem;
    font-weight: 700;
    letter-spacing: 0.18em;
    text-transform: uppercase;
  }

  .section-title h2 {
    margin: 0;
    font-size: clamp(2rem, 4vw, 3.35rem);
    line-height: 0.98;
    letter-spacing: -0.05em;
  }

  .section-title__subtitle {
    margin: 0;
    color: var(--color-text-muted);
    font-size: 1.02rem;
    line-height: 1.7;
  }
</style>
