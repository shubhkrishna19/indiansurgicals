---
interface Props {
  variant?: 'primary' | 'secondary' | 'accent' | 'ghost' | 'whatsapp' | 'phone' | 'email';
  href?: string;
  icon?: 'whatsapp' | 'phone' | 'email' | 'arrow' | 'external';
  children: any;
  class?: string;
  target?: string;
}

const {
  variant = 'primary',
  href = '#',
  icon,
  children,
  class: className = '',
  target
} = Astro.props;

// Icon SVG mappings
const icons: Record<string, string> = {
  whatsapp: `<svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 11.5a8.38 8.38 0 0 1-.9 3.8 8.5 8.5 0 0 1-7.6 4.7 8.38 8.38 0 0 1-3.8-.9L3 21l1.9-5.7a8.38 8.38 0 0 1-.9-3.8 8.5 8.5 0 0 1 4.7-7.6 8.38 8.38 0 0 1 3.8-.9h.5a8.48 8.48 0 0 1 8 8v.5z"></path></svg>`,
  phone: `<svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"></path></svg>`,
  email: `<svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"></path><polyline points="22,6 12,13 2,6"></polyline></svg>`,
  arrow: `<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"></line><polyline points="12 5 19 12 12 19"></polyline></svg>`,
  external: `<svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"></path><polyline points="15 3 21 3 21 9"></polyline><line x1="10" y1="14" x2="21" y2="3"></line></svg>`
};

// Determine button variant
const buttonVariant = variant === 'whatsapp' ? 'accent' : variant === 'phone' || variant === 'email' ? 'secondary' : variant;
---

{href && href !== '#' ? (
  <a
    href={href}
    class:list={[
      'cta-button',
      `cta-button--${buttonVariant}`,
      { 'cta-button--with-icon': icon },
      { 'cta-button--magnetic': true },
      className
    ]}
    target={target}
    rel={target === '_blank' ? 'noopener noreferrer' : undefined}
  >
    {icon && <span class="cta-button__icon" set:html={icons[icon]} />}
    <span class="cta-button__text">
      <slot />
    </span>
  </a>
) : (
  <button
    class:list={[
      'cta-button',
      `cta-button--${buttonVariant}`,
      { 'cta-button--with-icon': icon },
      { 'cta-button--magnetic': true },
      className
    ]}
  >
    {icon && <span class="cta-button__icon" set:html={icons[icon]} />}
    <span class="cta-button__text">
      <slot />
    </span>
  </button>
)}

<style>
  .cta-button {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: var(--space-2);
    padding: var(--space-3) var(--space-6);
    font-family: var(--font-body);
    font-size: 0.9375rem;
    font-weight: 500;
    border-radius: var(--radius-full);
    transition: all 0.3s var(--ease-out-expo);
    white-space: nowrap;
    cursor: pointer;
    position: relative;
    overflow: hidden;
  }

  .cta-button--primary {
    background: var(--color-primary);
    color: white;
    border: none;
  }

  .cta-button--primary:hover {
    background: var(--color-primary-dark);
    color: white;
    transform: translateY(-2px);
    box-shadow: var(--shadow-glow);
  }

  .cta-button--secondary {
    background: transparent;
    color: var(--color-primary);
    border: 1.5px solid var(--color-primary);
  }

  .cta-button--secondary:hover {
    background: var(--color-primary);
    color: white;
    transform: translateY(-2px);
  }

  .cta-button--accent,
  .cta-button--whatsapp {
    background: #25D366;
    color: white;
    border: none;
  }

  .cta-button--accent:hover,
  .cta-button--whatsapp:hover {
    background: #128C7E;
    color: white;
    transform: translateY(-2px);
    box-shadow: 0 0 30px rgba(37, 211, 102, 0.25);
  }

  .cta-button--ghost {
    background: transparent;
    color: var(--color-text);
    border: none;
  }

  .cta-button--ghost:hover {
    background: var(--color-secondary);
    color: var(--color-text);
    transform: translateY(-2px);
  }

  .cta-button--phone {
    background: var(--color-primary);
    color: white;
    border: none;
  }

  .cta-button--phone:hover {
    background: var(--color-primary-dark);
    color: white;
    transform: translateY(-2px);
    box-shadow: var(--shadow-glow);
  }

  .cta-button--email {
    background: transparent;
    color: var(--color-primary);
    border: 1.5px solid var(--color-primary);
  }

  .cta-button--email:hover {
    background: var(--color-primary);
    color: white;
    transform: translateY(-2px);
  }

  .cta-button__icon {
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }

  .cta-button__icon :global(svg) {
    width: 18px;
    height: 18px;
  }

  .cta-button--with-icon .cta-button__text {
    display: flex;
    align-items: center;
    gap: var(--space-2);
  }

  /* Magnetic hover effect */
  .cta-button--magnetic {
    position: relative;
  }

  @media (hover: hover) {
    .cta-button--magnetic:hover {
      transform: translateY(-2px) scale(1.02);
    }

    .cta-button--magnetic:active {
      transform: translateY(0) scale(0.98);
    }
  }

  /* Focus styles */
  .cta-button:focus-visible {
    outline: 2px solid var(--color-primary);
    outline-offset: 2px;
  }

  /* Reduced motion */
  @media (prefers-reduced-motion: reduce) {
    .cta-button {
      transition: none;
    }

    .cta-button--magnetic:hover {
      transform: none;
    }

    .cta-button--magnetic:active {
      transform: none;
    }
  }
</style>
