---
import { getCatalogueExports, getCatalogueStats } from "../data/catalogue";

interface Props {
  title?: string;
  subtitle?: string;
  compact?: boolean;
}

const {
  title = "Official Company Catalogue",
  subtitle = "View the range online or download the official PDF.",
  compact = false,
} = Astro.props;

const catalogueExports = getCatalogueExports();
const stats = getCatalogueStats();
---

<section class:list={["catalogue-download panel", { "catalogue-download--compact": compact }]}>
  <div class="catalogue-download__copy">
    <span class="catalogue-download__kicker">Official Catalogue</span>
    <h2>{title}</h2>
    <p>{subtitle}</p>
  </div>

  <div class="catalogue-download__actions">
    <a href={catalogueExports.previewPath} class="button button--primary">View online</a>
    <a
      href={catalogueExports.workbookPath}
      class="button button--secondary"
      download={catalogueExports.workbookName}
    >
      Download PDF
    </a>
  </div>

  <div class="catalogue-download__meta">
    <article>
      <strong>{stats.categoryCount}</strong>
      <span>product categories</span>
    </article>
    <article>
      <strong>{stats.familyCount}</strong>
      <span>product families</span>
    </article>
    <article>
      <strong>{stats.variantCount}</strong>
      <span>listed models</span>
    </article>
  </div>
</section>

<style>
  .catalogue-download {
    display: grid;
    gap: 1.2rem;
    padding: 1.35rem;
    background:
      radial-gradient(circle at top right, rgba(201, 111, 40, 0.12), transparent 24%),
      linear-gradient(180deg, rgba(255, 255, 255, 0.98), rgba(244, 247, 249, 0.96));
  }

  .catalogue-download__copy {
    display: grid;
    gap: 0.7rem;
    max-width: 54rem;
  }

  .catalogue-download__kicker {
    color: var(--color-primary);
    font-size: 0.76rem;
    font-weight: 700;
    letter-spacing: 0.14em;
    text-transform: uppercase;
  }

  .catalogue-download__copy h2,
  .catalogue-download__copy p {
    margin: 0;
  }

  .catalogue-download__copy h2 {
    font-size: clamp(1.7rem, 3vw, 2.5rem);
    line-height: 1.02;
    letter-spacing: -0.04em;
  }

  .catalogue-download__copy p {
    color: var(--color-text-muted);
    line-height: 1.75;
  }

  .catalogue-download__actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.9rem;
  }

  .catalogue-download__meta {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 0.85rem;
  }

  .catalogue-download__meta article {
    display: grid;
    gap: 0.28rem;
    padding: 0.9rem 1rem;
    border-radius: 1rem;
    background: rgba(25, 77, 128, 0.06);
  }

  .catalogue-download__meta strong {
    font-size: 1.08rem;
  }

  .catalogue-download__meta span {
    color: var(--color-text-muted);
    font-size: 0.82rem;
  }

  .catalogue-download--compact {
    padding: 1.1rem;
  }

  .catalogue-download--compact .catalogue-download__copy h2 {
    font-size: clamp(1.4rem, 2.4vw, 1.95rem);
  }

  @media (max-width: 900px) {
    .catalogue-download__meta {
      grid-template-columns: repeat(3, minmax(0, 1fr));
    }
  }

  @media (max-width: 640px) {
    .catalogue-download {
      gap: 0.8rem;
      padding: 0.92rem;
      border-radius: 1.1rem;
    }

    .catalogue-download__copy {
      gap: 0.42rem;
    }

    .catalogue-download__kicker {
      font-size: 0.68rem;
      letter-spacing: 0.12em;
    }

    .catalogue-download__copy h2 {
      font-size: clamp(1.26rem, 6.2vw, 1.58rem);
      line-height: 1.04;
    }

    .catalogue-download__copy p {
      font-size: 0.86rem;
      line-height: 1.42;
    }

    .catalogue-download__actions {
      display: grid;
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: 0.55rem;
    }

    .catalogue-download__meta {
      grid-template-columns: repeat(3, minmax(0, 1fr));
      gap: 0.45rem;
    }

    .catalogue-download__actions .button {
      min-height: 2.5rem;
      padding: 0.62rem 0.72rem;
      font-size: 0.8rem;
      line-height: 1.1;
      justify-content: center;
      text-align: center;
      border-radius: 0.92rem;
    }

    .catalogue-download__meta article {
      gap: 0.16rem;
      padding: 0.62rem 0.68rem;
      border-radius: 0.86rem;
    }

    .catalogue-download__meta strong {
      font-size: 0.98rem;
      line-height: 1;
    }

    .catalogue-download__meta span {
      font-size: 0.68rem;
      line-height: 1.2;
    }
  }
</style>
