---
import type { CatalogueCategory } from "../data/catalogue";

interface Props {
  category: CatalogueCategory;
  inert?: boolean;
}

const { category, inert = false } = Astro.props;
---

<a
  href={`/products/${category.slug}`}
  class="category-card"
  tabindex={inert ? "-1" : undefined}
  aria-hidden={inert ? "true" : undefined}
>
  <div class="category-card__media">
    {category.heroImage ? (
      <img src={category.heroImage} alt={category.name} loading="lazy" />
    ) : (
      <div class="category-card__placeholder"></div>
    )}
  </div>

  <div class="category-card__body">
    <h3>{category.name}</h3>
  </div>
</a>

<style>
  .category-card {
    display: flex;
    flex-direction: column;
    border: 1px solid var(--color-line);
    border-radius: 1.6rem;
    overflow: hidden;
    background:
      radial-gradient(circle at top right, rgba(201, 111, 40, 0.14), transparent 28%),
      linear-gradient(180deg, rgba(255, 255, 255, 0.98), rgba(242, 246, 249, 0.96));
    box-shadow:
      0 22px 44px rgba(13, 45, 76, 0.12),
      0 8px 18px rgba(13, 45, 76, 0.06);
    min-height: 100%;
    transition:
      transform 180ms ease,
      box-shadow 180ms ease,
      border-color 180ms ease;
  }

  .category-card:hover {
    transform: translateY(-8px);
    border-color: rgba(25, 77, 128, 0.3);
    box-shadow:
      0 28px 52px rgba(13, 45, 76, 0.16),
      0 12px 24px rgba(13, 45, 76, 0.08);
  }

  .category-card__media {
    position: relative;
    aspect-ratio: 1 / 1;
    background:
      radial-gradient(circle at top left, rgba(201, 111, 40, 0.22), transparent 36%),
      radial-gradient(circle at bottom right, rgba(25, 77, 128, 0.12), transparent 34%),
      linear-gradient(180deg, rgba(255, 255, 255, 0.98), rgba(243, 247, 249, 0.98));
    overflow: hidden;
  }

  .category-card__media::after {
    content: "";
    position: absolute;
    inset: auto 1rem 0.9rem;
    height: 0.35rem;
    border-radius: 999px;
    background: linear-gradient(90deg, rgba(25, 77, 128, 0.18), rgba(201, 111, 40, 0.28));
    filter: blur(6px);
    opacity: 0.9;
    pointer-events: none;
  }

  .category-card__media img,
  .category-card__placeholder {
    width: 100%;
    height: 100%;
    object-fit: contain;
    padding: 1.15rem 1.15rem 0.95rem;
  }

  .category-card__placeholder {
    background:
      linear-gradient(135deg, rgba(25, 77, 128, 0.12), rgba(11, 27, 43, 0.04)),
      linear-gradient(90deg, transparent 0%, rgba(255, 255, 255, 0.25) 50%, transparent 100%);
  }

  .category-card__body {
    display: flex;
    align-items: center;
    justify-content: center;
    min-height: 5.8rem;
    padding: 1.1rem 1.15rem 1.2rem;
    text-align: center;
    background: linear-gradient(180deg, rgba(255, 255, 255, 0.78), rgba(248, 250, 252, 0.96));
  }

  .category-card h3 {
    margin: 0;
    font-size: 1.08rem;
    line-height: 1.3;
    letter-spacing: -0.02em;
    text-wrap: balance;
  }
</style>
