---
import type { CatalogueCategory } from "../data/catalogue";

interface Props {
  category: CatalogueCategory;
}

const { category } = Astro.props;
---

<a href={`/products/${category.slug}`} class="category-card">
  <div class="category-card__media">
    {category.heroImage ? (
      <img src={category.heroImage} alt={category.name} loading="lazy" />
    ) : (
      <div class="category-card__placeholder"></div>
    )}
  </div>

  <div class="category-card__body">
    <h3>{category.name}</h3>
  </div>
</a>

<style>
  .category-card {
    display: flex;
    flex-direction: column;
    border: 1px solid var(--color-line);
    border-radius: 1.4rem;
    overflow: hidden;
    background:
      linear-gradient(180deg, rgba(255, 255, 255, 0.96), rgba(247, 249, 251, 0.96));
    box-shadow: var(--shadow-card);
    min-height: 100%;
    transition:
      transform 180ms ease,
      box-shadow 180ms ease,
      border-color 180ms ease;
  }

  .category-card:hover {
    transform: translateY(-4px);
    border-color: rgba(25, 77, 128, 0.24);
    box-shadow: var(--shadow-card-hover);
  }

  .category-card__media {
    position: relative;
    aspect-ratio: 1 / 1;
    background:
      radial-gradient(circle at top left, rgba(201, 111, 40, 0.22), transparent 40%),
      linear-gradient(180deg, rgba(255, 255, 255, 0.98), rgba(243, 247, 249, 0.98));
    overflow: hidden;
  }

  .category-card__media img,
  .category-card__placeholder {
    width: 100%;
    height: 100%;
    object-fit: contain;
    padding: 1rem;
  }

  .category-card__placeholder {
    background:
      linear-gradient(135deg, rgba(25, 77, 128, 0.12), rgba(11, 27, 43, 0.04)),
      linear-gradient(90deg, transparent 0%, rgba(255, 255, 255, 0.25) 50%, transparent 100%);
  }

  .category-card__body {
    display: flex;
    align-items: center;
    justify-content: center;
    min-height: 5.4rem;
    padding: 1.05rem 1.15rem 1.15rem;
    text-align: center;
  }

  .category-card h3 {
    margin: 0;
    font-size: 1.05rem;
    line-height: 1.25;
    text-wrap: balance;
  }
</style>
