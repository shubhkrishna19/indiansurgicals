---
import type { CatalogueCategory } from "../data/catalogue";

interface Props {
  category: CatalogueCategory;
  inert?: boolean;
}

const { category, inert = false } = Astro.props;
const categorySlug = category.slug.toLowerCase();
const categoryName = category.name.toLowerCase();

const fitClass = (() => {
  if (categorySlug.includes("autoclave") || categoryName.includes("autoclave")) {
    return "category-card__media-image--autoclave";
  }

  if (
    categorySlug.includes("fumigator") ||
    categorySlug.includes("hospital-utensil") ||
    categoryName.includes("fumigator") ||
    categoryName.includes("hospital utensil")
  ) {
    return "category-card__media-image--fumigator";
  }

  if (categorySlug.includes("needle-destroy") || categoryName.includes("needle destroy")) {
    return "category-card__media-image--needle-destroyer";
  }

  if (
    categorySlug.includes("stainless-steel-tray") ||
    categoryName.includes("stainless steel tray") ||
    categorySlug.includes("ward-equipment") ||
    categoryName.includes("ward equipment")
  ) {
    return "category-card__media-image--wide-stage";
  }

  return "";
})();
---

<a
  href={`/products/${category.slug}`}
  class="category-card"
  tabindex={inert ? "-1" : undefined}
  aria-hidden={inert ? "true" : undefined}
>
  <div class="category-card__media">
    {category.heroImage ? (
      <img
        src={category.heroImage}
        alt={category.name}
        loading="lazy"
        draggable="false"
        class:list={fitClass ? [fitClass] : []}
      />
    ) : (
      <div class="category-card__placeholder"></div>
    )}
  </div>

  <div class="category-card__body">
    <h3>{category.name}</h3>
  </div>
</a>

<style>
  .category-card {
    display: grid;
    grid-template-rows: minmax(0, 1fr) auto;
    align-content: start;
    color: inherit;
    border: 1px solid rgba(84, 96, 109, 0.12);
    border-radius: 0.95rem;
    overflow: hidden;
    background: rgba(255, 255, 255, 0.92);
    box-shadow: 0 12px 24px rgba(13, 45, 76, 0.07);
    min-height: 100%;
    text-decoration: none;
    transition:
      transform 180ms ease,
      box-shadow 180ms ease,
      border-color 180ms ease;
  }

  .category-card:hover,
  .category-card:focus-visible {
    transform: translateY(-4px);
    border-color: rgba(25, 77, 128, 0.22);
    box-shadow: 0 22px 38px rgba(13, 45, 76, 0.12);
  }

  .category-card__media {
    display: grid;
    place-items: center;
    aspect-ratio: 1 / 0.88;
    min-height: 0;
    background: linear-gradient(180deg, rgba(255, 255, 255, 0.98), rgba(244, 247, 250, 0.98));
    overflow: hidden;
  }

  .category-card__media img,
  .category-card__placeholder {
    width: 100%;
    height: 100%;
    object-fit: contain;
    object-position: center center;
    padding: 0.62rem 0.64rem 0.58rem;
  }

  .category-card__media-image--autoclave {
    width: auto;
    height: auto;
    max-width: 74%;
    max-height: 74%;
    padding: 0;
  }

  .category-card__media-image--fumigator {
    width: auto;
    height: auto;
    max-width: 70%;
    max-height: 70%;
    padding: 0;
  }

  .category-card__media-image--needle-destroyer {
    width: auto;
    height: auto;
    max-width: 68%;
    max-height: 68%;
    padding: 0;
  }

  .category-card__media-image--wide-stage {
    width: auto;
    height: auto;
    max-width: 72%;
    max-height: 72%;
    padding: 0;
  }

  .category-card__placeholder {
    background: linear-gradient(135deg, rgba(25, 77, 128, 0.08), rgba(201, 111, 40, 0.05));
  }

  .category-card__body {
    display: flex;
    align-items: center;
    justify-content: center;
    min-height: 3.3rem;
    padding: 0.68rem 0.72rem 0.75rem;
    text-align: center;
    border-top: 1px solid rgba(84, 96, 109, 0.08);
  }

  .category-card h3 {
    margin: 0;
    font-size: 0.84rem;
    line-height: 1.22;
    letter-spacing: -0.02em;
    text-wrap: balance;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  @media (max-width: 720px) {
    .category-card {
      border-radius: 0.88rem;
    }

    .category-card__media {
      aspect-ratio: 1 / 0.78;
    }

    .category-card__media-image--autoclave {
      max-width: 60%;
      max-height: 60%;
    }

    .category-card__media-image--fumigator {
      max-width: 56%;
      max-height: 56%;
    }

    .category-card__media-image--needle-destroyer {
      max-width: 56%;
      max-height: 56%;
    }

    .category-card__media-image--wide-stage {
      max-width: 58%;
      max-height: 58%;
    }

    .category-card__media img,
    .category-card__placeholder {
      padding: 0.35rem 0.38rem 0.32rem;
    }

    .category-card__body {
      min-height: 2.65rem;
      padding: 0.4rem 0.46rem 0.5rem;
    }

    .category-card h3 {
      font-size: 0.72rem;
      line-height: 1.18;
    }
  }
</style>
