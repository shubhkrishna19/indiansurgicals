---
import type { CatalogueCategory } from "../data/catalogue";

interface Props {
  category: CatalogueCategory;
  inert?: boolean;
}

const { category, inert = false } = Astro.props;
---

<a
  href={`/products/${category.slug}`}
  class="category-card"
  tabindex={inert ? "-1" : undefined}
  aria-hidden={inert ? "true" : undefined}
>
  <div class="category-card__media">
    {category.heroImage ? (
      <img src={category.heroImage} alt={category.name} loading="lazy" />
    ) : (
      <div class="category-card__placeholder"></div>
    )}
  </div>

  <div class="category-card__body">
    <h3>{category.name}</h3>
  </div>
</a>

<style>
  .category-card {
    display: flex;
    flex-direction: column;
    border: 1px solid rgba(84, 96, 109, 0.12);
    border-radius: 1.1rem;
    overflow: hidden;
    background: rgba(255, 255, 255, 0.94);
    box-shadow: 0 16px 32px rgba(13, 45, 76, 0.08);
    min-height: 100%;
    transition:
      transform 180ms ease,
      box-shadow 180ms ease,
      border-color 180ms ease;
  }

  .category-card:hover,
  .category-card:focus-visible {
    transform: translateY(-4px);
    border-color: rgba(25, 77, 128, 0.22);
    box-shadow: 0 22px 38px rgba(13, 45, 76, 0.12);
  }

  .category-card__media {
    display: grid;
    place-items: center;
    min-height: 11.5rem;
    background: linear-gradient(180deg, rgba(255, 255, 255, 0.98), rgba(244, 247, 250, 0.98));
    overflow: hidden;
  }

  .category-card__media img,
  .category-card__placeholder {
    width: 100%;
    height: 100%;
    object-fit: contain;
    padding: 1rem;
  }

  .category-card__placeholder {
    background: linear-gradient(135deg, rgba(25, 77, 128, 0.08), rgba(201, 111, 40, 0.05));
  }

  .category-card__body {
    display: flex;
    align-items: center;
    justify-content: center;
    min-height: 4.8rem;
    padding: 0.95rem 1rem 1rem;
    text-align: center;
    border-top: 1px solid rgba(84, 96, 109, 0.08);
  }

  .category-card h3 {
    margin: 0;
    font-size: 1rem;
    line-height: 1.35;
    letter-spacing: -0.02em;
    text-wrap: balance;
  }
</style>
