---
import type { CatalogueCategory } from "../data/catalogue";

interface Props {
  category: CatalogueCategory;
  inert?: boolean;
}

const { category, inert = false } = Astro.props;
---

<a
  href={`/products/${category.slug}`}
  class="category-card"
  tabindex={inert ? "-1" : undefined}
  aria-hidden={inert ? "true" : undefined}
>
  <div class="category-card__media">
    {category.heroImage ? (
      <img src={category.heroImage} alt={category.name} loading="lazy" draggable="false" />
    ) : (
      <div class="category-card__placeholder"></div>
    )}
  </div>

  <div class="category-card__body">
    <h3>{category.name}</h3>
  </div>
</a>

<style>
  .category-card {
    display: flex;
    flex-direction: column;
    color: inherit;
    border: 1px solid rgba(84, 96, 109, 0.12);
    border-radius: 0.95rem;
    overflow: hidden;
    background: rgba(255, 255, 255, 0.92);
    box-shadow: 0 12px 24px rgba(13, 45, 76, 0.07);
    min-height: 100%;
    text-decoration: none;
    transition:
      transform 180ms ease,
      box-shadow 180ms ease,
      border-color 180ms ease;
  }

  .category-card:hover,
  .category-card:focus-visible {
    transform: translateY(-4px);
    border-color: rgba(25, 77, 128, 0.22);
    box-shadow: 0 22px 38px rgba(13, 45, 76, 0.12);
  }

  .category-card__media {
    display: grid;
    place-items: center;
    min-height: 7.7rem;
    background: linear-gradient(180deg, rgba(255, 255, 255, 0.98), rgba(244, 247, 250, 0.98));
    overflow: hidden;
  }

  .category-card__media img,
  .category-card__placeholder {
    width: 100%;
    height: 100%;
    object-fit: contain;
    padding: 0.65rem;
  }

  .category-card__placeholder {
    background: linear-gradient(135deg, rgba(25, 77, 128, 0.08), rgba(201, 111, 40, 0.05));
  }

  .category-card__body {
    display: flex;
    align-items: center;
    justify-content: center;
    min-height: 3.4rem;
    padding: 0.72rem 0.75rem 0.78rem;
    text-align: center;
    border-top: 1px solid rgba(84, 96, 109, 0.08);
  }

  .category-card h3 {
    margin: 0;
    font-size: 0.86rem;
    line-height: 1.28;
    letter-spacing: -0.02em;
    text-wrap: balance;
  }

  @media (max-width: 720px) {
    .category-card {
      border-radius: 0.88rem;
    }

    .category-card__media {
      min-height: 6.5rem;
    }

    .category-card__media img,
    .category-card__placeholder {
      padding: 0.55rem;
    }

    .category-card__body {
      min-height: 3rem;
      padding: 0.58rem 0.62rem 0.68rem;
    }

    .category-card h3 {
      font-size: 0.79rem;
      line-height: 1.22;
    }
  }
</style>
