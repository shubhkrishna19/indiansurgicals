---
import type { ProductFamily } from "../data/catalogue";

interface Props {
  family: ProductFamily;
}

const { family } = Astro.props;
const image = family.images[0] ?? "";
---

<article class="family-card">
  <a href={`/products/${family.categorySlug}/${family.slug}`} class="family-card__media">
    {image ? (
      <img src={image} alt={family.name} loading="lazy" />
    ) : (
      <div class="family-card__placeholder"></div>
    )}
    <span class="family-card__badge">
      {family.variants.length} model{family.variants.length === 1 ? "" : "s"}
    </span>
  </a>

  <div class="family-card__body">
    <p class="family-card__eyebrow">{family.subheading || "Product Family"}</p>
    <a href={`/products/${family.categorySlug}/${family.slug}`} class="family-card__title-link">
      <h3>{family.name}</h3>
    </a>
    <p class="family-card__summary">{family.summary}</p>

    <div class="family-card__chips">
      {family.tableColumns.slice(1, 4).map((column) => (
        <span>{column}</span>
      ))}
    </div>

    <div class="family-card__footer">
      <span>Read specifications</span>
      <span>Quote only</span>
    </div>
  </div>
</article>

<style>
  .family-card {
    display: grid;
    grid-template-rows: auto 1fr;
    border: 1px solid var(--color-line);
    border-radius: 1.35rem;
    overflow: hidden;
    background: var(--color-surface);
    box-shadow: var(--shadow-card);
    min-height: 100%;
    transition:
      transform 180ms ease,
      box-shadow 180ms ease,
      border-color 180ms ease;
  }

  .family-card:hover {
    transform: translateY(-4px);
    border-color: rgba(25, 77, 128, 0.24);
    box-shadow: var(--shadow-card-hover);
  }

  .family-card__media {
    position: relative;
    display: block;
    aspect-ratio: 16 / 11;
    background:
      radial-gradient(circle at top left, rgba(25, 77, 128, 0.12), transparent 45%),
      linear-gradient(135deg, rgba(11, 27, 43, 0.06), rgba(25, 77, 128, 0.04));
    overflow: hidden;
  }

  .family-card__media img,
  .family-card__placeholder {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 220ms ease;
  }

  .family-card:hover .family-card__media img,
  .family-card:hover .family-card__placeholder {
    transform: scale(1.03);
  }

  .family-card__placeholder {
    background:
      linear-gradient(135deg, rgba(25, 77, 128, 0.1), rgba(201, 111, 40, 0.08)),
      repeating-linear-gradient(
        90deg,
        rgba(255, 255, 255, 0.08) 0,
        rgba(255, 255, 255, 0.08) 1px,
        transparent 1px,
        transparent 22px
      );
  }

  .family-card__badge {
    position: absolute;
    right: 1rem;
    bottom: 1rem;
    display: inline-flex;
    align-items: center;
    border-radius: 999px;
    padding: 0.5rem 0.85rem;
    background: rgba(255, 255, 255, 0.92);
    color: var(--color-text);
    font-size: 0.78rem;
    font-weight: 600;
    box-shadow: 0 8px 18px rgba(11, 27, 43, 0.12);
  }

  .family-card__body {
    display: grid;
    gap: 0.95rem;
    padding: 1.2rem 1.2rem 1.25rem;
  }

  .family-card__eyebrow {
    margin: 0;
    color: var(--color-primary);
    font-size: 0.74rem;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }

  .family-card__title-link {
    color: inherit;
  }

  .family-card h3 {
    margin: 0;
    font-size: 1.16rem;
    line-height: 1.2;
  }

  .family-card__summary {
    margin: 0;
    color: var(--color-text-muted);
    font-size: 0.94rem;
    line-height: 1.62;
  }

  .family-card__chips {
    display: flex;
    flex-wrap: wrap;
    gap: 0.45rem;
  }

  .family-card__chips span {
    display: inline-flex;
    align-items: center;
    border-radius: 999px;
    padding: 0.38rem 0.7rem;
    background: rgba(25, 77, 128, 0.08);
    color: var(--color-primary);
    font-size: 0.75rem;
    font-weight: 600;
  }

  .family-card__footer {
    display: flex;
    justify-content: space-between;
    gap: 0.8rem;
    margin-top: auto;
    padding-top: 0.95rem;
    border-top: 1px solid rgba(84, 96, 109, 0.16);
    color: var(--color-text-muted);
    font-size: 0.82rem;
  }
</style>
