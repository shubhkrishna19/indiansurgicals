---
import type { ProductFamily } from "../data/catalogue";

interface Props {
  family: ProductFamily;
}

const { family } = Astro.props;
const image = family.images[0] ?? "";
const imageCount = family.images.length;
const href = `/products/${family.categorySlug}/${family.slug}`;
---

<a href={href} class="family-card">
  <div class="family-card__media">
    {image ? (
      <img src={image} alt={family.name} loading="lazy" />
    ) : (
      <div class="family-card__placeholder"></div>
    )}
  </div>

  <div class="family-card__body">
    <div class="family-card__header">
      <p class="family-card__eyebrow">{family.subheading || "Indian Surgical Industries"}</p>

      <div class="family-card__badges">
        <span class="family-card__badge">
          {family.variants.length} model{family.variants.length === 1 ? "" : "s"}
        </span>
        {imageCount > 1 && <span class="family-card__views">{imageCount} photos</span>}
      </div>
    </div>

    <h3>{family.name}</h3>
    <p class="family-card__summary">{family.summary}</p>

    <div class="family-card__chips">
      {family.tableColumns.slice(1, 4).map((column) => (
        <span>{column}</span>
      ))}
    </div>

    <div class="family-card__footer">
      <span>View product</span>
      <span>Get quote</span>
    </div>
  </div>
</a>

<style>
  .family-card {
    display: grid;
    grid-template-rows: auto 1fr;
    border: 1px solid var(--color-line);
    border-radius: 1.35rem;
    overflow: hidden;
    background: var(--color-surface);
    box-shadow: var(--shadow-card);
    min-height: 100%;
    transition:
      transform 180ms ease,
      box-shadow 180ms ease,
      border-color 180ms ease;
    color: inherit;
    text-decoration: none;
  }

  .family-card:hover,
  .family-card:focus-visible {
    transform: translateY(-4px);
    border-color: rgba(25, 77, 128, 0.24);
    box-shadow: var(--shadow-card-hover);
  }

  .family-card__media {
    position: relative;
    display: grid;
    place-items: center;
    aspect-ratio: 4 / 3.1;
    background:
      radial-gradient(circle at top left, rgba(25, 77, 128, 0.12), transparent 45%),
      linear-gradient(180deg, rgba(255, 255, 255, 0.98), rgba(244, 247, 249, 0.98));
    overflow: hidden;
  }

  .family-card__media img {
    width: auto;
    height: auto;
    max-width: 82%;
    max-height: 82%;
    object-fit: contain;
    object-position: center center;
    transition: transform 220ms ease;
  }

  .family-card__placeholder {
    width: 100%;
    height: 100%;
  }

  .family-card:hover .family-card__media img,
  .family-card:hover .family-card__placeholder {
    transform: scale(1.03);
  }

  .family-card__placeholder {
    background:
      linear-gradient(135deg, rgba(25, 77, 128, 0.1), rgba(201, 111, 40, 0.08)),
      repeating-linear-gradient(
        90deg,
        rgba(255, 255, 255, 0.08) 0,
        rgba(255, 255, 255, 0.08) 1px,
        transparent 1px,
        transparent 22px
      );
  }

  .family-card__badge {
    display: inline-flex;
    align-items: center;
    border-radius: 999px;
    padding: 0.42rem 0.72rem;
    background: rgba(25, 77, 128, 0.08);
    color: var(--color-primary);
    font-size: 0.74rem;
    font-weight: 600;
  }

  .family-card__views {
    display: inline-flex;
    align-items: center;
    border-radius: 999px;
    padding: 0.42rem 0.72rem;
    background: rgba(11, 27, 43, 0.88);
    color: white;
    font-size: 0.69rem;
    font-weight: 700;
    letter-spacing: 0.04em;
    text-transform: uppercase;
  }

  .family-card__body {
    display: grid;
    gap: 0.82rem;
    padding: 1.08rem 1.1rem 1.12rem;
    min-width: 0;
  }

  .family-card__header {
    display: grid;
    gap: 0.55rem;
  }

  .family-card__badges {
    display: flex;
    flex-wrap: wrap;
    gap: 0.45rem;
  }

  .family-card__eyebrow {
    margin: 0;
    color: var(--color-primary);
    font-size: 0.74rem;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }

  .family-card h3 {
    margin: 0;
    font-size: 1.16rem;
    line-height: 1.2;
    min-width: 0;
  }

  .family-card__summary {
    margin: 0;
    color: var(--color-text-muted);
    font-size: 0.94rem;
    line-height: 1.62;
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .family-card__chips {
    display: flex;
    flex-wrap: wrap;
    gap: 0.45rem;
  }

  .family-card__chips span {
    display: inline-flex;
    align-items: center;
    border-radius: 999px;
    padding: 0.38rem 0.7rem;
    background: rgba(25, 77, 128, 0.08);
    color: var(--color-primary);
    font-size: 0.75rem;
    font-weight: 600;
  }

  .family-card__footer {
    display: flex;
    justify-content: space-between;
    gap: 0.8rem;
    margin-top: auto;
    padding-top: 0.85rem;
    border-top: 1px solid rgba(84, 96, 109, 0.16);
    color: var(--color-text-muted);
    font-size: 0.82rem;
  }

  @media (max-width: 720px) {
    .family-card {
      border-radius: 1.18rem;
    }

    .family-card__media {
      aspect-ratio: 1 / 0.76;
    }

    .family-card__media img {
      max-width: 66%;
      max-height: 66%;
    }

    .family-card__body {
      gap: 0.48rem;
      padding: 0.72rem 0.74rem 0.78rem;
    }

    .family-card__header {
      gap: 0.45rem;
    }

    .family-card__badge,
    .family-card__views {
      font-size: 0.66rem;
      padding: 0.35rem 0.6rem;
    }

    .family-card h3 {
      font-size: 0.96rem;
      line-height: 1.18;
    }

    .family-card__summary {
      font-size: 0.8rem;
      line-height: 1.38;
      -webkit-line-clamp: 2;
    }

    .family-card__footer {
      font-size: 0.67rem;
      padding-top: 0.5rem;
    }
  }

  @media (max-width: 520px) {
    .family-card__media {
      aspect-ratio: 1 / 0.72;
    }

    .family-card__media img {
      max-width: 62%;
      max-height: 62%;
    }

    .family-card__body {
      gap: 0.42rem;
      padding: 0.66rem 0.68rem 0.72rem;
    }

    .family-card__badge,
    .family-card__views {
      font-size: 0.62rem;
      padding: 0.3rem 0.52rem;
    }

    .family-card h3 {
      font-size: 0.9rem;
    }

    .family-card__chips {
      display: none;
    }
  }
</style>
