---
import { business, getWhatsAppLink } from "../data/business";
import { getAllCategories } from "../data/catalogue";

const categories = getAllCategories();
const year = new Date().getFullYear();
const whatsappLink = getWhatsAppLink();
const otherWebsiteHref = business.contact.website ? `https://${business.contact.website}` : "";
const showWebsiteInFooter =
  business.contact.website &&
  business.contact.website.trim().toLowerCase() !== "example.com";
---

<footer class="site-footer">
  <div class="container site-footer__grid">
    <section class="site-footer__intro">
      <span class="site-footer__mark">
        <img src="/life-equip-logo.png" alt={`${business.brandMark} logo`} />
      </span>
      <h2>{business.brand}</h2>
      <p>{business.shortDescription}</p>
      <ul class="site-footer__tags">
        {business.certifications.map((item) => (
          <li>{item}</li>
        ))}
      </ul>

      <div class="site-footer__socials">
        <a
          href={whatsappLink}
          class="site-footer__social site-footer__social--whatsapp"
          target="_blank"
          rel="noreferrer"
          aria-label="WhatsApp"
          title="WhatsApp"
        >
          <svg viewBox="0 0 24 24" aria-hidden="true">
            <path
              fill="currentColor"
              d="M19.1 4.9A9.94 9.94 0 0 0 12.03 2C6.53 2 2.06 6.46 2.05 11.96c0 1.76.46 3.48 1.34 5l-1.42 5.2 5.32-1.4a9.91 9.91 0 0 0 4.74 1.2h.01c5.5 0 9.97-4.47 9.97-9.97a9.9 9.9 0 0 0-2.91-7.09Zm-7.07 15.38h-.01a8.3 8.3 0 0 1-4.23-1.16l-.3-.18-3.15.83.84-3.07-.2-.31a8.3 8.3 0 0 1-1.28-4.43c0-4.6 3.74-8.34 8.34-8.34 2.23 0 4.33.87 5.9 2.44a8.28 8.28 0 0 1 2.44 5.9c0 4.6-3.74 8.33-8.35 8.33Zm4.57-6.24c-.25-.12-1.47-.73-1.7-.82-.23-.08-.4-.12-.57.12-.16.25-.65.82-.8.99-.15.16-.29.19-.54.06-.25-.12-1.03-.38-1.96-1.22-.72-.64-1.2-1.43-1.34-1.68-.14-.25-.02-.38.1-.5.1-.1.25-.27.37-.4.12-.15.16-.25.25-.42.08-.17.04-.31-.02-.44-.06-.12-.57-1.36-.78-1.87-.2-.48-.4-.42-.57-.43h-.48c-.17 0-.44.06-.67.31-.23.25-.88.85-.88 2.08 0 1.22.9 2.4 1.02 2.56.12.16 1.77 2.7 4.28 3.78.6.26 1.07.42 1.43.54.6.19 1.14.16 1.56.1.48-.07 1.47-.6 1.68-1.18.21-.58.21-1.08.15-1.18-.06-.1-.23-.16-.48-.29Z"
            />
          </svg>
        </a>
        <a
          href={business.socialLinks.instagram}
          class="site-footer__social site-footer__social--instagram"
          target="_blank"
          rel="noreferrer"
          aria-label="Instagram"
          title="Instagram"
        >
          <svg viewBox="0 0 24 24" aria-hidden="true">
            <rect
              x="3"
              y="3"
              width="18"
              height="18"
              rx="5"
              ry="5"
              fill="none"
              stroke="currentColor"
              stroke-width="1.9"
            />
            <circle cx="12" cy="12" r="4.2" fill="none" stroke="currentColor" stroke-width="1.9" />
            <circle cx="17.3" cy="6.7" r="1.1" fill="currentColor" />
          </svg>
        </a>
        <a
          href={business.socialLinks.twitter}
          class="site-footer__social site-footer__social--x"
          target="_blank"
          rel="noreferrer"
          aria-label="X"
          title="X"
        >
          <svg viewBox="0 0 24 24" aria-hidden="true">
            <path
              fill="currentColor"
              d="M18.9 3H21l-4.58 5.24L21.8 21h-4.9l-3.84-5.03L8.66 21H6.54l4.9-5.6L2.2 3h5.02l3.47 4.59L18.9 3Zm-1.72 16.39h1.17L6.56 4.52H5.3l11.88 14.87Z"
            />
          </svg>
        </a>
        <a
          href={business.socialLinks.youtube}
          class="site-footer__social site-footer__social--youtube"
          target="_blank"
          rel="noreferrer"
          aria-label="YouTube"
          title="YouTube"
        >
          <svg viewBox="0 0 24 24" aria-hidden="true">
            <path
              fill="currentColor"
              d="M21.58 7.19a2.98 2.98 0 0 0-2.1-2.11C17.62 4.5 12 4.5 12 4.5s-5.62 0-7.48.58A2.98 2.98 0 0 0 2.42 7.2 31.3 31.3 0 0 0 2 12a31.3 31.3 0 0 0 .42 4.81 2.98 2.98 0 0 0 2.1 2.11c1.86.58 7.48.58 7.48.58s5.62 0 7.48-.58a2.98 2.98 0 0 0 2.1-2.11A31.3 31.3 0 0 0 22 12a31.3 31.3 0 0 0-.42-4.81ZM10.2 15.03V8.97L15.4 12l-5.2 3.03Z"
            />
          </svg>
        </a>
      </div>

      {showWebsiteInFooter && (
        <a
          href={otherWebsiteHref}
          class="site-footer__website"
          target="_blank"
          rel="noreferrer"
        >
          Visit Our Other Website
        </a>
      )}
    </section>

    <section>
      <h3>Catalogue Sections</h3>
      <ul class="site-footer__links">
        {categories.map((category) => (
          <li><a href={`/products/${category.slug}`}>{category.name}</a></li>
        ))}
      </ul>
    </section>

    <section>
      <h3>Company</h3>
      <ul class="site-footer__links">
        <li><a href="/about">About the manufacturer</a></li>
        <li><a href="/get-quote">Get quote and contact</a></li>
        <li><a href="/products">Browse all product families</a></li>
        <li><a href="/catalogue-preview">Open catalogue preview</a></li>
        <li><a href="/contact">Contact and enquiries</a></li>
      </ul>
    </section>

    <section>
      <h3>Contact</h3>
      <ul class="site-footer__notes">
        {business.contact.addressLines.map((line) => (
          <li>{line}</li>
        ))}
        {business.contact.phones.map((phone) => (
          <li><a href={`tel:${phone}`}>{phone}</a></li>
        ))}
        {business.contact.telephones.map((phone) => (
          <li><a href={`tel:${phone}`}>{phone}</a></li>
        ))}
        {business.contact.emails.map((email) => (
          <li><a href={`mailto:${email}`}>{email}</a></li>
        ))}
      </ul>
    </section>
  </div>

  <section class="container site-footer__shipping" aria-label="Supported global shipment countries">
    <div class="site-footer__shipping-copy">
      <h3>Supported Global Shipment Countries</h3>
      <p>
        Indian Surgical Industries supports shipment and export-led product enquiries across the
        following markets for institutional, dealer, and procurement-led requirements.
      </p>
    </div>

    <ul class="site-footer__shipping-list">
      {business.globalShipmentCountries.map((country) => (
        <li>{country}</li>
      ))}
    </ul>
  </section>

  <div class="container site-footer__bottom">
    <span>(c) {year} {business.brand}. All rights reserved.</span>
    <span>Manufacturer of medical and surgical equipment from Noida, India.</span>
  </div>
</footer>

<style>
  .site-footer {
    margin-top: 5rem;
    padding: 3rem 0 1.5rem;
    background:
      linear-gradient(180deg, rgba(11, 27, 43, 0.02), rgba(11, 27, 43, 0.07)),
      #f4f7fa;
    border-top: 1px solid rgba(84, 96, 109, 0.16);
  }

  .site-footer__grid {
    display: grid;
    grid-template-columns: 1.6fr 1fr 1fr 1.2fr;
    gap: 2rem;
  }

  .site-footer__intro h2 {
    margin: 0.8rem 0 0.75rem;
    font-size: 1.45rem;
  }

  .site-footer__intro p {
    margin: 0;
    color: var(--color-text-muted);
    line-height: 1.65;
  }

  .site-footer__mark {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 4.2rem;
    height: 4.2rem;
    border-radius: 1.2rem;
    padding: 0.24rem;
    background: rgba(255, 255, 255, 0.98);
    box-shadow:
      0 14px 28px rgba(25, 77, 128, 0.08),
      inset 0 0 0 1px rgba(84, 96, 109, 0.08);
  }

  .site-footer__mark img {
    width: 100%;
    height: 100%;
    display: block;
    object-fit: contain;
  }

  .site-footer h3 {
    margin: 0 0 1rem;
    font-size: 0.94rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .site-footer__links,
  .site-footer__notes,
  .site-footer__tags {
    display: grid;
    gap: 0.72rem;
    padding: 0;
    margin: 0;
    list-style: none;
  }

  .site-footer__links a,
  .site-footer__notes a,
  .site-footer__notes li {
    color: var(--color-text-muted);
    font-size: 0.93rem;
    line-height: 1.55;
  }

  .site-footer__tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin-top: 1rem;
  }

  .site-footer__tags li {
    border-radius: 999px;
    padding: 0.4rem 0.72rem;
    background: rgba(25, 77, 128, 0.08);
    color: var(--color-primary);
    font-size: 0.76rem;
    font-weight: 700;
  }

  .site-footer__socials {
    display: flex;
    flex-wrap: wrap;
    gap: 0.65rem;
    margin-top: 1rem;
  }

  .site-footer__social {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 2.9rem;
    height: 2.9rem;
    border-radius: 999px;
    background: rgba(11, 27, 43, 0.92);
    color: white;
    box-shadow:
      0 10px 18px rgba(11, 27, 43, 0.14),
      inset 0 0 0 1px rgba(255, 255, 255, 0.08);
    transition:
      transform 160ms ease,
      box-shadow 160ms ease,
      filter 160ms ease;
  }

  .site-footer__social svg {
    width: 1.2rem;
    height: 1.2rem;
    display: block;
  }

  .site-footer__social:hover,
  .site-footer__social:focus-visible {
    transform: translateY(-2px);
    box-shadow:
      0 14px 24px rgba(11, 27, 43, 0.18),
      inset 0 0 0 1px rgba(255, 255, 255, 0.1);
    filter: saturate(1.08);
  }

  .site-footer__social--whatsapp {
    background: linear-gradient(135deg, #22c55e, #15803d);
  }

  .site-footer__social--instagram {
    background: linear-gradient(135deg, #f58529, #dd2a7b 52%, #515bd4);
  }

  .site-footer__social--x {
    background: linear-gradient(135deg, #111827, #020617);
  }

  .site-footer__social--youtube {
    background: linear-gradient(135deg, #ef4444, #b91c1c);
  }

  .site-footer__website {
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    margin-top: 0.9rem;
    color: var(--color-text);
    font-size: 0.94rem;
    font-weight: 600;
    text-decoration: underline;
    text-decoration-color: rgba(25, 77, 128, 0.3);
    text-underline-offset: 0.18rem;
  }

  .site-footer__website::after {
    content: "\2197";
    font-size: 0.88rem;
  }

  .site-footer__bottom {
    display: flex;
    justify-content: space-between;
    gap: 1rem;
    margin-top: 2rem;
    padding-top: 1.2rem;
    border-top: 1px solid rgba(84, 96, 109, 0.14);
    color: var(--color-text-muted);
    font-size: 0.82rem;
  }

  .site-footer__shipping {
    display: grid;
    gap: 1rem;
    margin-top: 2.2rem;
    padding-top: 1.4rem;
    border-top: 1px solid rgba(84, 96, 109, 0.14);
  }

  .site-footer__shipping-copy {
    display: grid;
    gap: 0.55rem;
    max-width: 58rem;
  }

  .site-footer__shipping-copy h3 {
    margin: 0;
  }

  .site-footer__shipping-copy p {
    margin: 0;
    color: var(--color-text-muted);
    font-size: 0.94rem;
    line-height: 1.65;
  }

  .site-footer__shipping-list {
    display: flex;
    flex-wrap: wrap;
    gap: 0.55rem;
    margin: 0;
    padding: 0;
    list-style: none;
  }

  .site-footer__shipping-list li {
    border-radius: 999px;
    padding: 0.48rem 0.82rem;
    background: rgba(25, 77, 128, 0.07);
    color: var(--color-primary);
    font-size: 0.8rem;
    font-weight: 600;
    line-height: 1.2;
  }

  @media (max-width: 960px) {
    .site-footer__grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }

    .site-footer__bottom {
      flex-direction: column;
    }
  }

  @media (max-width: 640px) {
    .site-footer__grid {
      grid-template-columns: 1fr;
    }
  }
</style>
