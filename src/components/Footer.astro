---
import { business } from '../data/business';

const { brand, legalName, email, phones, address, workingHours, trustChips } = business;

const currentYear = new Date().getFullYear();

const quickLinks = [
  { href: '/', label: 'Home' },
  { href: '/products', label: 'Products' },
  { href: '/about', label: 'About Us' },
  { href: '/contact', label: 'Contact' },
];

const formatWorkingHours = () => {
  const schedule = workingHours.schedule;
  const openDays = schedule.filter(s => s.open !== null).map(s => s.day);
  const closedDays = schedule.filter(s => s.open === null).map(s => s.day);

  const openTime = schedule.find(s => s.open)?.open;
  const closeTime = schedule.find(s => s.close)?.close;

  return {
    days: openDays.join(' - ') + (closedDays.length > 0 ? ` (${closedDays.join(', ')} closed)` : ''),
    time: openTime && closeTime ? `${openTime} - ${closeTime} IST` : ''
  };
};

const hoursInfo = formatWorkingHours();
---

<footer class="footer">
  <div class="container">
    <div class="footer-grid">
      <!-- Brand Section -->
      <div class="footer-brand">
        <a href="/" class="footer-logo">{brand}</a>
        <p class="footer-description">
          {business.descriptionShort}
        </p>
        <div class="trust-chips">
          {trustChips.map((chip) => (
            <span class="chip">{chip}</span>
          ))}
        </div>
      </div>

      <!-- Quick Links -->
      <div class="footer-section">
        <h4 class="footer-heading">Quick Links</h4>
        <ul class="footer-links">
          {quickLinks.map((link) => (
            <li>
              <a href={link.href} class="footer-link">{link.label}</a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Contact Info -->
      <div class="footer-section">
        <h4 class="footer-heading">Contact</h4>
        <ul class="footer-contact">
          <li>
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"></path>
            </svg>
            <span>{phones[0]}</span>
          </li>
          <li>
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"></path>
              <polyline points="22,6 12,13 2,6"></polyline>
            </svg>
            <span>{email}</span>
          </li>
          <li>
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"></path>
              <circle cx="12" cy="10" r="3"></circle>
            </svg>
            <span>{address.city}, {address.state}</span>
          </li>
        </ul>
      </div>

      <!-- Working Hours -->
      <div class="footer-section">
        <h4 class="footer-heading">Working Hours</h4>
        <div class="working-hours">
          <div class="working-hours-badge badge badge-warning">Check Status</div>
          <p class="hours-text">{hoursInfo.days}</p>
          <p class="hours-text">{hoursInfo.time}</p>
        </div>
      </div>
    </div>

    <div class="footer-bottom">
      <p class="copyright">
        &copy; {currentYear} {legalName}. All rights reserved.
      </p>
    </div>
  </div>
</footer>

<style>
  .footer {
    background: var(--color-surface);
    border-top: 1px solid var(--color-border, #e5e7eb);
    padding: var(--space-16) 0 var(--space-8);
    margin-top: auto;
  }

  .footer-grid {
    display: grid;
    gap: var(--space-10);
    grid-template-columns: 1fr;
  }

  @media (min-width: 640px) {
    .footer-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (min-width: 1024px) {
    .footer-grid {
      grid-template-columns: 2fr 1fr 1fr 1fr;
    }
  }

  .footer-logo {
    font-family: var(--font-heading);
    font-size: 1.5rem;
    font-weight: 600;
    color: var(--color-primary);
    text-decoration: none;
  }

  .footer-description {
    color: var(--color-text-muted);
    margin-top: var(--space-3);
    font-size: 0.9375rem;
    line-height: 1.6;
  }

  .trust-chips {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2);
    margin-top: var(--space-4);
  }

  .chip {
    display: inline-block;
    padding: var(--space-1) var(--space-3);
    font-size: 0.75rem;
    font-weight: 500;
    background: var(--color-secondary);
    color: var(--color-text-muted);
    border-radius: var(--radius-full);
  }

  .footer-heading {
    font-size: 1rem;
    font-weight: 600;
    margin-bottom: var(--space-4);
    color: var(--color-text);
  }

  .footer-links {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
  }

  .footer-link {
    color: var(--color-text-muted);
    text-decoration: none;
    transition: color 0.2s ease;
  }

  .footer-link:hover {
    color: var(--color-primary);
  }

  .footer-contact {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
  }

  .footer-contact li {
    display: flex;
    align-items: flex-start;
    gap: var(--space-2);
    color: var(--color-text-muted);
    font-size: 0.9375rem;
  }

  .footer-contact svg {
    flex-shrink: 0;
    margin-top: 2px;
    color: var(--color-primary);
  }

  .hours-text {
    color: var(--color-text-muted);
    font-size: 0.875rem;
    margin-top: var(--space-1);
  }

  .footer-bottom {
    margin-top: var(--space-12);
    padding-top: var(--space-6);
    border-top: 1px solid var(--color-border, #e5e7eb);
  }

  .copyright {
    text-align: center;
    color: var(--color-text-muted);
    font-size: 0.875rem;
  }

  /* Badge styles */
  .badge {
    display: inline-flex;
    align-items: center;
    gap: var(--space-1);
    padding: var(--space-1) var(--space-3);
    font-size: 0.75rem;
    font-weight: 600;
    border-radius: var(--radius-full);
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .badge-warning {
    background: rgba(245, 158, 11, 0.1);
    color: #d97706;
  }
</style>
