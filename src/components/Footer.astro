---
import { business } from "../data/business";
import { getAllCategories } from "../data/catalogue";

const categories = getAllCategories();
const year = new Date().getFullYear();
---

<footer class="site-footer">
  <div class="container site-footer__grid">
    <section class="site-footer__intro">
      <span class="site-footer__mark">
        <img src="/life-equip-logo.png" alt={`${business.brandMark} logo`} />
      </span>
      <h2>{business.brand}</h2>
      <p>{business.shortDescription}</p>
      <ul class="site-footer__tags">
        {business.certifications.map((item) => (
          <li>{item}</li>
        ))}
      </ul>
    </section>

    <section>
      <h3>Catalogue Sections</h3>
      <ul class="site-footer__links">
        {categories.map((category) => (
          <li><a href={`/products/${category.slug}`}>{category.name}</a></li>
        ))}
      </ul>
    </section>

    <section>
      <h3>Company</h3>
      <ul class="site-footer__links">
        <li><a href="/about">About the manufacturer</a></li>
        <li><a href="/products">Browse all product families</a></li>
        <li><a href="/contact">Contact and enquiry status</a></li>
      </ul>
    </section>

    <section>
      <h3>Contact</h3>
      <ul class="site-footer__notes">
        {business.contact.addressLines.map((line) => (
          <li>{line}</li>
        ))}
        {business.contact.phones.map((phone) => (
          <li><a href={`tel:${phone}`}>{phone}</a></li>
        ))}
        {business.contact.telephones.map((phone) => (
          <li><a href={`tel:${phone}`}>{phone}</a></li>
        ))}
        {business.contact.emails.map((email) => (
          <li><a href={`mailto:${email}`}>{email}</a></li>
        ))}
        <li>{business.contact.website}</li>
      </ul>
    </section>
  </div>

  <div class="container site-footer__bottom">
    <span>(c) {year} {business.brand}. All rights reserved.</span>
    <span>Catalogue build prepared for web and future export-driven product collateral.</span>
  </div>
</footer>

<style>
  .site-footer {
    margin-top: 5rem;
    padding: 3rem 0 1.5rem;
    background:
      linear-gradient(180deg, rgba(11, 27, 43, 0.02), rgba(11, 27, 43, 0.07)),
      #f4f7fa;
    border-top: 1px solid rgba(84, 96, 109, 0.16);
  }

  .site-footer__grid {
    display: grid;
    grid-template-columns: 1.6fr 1fr 1fr 1.2fr;
    gap: 2rem;
  }

  .site-footer__intro h2 {
    margin: 0.8rem 0 0.75rem;
    font-size: 1.45rem;
  }

  .site-footer__intro p {
    margin: 0;
    color: var(--color-text-muted);
    line-height: 1.65;
  }

  .site-footer__mark {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 4.2rem;
    height: 4.2rem;
    border-radius: 1.2rem;
    padding: 0.24rem;
    background: rgba(255, 255, 255, 0.98);
    box-shadow:
      0 14px 28px rgba(25, 77, 128, 0.08),
      inset 0 0 0 1px rgba(84, 96, 109, 0.08);
  }

  .site-footer__mark img {
    width: 100%;
    height: 100%;
    display: block;
    object-fit: contain;
  }

  .site-footer h3 {
    margin: 0 0 1rem;
    font-size: 0.94rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .site-footer__links,
  .site-footer__notes,
  .site-footer__tags {
    display: grid;
    gap: 0.72rem;
    padding: 0;
    margin: 0;
    list-style: none;
  }

  .site-footer__links a,
  .site-footer__notes a,
  .site-footer__notes li {
    color: var(--color-text-muted);
    font-size: 0.93rem;
    line-height: 1.55;
  }

  .site-footer__tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin-top: 1rem;
  }

  .site-footer__tags li {
    border-radius: 999px;
    padding: 0.4rem 0.72rem;
    background: rgba(25, 77, 128, 0.08);
    color: var(--color-primary);
    font-size: 0.76rem;
    font-weight: 700;
  }

  .site-footer__bottom {
    display: flex;
    justify-content: space-between;
    gap: 1rem;
    margin-top: 2rem;
    padding-top: 1.2rem;
    border-top: 1px solid rgba(84, 96, 109, 0.14);
    color: var(--color-text-muted);
    font-size: 0.82rem;
  }

  @media (max-width: 960px) {
    .site-footer__grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }

    .site-footer__bottom {
      flex-direction: column;
    }
  }

  @media (max-width: 640px) {
    .site-footer__grid {
      grid-template-columns: 1fr;
    }
  }
</style>
